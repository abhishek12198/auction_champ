  <script>
    (function () {
      var MESSAGES = [
        '🔨 Entering the Arena...',
        '🏆 Loading the Squad...',
        '⚽ Taking the Field...',
        '🏏 Toss in Progress...',
        '🎯 Locking in your Bid...',
        '🏅 Warming Up...',
        '💰 Counting the Purse...',
        '📋 Checking the Roster...',
      ];
      var idx  = 0;
      var msgEl = document.getElementById('ac-load-msg');

      function cycleMsg() {
        msgEl.classList.add('ac-fade');
        setTimeout(function () {
          idx = (idx + 1) % MESSAGES.length;
          msgEl.textContent = MESSAGES[idx];
          msgEl.classList.remove('ac-fade');
        }, 260);
      }

      document.querySelector('form').addEventListener('submit', function () {
        document.getElementById('ac-loader').classList.add('ac-visible');
        setInterval(cycleMsg, 1400);
      });
    })();

    /* ── Logout overlay — shown when ?logged_out=1 is in the URL ──── */
    (function () {
      if (window.location.search.indexOf('logged_out=1') === -1) return;

      // Clean URL immediately so a browser refresh won't re-trigger the overlay
      if (window.history &amp;&amp; window.history.replaceState) {
        window.history.replaceState(null, '', '/web/login');
      }

      var GOODBYE = [
        '\uD83D\uDC4B See You in the Arena!',
        '\uD83C\uDFC6 Champions Always Return',
        '\uD83C\uDFCF Bat Resting\u2026 For Now',
        '\u26BD Off the Pitch, Back Soon',
        '\uD83C\uDFAF Auction Awaits Your Return',
        '\uD83E\uDD47 Till the Next Bid!',
        '\uD83D\uDCB0 Your Purse Is Safe',
        '\uD83D\uDCCB See You Next Season!',
      ];

      var idx    = 0;
      var overlay = document.getElementById('ac-logout-overlay');
      var msgEl   = document.getElementById('ac-logout-msg');

      overlay.classList.add('ac-visible');

      function cycleGoodbye() {
        msgEl.classList.add('ac-fade');
        setTimeout(function () {
          idx = (idx + 1) % GOODBYE.length;
          msgEl.textContent = GOODBYE[idx];
          msgEl.classList.remove('ac-fade');
        }, 260);
      }

      var timer = setInterval(cycleGoodbye, 1400);

      // Fade out after ~3s and reveal the login form beneath
      setTimeout(function () {
        clearInterval(timer);
        overlay.classList.add('ac-fade-out');
        setTimeout(function () {
          overlay.classList.remove('ac-visible');
          overlay.classList.remove('ac-fade-out');
        }, 520);
      }, 3000);
    })();
  </script>

