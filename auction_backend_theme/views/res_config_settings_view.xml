<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inject "Backend App Title" into the General Settings page -->
    <record id="res_config_settings_view_auction_title" model="ir.ui.view">
        <field name="name">res.config.settings.auction.backend.title</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="AuctionChamp" string="AuctionChamp">
                    <h2>AuctionChamp Branding</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="auction_backend_title" string="Backend App Title"/>
                                <div class="text-muted">
                                    Replaces "Odoo" in the browser tab title (e.g. set to <em>AuctionChamp</em> to show "AuctionChamp – Players").
                                </div>
                                <div class="content-group">
                                    <div class="mt8">
                                        <field name="auction_backend_title"
                                               placeholder="AuctionChamp"
                                               class="o_light_label"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
