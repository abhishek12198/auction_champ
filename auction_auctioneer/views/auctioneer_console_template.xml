<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="auctioneer_console_template" name="Auctioneer Console">
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <link rel="shortcut icon" t-att-href="favicon_url" type="image/x-icon"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Auctioneer Console</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;family=Rajdhani:wght@500;600;700&amp;family=Orbitron:wght@700;900&amp;display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="/auction_auctioneer/static/src/css/auctioneer_console.css"/>
</head>
<body class="ac-body" id="acBody">

<!-- ═══ TOP NAV ═══ -->
<nav class="ac-nav">
    <div class="ac-nav__left">
        <t t-if="tournament and tournament.logo">
            <img t-att-src="'/auction/public/image/auction.tournament/%d/logo' % tournament.id"
                 alt="Logo" class="ac-nav__logo"/>
        </t>
        <t t-else="">
            <div class="ac-nav__logo-placeholder"><span>🏏</span></div>
        </t>
        <div class="ac-nav__info">
            <span class="ac-nav__badge">AUCTIONEER CONSOLE</span>
            <span class="ac-nav__tournament-name" t-esc="tournament.name if tournament else 'No Tournament'"/>
        </div>
    </div>
    <div class="ac-nav__center">
        <div class="ac-live-indicator" id="acLiveIndicator">
            <span class="ac-live-dot" id="acStatusDot"></span>
            <span class="ac-live-text" id="acStatusText">Connecting…</span>
        </div>
    </div>
    <div class="ac-nav__right">
        <button class="ac-theme-toggle" id="acThemeToggle" onclick="acToggleTheme()" title="Toggle theme">
            <span id="acThemeIcon">☀</span>
        </button>
        <a href="/web/session/logout" class="ac-btn-logout" title="Logout">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            <span>Logout</span>
        </a>
    </div>
</nav>

<!-- ═══ MAIN LAYOUT ═══ -->
<div class="ac-layout" id="acLayout">

    <!-- ── Player Spotlight Panel ── -->
    <aside class="ac-player-panel" id="acPlayerPanel">

        <div class="ac-player-empty" id="acPlayerEmpty">
            <div class="ac-player-empty__gfx">
                <div class="ac-empty-ring"></div>
                <span class="ac-empty-icon">🏏</span>
            </div>
            <h3 class="ac-player-empty__title">Awaiting Player</h3>
            <p class="ac-player-empty__sub">Bring a player to stage from the auction screen</p>
        </div>

        <div class="ac-player-card" id="acPlayerCard" style="display:none">

            <!-- Tier ribbon -->
            <div class="ac-tier-ribbon" id="acPlayerTier"></div>

            <!-- Photo section -->
            <div class="ac-player-photo-section">
                <div class="ac-player-photo-frame">
                    <img id="acPlayerPhoto" src="" alt="Player" class="ac-player-photo"/>
                    <div class="ac-player-sl-badge" id="acPlayerSl"></div>
                </div>
            </div>

            <!-- Player info -->
            <div class="ac-player-info">
                <h2 class="ac-player-name" id="acPlayerName"></h2>
                <div class="ac-player-meta" id="acPlayerMeta"></div>
            </div>

            <!-- Bid dashboard -->
            <div class="ac-bid-dashboard">
                <div class="ac-bid-stat">
                    <span class="ac-bid-stat__label">BASE</span>
                    <span class="ac-bid-stat__value" id="acBasePrice">—</span>
                </div>
                <div class="ac-bid-stat ac-bid-stat--live">
                    <span class="ac-bid-stat__label">CURRENT BID</span>
                    <span class="ac-bid-stat__value ac-bid-stat__value--big" id="acCurrentBid">—</span>
                </div>
            </div>

            <!-- Current bidder -->
            <div class="ac-current-bidder" id="acCurrentBidder" style="display:none">
                <img id="acBidderLogo" src="" alt="" class="ac-bidder-logo"/>
                <div class="ac-bidder-info">
                    <span class="ac-bidder-label">HIGHEST BID</span>
                    <span id="acBidderName" class="ac-bidder-name"></span>
                </div>
            </div>

            <!-- Action buttons -->
            <div class="ac-player-actions">
                <button class="ac-btn ac-btn--reset" id="acResetBidBtn" onclick="acResetBid()" style="display:none">
                    <span class="ac-btn__icon">↩</span> RESET BID
                </button>
                <button class="ac-btn ac-btn--sold" id="acFinalizeBtn" onclick="acFinalizeBid()" style="display:none">
                    <span class="ac-btn__icon">🔨</span> SOLD!
                </button>
            </div>
        </div>
    </aside>

    <!-- ── Teams Panel ── -->
    <main class="ac-teams-panel">
        <div class="ac-teams-header">
            <div class="ac-teams-header__left">
                <h3 class="ac-teams-title">TEAMS</h3>
                <span class="ac-teams-subtitle">Tap a team to place a bid</span>
            </div>
            <span class="ac-teams-count-badge" id="acTeamsCount"></span>
        </div>
        <div class="ac-teams-grid" id="acTeamsGrid">
            <!-- Populated by JS -->
        </div>
    </main>

</div>

<!-- ═══ BID MODAL ═══ -->
<div class="ac-overlay" id="acBidModal" style="display:none" onclick="acCloseBidModal(event)">
    <div class="ac-modal">
        <button class="ac-modal__close" onclick="acCloseBidModal()">✕</button>

        <div class="ac-modal__header">
            <img id="acModalTeamLogo" src="" alt="" class="ac-modal__team-logo"/>
            <div class="ac-modal__team-text">
                <h2 class="ac-modal__team-name" id="acModalTeamName"></h2>
                <p class="ac-modal__team-meta" id="acModalTeamMeta"></p>
            </div>
        </div>

        <div class="ac-modal__sep"></div>

        <div class="ac-modal__player-row">
            <img id="acModalPlayerPhoto" src="" alt="" class="ac-modal__player-photo"/>
            <div class="ac-modal__player-info">
                <h3 class="ac-modal__player-name" id="acModalPlayerName"></h3>
                <p class="ac-modal__player-role" id="acModalPlayerRole"></p>
                <span class="ac-tier-pill" id="acModalTierBadge"></span>
            </div>
        </div>

        <div class="ac-modal__sep"></div>

        <div class="ac-bid-control">
            <div class="ac-bid-control__limits">
                <div class="ac-bid-limit">
                    <span class="ac-bid-limit__label">Base Price</span>
                    <span class="ac-bid-limit__val" id="acModalBase"></span>
                </div>
                <div class="ac-bid-limit ac-bid-limit--max">
                    <span class="ac-bid-limit__label">Max Call</span>
                    <span class="ac-bid-limit__val" id="acModalMax"></span>
                </div>
            </div>
            <label class="ac-bid-control__label">POINTS TO CALL</label>
            <div class="ac-bid-control__row">
                <button class="ac-bid-adj" id="acBidDecBtn" onclick="acAdjustBid(-1)">−</button>
                <input type="number" class="ac-bid-input" id="acBidInput" min="0" step="1"/>
                <button class="ac-bid-adj" id="acBidIncBtn" onclick="acAdjustBid(1)">+</button>
            </div>
            <p class="ac-bid-hint" id="acBidHint"></p>
        </div>

        <button class="ac-btn ac-btn--place-bid" id="acPlaceBidBtn" onclick="acPlaceBid()">
            🔨 &#160;PLACE BID
        </button>
    </div>
</div>

<!-- ═══ CONFIRM SOLD MODAL ═══ -->
<div class="ac-overlay ac-overlay--dark" id="acSoldConfirmModal" style="display:none">
    <div class="ac-sold-modal">
        <div class="ac-sold-modal__icon">🔨</div>
        <h2 class="ac-sold-modal__title">Confirm Sale</h2>
        <p class="ac-sold-modal__sub">This action cannot be undone</p>

        <div class="ac-sold-deal">
            <div class="ac-sold-deal__side">
                <div class="ac-sold-deal__img-wrap">
                    <img id="acSoldPlayerPhoto" src="" alt="" class="ac-sold-deal__img"/>
                    <span class="ac-sold-deal__tier-tag" id="acSoldPlayerTier"></span>
                </div>
                <div class="ac-sold-deal__name" id="acSoldPlayerName"></div>
                <div class="ac-sold-deal__role" id="acSoldPlayerRole"></div>
            </div>

            <div class="ac-sold-deal__center">
                <div class="ac-sold-deal__pts" id="acSoldBidPts"></div>
                <div class="ac-sold-deal__pts-label">pts</div>
                <div class="ac-sold-deal__arrow">→</div>
            </div>

            <div class="ac-sold-deal__side">
                <div class="ac-sold-deal__img-wrap">
                    <img id="acSoldTeamLogo" src="" alt="" class="ac-sold-deal__img ac-sold-deal__img--team"/>
                </div>
                <div class="ac-sold-deal__name" id="acSoldTeamName"></div>
                <div class="ac-sold-deal__role" id="acSoldTeamMeta"></div>
            </div>
        </div>

        <div class="ac-sold-modal__actions">
            <button class="ac-btn ac-btn--cancel" onclick="acCancelSoldConfirm()">✕ Cancel</button>
            <button class="ac-btn ac-btn--confirm-sold" id="acSoldConfirmBtn" onclick="acConfirmSold()">
                🏆 CONFIRM SOLD!
            </button>
        </div>
    </div>
</div>

<!-- ═══ TOAST ═══ -->
<div class="ac-toast" id="acToast"></div>

<!-- ═══ JS ═══ -->
<script>
window.AC_DATA_URL      = '/auction/auctioneer/data';
window.AC_BID_URL       = '/auction/auctioneer/place-bid';
window.AC_RESET_URL     = '/auction/auctioneer/reset-bid';
window.AC_FINALIZE_URL  = '/auction/auctioneer/finalize-bid';
window.AC_CSRF_TOKEN    = '<t t-esc="request.csrf_token()"/>';

// Theme init before paint
(function() {
    var saved = localStorage.getItem('ac_theme') || 'dark';
    document.getElementById('acBody').setAttribute('data-theme', saved);
    var icon = document.getElementById('acThemeIcon');
    if (icon) icon.textContent = saved === 'dark' ? '☀' : '🌙';
})();

window.acToggleTheme = function() {
    var body = document.getElementById('acBody');
    var cur  = body.getAttribute('data-theme') || 'dark';
    var next = cur === 'dark' ? 'light' : 'dark';
    body.setAttribute('data-theme', next);
    localStorage.setItem('ac_theme', next);
    document.getElementById('acThemeIcon').textContent = next === 'dark' ? '☀' : '🌙';
};
</script>
<script src="/auction_auctioneer/static/src/js/auctioneer_console.js"></script>
</body>
</html>
</template>
</odoo>
