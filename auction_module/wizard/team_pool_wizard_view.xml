<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_team_pool_wizard_form" model="ir.ui.view">
        <field name="name">auction.team.pool.wizard.form</field>
        <field name="model">auction.team.pool.wizard</field>
        <field name="arch" type="xml">
            <form string="Team Pool Generator" class="o_form_sheet">

                <!-- fields used in attrs must be declared in the view -->
                <field name="pool_structure_json" invisible="1"/>

                <group string="Select Teams">
                    <field name="team_ids" nolabel="1">
                        <kanban class="o_kanban_mobile" create="0" edit="0">
                            <field name="name"/>
                            <field name="logo"/>
                            <field name="tournament_id"/>
                            <field name="manager"/>
                            <field name="key_player_ids"/>
                            <field name="id"/>
                            <templates>
                                <t t-name="kanban-box">
                                    <div class="oe_kanban_global_click o_kanban_record">
                                        <div class="o_kanban_image">
                                            <img alt="Avatar" t-att-src="kanban_image('auction.team', 'logo', record.id.raw_value)"/>
                                        </div>
                                        <div class="o_kanban_details">
                                            <strong t-esc="record.name.raw_value"/>
                                            <div t-if="record.manager">
                                                <span> Manager: </span>
                                                <field name="manager"/>
                                            </div>
                                            <div t-if="record.key_player_ids">
                                                <span> Icon Player: </span>
                                                <field name="key_player_ids" widget="many2many_tags"/>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                </group>

                <group>
                    <field name="selected_team_count" readonly="1" force_save="1"/>
                    <field name="pool_count"/>
                </group>

                <!-- Pool names table — always visible so user can rename before or after -->
                <separator string="Pool Names"/>
                <p class="text-muted" style="font-size:.82rem;margin:-4px 0 8px;">
                    Edit the <b>Pool Name</b> column to give each pool a custom name (e.g. Blue Group, Red Group).
                    Names are preserved when you change the pool count.
                    After generating, click <b>Apply Custom Names</b> to rename without reshuffling teams.
                </p>
                <field name="pool_name_ids" nolabel="1">
                    <tree editable="bottom" create="0" delete="0">
                        <field name="pool_index" string="#" readonly="1"/>
                        <field name="default_label" string="Default" readonly="1"/>
                        <field name="custom_name" string="Pool Name"/>
                    </tree>
                </field>

                <footer>
                    <!-- Before generation -->
                    <button
                        name="action_generate_pools"
                        type="object"
                        string="Generate Pools"
                        class="btn btn-primary"
                        attrs="{'invisible': [('result_html', '!=', False)]}"
                    />

                    <!-- After generation -->
                    <button
                        name="action_apply_names"
                        type="object"
                        string="🎨 Apply Custom Names"
                        class="btn btn-info"
                        attrs="{'invisible': [('result_html', '=', False)]}"
                    />
                    <button
                        name="action_reset"
                        string="↺ Reshuffle"
                        class="btn btn-secondary"
                        type="object"
                        attrs="{'invisible': [('result_html', '=', False)]}"
                    />
                </footer>

                <div class="mt-3 text-end" attrs="{'invisible': [('result_html', '=', False)]}">
                    <a
                        href="#"
                        class="btn btn-outline-primary o_take_pool_snapshot"
                        role="button"
                    >
                        📸 Take Pool Snapshot
                    </a>
                </div>

                <separator string="Pool Result"/>

                <div id="pool_snapshot_container">
                    <field name="result_html" nolabel="1"/>
                </div>

                <!-- ── Fixture Generator ──────────────────────────────── -->
                <div attrs="{'invisible': [('pool_structure_json', '=', False)]}">
                    <separator string="Fixture Generator"/>
                    <p class="text-muted" style="font-size:.82rem;margin:-4px 0 10px;">
                        Choose a fixture type and click <b>Generate Fixture</b>.
                        Then <b>drag</b> match cards to reorder — numbers update live.
                        Click <b>📸 Download Fixture Image</b> to save the final arrangement.
                    </p>
                    <group>
                        <field name="fixture_type" string="Fixture Type"/>
                        <field
                            name="outside_pool_count"
                            string="Teams per Team Outside Pool (N)"
                            attrs="{'invisible': [('fixture_type', '!=', 'custom_outside')],
                                    'required':  [('fixture_type', '=',  'custom_outside')]}"
                        />
                    </group>
                    <div class="o_row">
                        <button
                            name="action_generate_fixture"
                            type="object"
                            string="📋 Generate Fixture"
                            class="btn btn-success"
                        />
                    </div>

                    <!-- fixture_html carries embedded JSON for JS; shown as a small status line -->
                    <div attrs="{'invisible': [('fixture_html', '=', False)]}" class="mt-2">
                        <field name="fixture_html" nolabel="1" readonly="1"/>
                    </div>

                    <!-- Drag-and-drop fixture board — populated by fixture_dnd.js -->
                    <div attrs="{'invisible': [('fixture_html', '=', False)]}">
                        <separator string="Fixture Schedule — Drag to Reorder"/>
                        <div id="fixture_dnd_container" style="min-height:60px;"/>
                        <div class="mt-2 text-end">
                            <a href="#" class="btn btn-outline-success o_take_fixture_snapshot" role="button">
                                📸 Download Fixture Image
                            </a>
                        </div>
                    </div>
                </div>

            </form>
        </field>
    </record>

    <record id="action_team_pool_wizard" model="ir.actions.act_window">
        <field name="name">Team Pool Generator</field>
        <field name="res_model">auction.team.pool.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

</odoo>
