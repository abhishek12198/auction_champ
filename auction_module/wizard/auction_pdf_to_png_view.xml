<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_auction_pdf_to_png_form" model="ir.ui.view">
            <field name="name">auction.pdf.to.png.form</field>
            <field name="model">auction.pdf.to.png</field>
            <field name="arch" type="xml">
                <form string="Convert Player Cards PDF to PNG">
                    <sheet>

                        <!-- Upload section -->
                        <div attrs="{'invisible': [('state', '=', 'done')]}">
                            <div class="oe_title">
                                <h2>Convert Player Cards PDF → PNG ZIP</h2>
                            </div>
                            <p class="text-muted">
                                Upload a player cards PDF. Each page will be converted to a
                                high-resolution PNG image. If a tournament is selected, images
                                are named by player serial number (e.g. <code>5.png</code>);
                                otherwise by page number.
                            </p>
                            <group>
                                <group string="Input">
                                    <field name="pdf_file" filename="pdf_filename" widget="binary" required="1"/>
                                    <field name="pdf_filename" invisible="1"/>
                                </group>
                                <group string="Naming">
                                    <field name="tournament_id" options="{'no_create': True}"/>
                                </group>
                            </group>
                        </div>

                        <!-- Result section -->
                        <div attrs="{'invisible': [('state', '=', 'draft')]}">
                            <div class="alert alert-success" role="alert">
                                <strong>&#10003; Conversion complete!</strong>
                                <field name="page_count" readonly="1" nolabel="1"
                                       style="display:inline;margin-left:6px;"/>
                                pages converted. Click below to download the ZIP.
                            </div>
                            <group>
                                <group string="Download">
                                    <field name="zip_file" filename="zip_filename" widget="binary" readonly="1"/>
                                    <field name="zip_filename" invisible="1"/>
                                </group>
                            </group>
                        </div>

                        <field name="state" invisible="1"/>
                    </sheet>

                    <footer>
                        <button name="action_convert" string="Convert to PNG" type="object"
                                class="oe_highlight"
                                attrs="{'invisible': [('state', '=', 'done')]}"/>
                        <button name="action_reset" string="Convert Another" type="object"
                                attrs="{'invisible': [('state', '=', 'draft')]}"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_auction_pdf_to_png" model="ir.actions.act_window">
            <field name="name">Convert PDF to PNG</field>
            <field name="res_model">auction.pdf.to.png</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_auction_pdf_to_png_form"/>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
