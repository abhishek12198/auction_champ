<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_auction_sell_player" model="ir.ui.view">
            <field name="name">auction.sell.player.form</field>
            <field name="model">auction.sell.player</field>
            <field name="arch" type="xml">
                <form string="Sell Player" class="o_asp_wizard">

                    <!-- Player identity header -->
                    <div class="asp-header">
                        <div class="asp-photo-wrap">
                            <field name="player_photo" widget="image" readonly="1"/>
                        </div>
                        <div class="asp-header-meta">
                            <div class="asp-header-label">Selling Player</div>
                            <div class="asp-header-name">
                                <field name="player_id" readonly="1" force_save="1"/>
                            </div>
                        </div>
                        <div class="asp-header-tag">
                            <i class="fa fa-tag" title="Sale"/>
                        </div>
                    </div>

                    <!-- Team selector -->
                    <div class="asp-section">
                        <div class="asp-section-label">
                            <i class="fa fa-shield" title="Team"/> Select Team
                        </div>
                        <field name="team_selection" widget="selection_badge"/>
                        <field name="team_id" invisible="1" required="0"
                               options="{'no_open': True, 'no_create': True}"/>
                        <field name="team_auction_id" invisible="1"/>
                    </div>

                    <!-- Team info card: appears when a team with auction is selected -->
                    <div class="asp-info-card" attrs="{'invisible': [('team_auction_id', '=', False)]}">
                        <div class="asp-team-row">
                            <div class="asp-team-logo-wrap">
                                <field name="team_logo" widget="image" readonly="1"/>
                            </div>
                            <div class="asp-team-details">
                                <div class="asp-team-name">
                                    <field name="team_name" readonly="1"/>
                                </div>
                                <div class="asp-stat-row">
                                    <div class="asp-stat-chip">
                                        <i class="fa fa-bolt" title="Points"/>
                                        <field name="points_remaining" readonly="1" force_save="1"/>
                                        <span>pts left</span>
                                    </div>
                                    <div class="asp-stat-chip">
                                        <i class="fa fa-users" title="Slots"/>
                                        <field name="players_remaining" readonly="1" force_save="1"/>
                                        <span>slots</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="asp-suggestion" attrs="{'invisible': [('suggestion', '=', False)]}">
                            <field name="suggestion" readonly="1" nolabel="1"/>
                        </div>
                    </div>

                    <!-- Points input -->
                    <div class="asp-section">
                        <div class="asp-section-label">
                            <i class="fa fa-money" title="Points"/> Selling Points
                        </div>
                        <div class="asp-points-card">
                            <i class="fa fa-trophy asp-points-icon" title="Points"/>
                            <field name="final_point" class="asp-points-input"/>
                        </div>
                    </div>

                    <footer>
                        <button string="Confirm Sale" type="object" class="btn-primary"
                                name="button_sell_player" onclick="window.playSoldSound()"
                                confirm="Confirm selling this player to the selected team for the stated points?"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>

                </form>
            </field>
        </record>

        <record id="action_auction_sell_player" model="ir.actions.act_window">
            <field name="name">Sell Player</field>
            <field name="res_model">auction.sell.player</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>

        </record>

    </data>
</odoo>
