<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_auction_set_key_player" model="ir.ui.view">
            <field name="name">auction.set.key.player.form</field>
            <field name="model">auction.set.key.player</field>
            <field name="arch" type="xml">
                <form string="Assign Icon Player" class="o_skp_wizard">

                    <!-- Player identity header -->
                    <div class="skp-header">
                        <div class="skp-photo-wrap">
                            <field name="player_photo" widget="image" readonly="1"/>
                        </div>
                        <div class="skp-header-meta">
                            <div class="skp-header-label">Assigning Icon Player</div>
                            <div class="skp-header-name">
                                <field name="player_id" readonly="1" force_save="1"/>
                            </div>
                        </div>
                        <div class="skp-header-star">
                            <i class="fa fa-star"/>
                        </div>
                    </div>

                    <!-- Team selector -->
                    <div class="skp-section">
                        <div class="skp-section-label">
                            <i class="fa fa-shield"/> Select Team
                        </div>
                        <field name="team_selection" widget="selection_badge"/>
                        <field name="team_id" invisible="1" required="0"
                               options="{'no_open': True, 'no_create': True}"/>
                    </div>

                    <!-- Assignment preview card — appears once a team is selected -->
                    <div class="skp-assign-card" attrs="{'invisible': [('team_logo', '=', False)]}">

                        <!-- Visual: player ──⭐── team -->
                        <div class="skp-assign-visual">
                            <div class="skp-av-player">
                                <field name="player_photo" widget="image" readonly="1"/>
                            </div>
                            <div class="skp-av-connector">
                                <div class="skp-av-line"/>
                                <div class="skp-av-star"><i class="fa fa-star"/></div>
                                <div class="skp-av-line"/>
                            </div>
                            <div class="skp-av-team">
                                <field name="team_logo" widget="image" readonly="1"/>
                            </div>
                        </div>

                        <!-- Confirmation sentence -->
                        <div class="skp-assign-info">
                            <i class="fa fa-info-circle skp-info-icon"/>
                            <span>
                                <field name="player_id" readonly="1" class="skp-info-name"/>
                                <span class="skp-info-label"> will be the Icon Player for </span>
                                <field name="team_id" readonly="1" class="skp-info-team"/>
                            </span>
                        </div>

                    </div>

                    <footer>
                        <button string="Confirm &amp; Set as Icon Player" type="object"
                                class="btn-primary" name="button_set_keyplayer"
                                confirm="This will promote the player to Icon Player status and assign them to the selected team. Continue?"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>

                </form>
            </field>
        </record>

        <record id="action_auction_set_key_player" model="ir.actions.act_window">
            <field name="name">Assign Key Player</field>
            <field name="res_model">auction.set.key.player</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
