<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!--
        TOURNAMENT-BASED DATA ISOLATION
        ================================
        Two complementary rules per model:

          1. "<Model>: own tournament only"
             Targets group_auction_group (the base group ALL non-admin Auction users
             belong to). Domain restricts records to the user's assigned tournament.

          2. "<Model>: admin sees all"
             Targets group_auction_group_admin. Domain = (1=1), unconditionally
             allows all records.

        Because group_auction_group_admin *implies* group_auction_group, an admin
        user matches BOTH rules. Odoo ORs same-model rules when a user belongs to
        all their groups → admin sees everything.

        A plain non-admin user only matches rule #1 → sees only their tournament.
    -->

    <!-- ═══════════════════════════════════════════════════════
         auction.tournament
    ═══════════════════════════════════════════════════════════ -->
    <record id="rule_tournament_own" model="ir.rule">
        <field name="name">Tournament: own tournament only</field>
        <field name="model_id" ref="auction_module.model_auction_tournament"/>
        <field name="groups" eval="[(4, ref('auction_module.group_auction_group'))]"/>
        <field name="domain_force">[('id', '=', user.tournament_id.id)]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_tournament_admin_all" model="ir.rule">
        <field name="name">Tournament: admin sees all</field>
        <field name="model_id" ref="auction_module.model_auction_tournament"/>
        <field name="groups" eval="[(4, ref('auction_module.group_auction_group_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

