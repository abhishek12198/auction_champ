<odoo>
    <data>
        <record id="action_report_auction_players" model="ir.actions.report">
            <field name="name">Auction Players</field>
            <field name="model">auction.auction</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">auction_module.report_auction_auction_document</field>
            <field name="report_file">auction_module.report_auction_auction_document</field>
            <field name="paperformat_id" ref="auction_module.paperformat_a4_roster"/>
            <field name="print_report_name">'%s Squad Roster' % ((object.team_id.name or 'Team'))</field>
        </record>

        <!-- Blank squad template (placeholder rows for manual fill-in) -->
        <record id="action_report_auction_template" model="ir.actions.report">
            <field name="name">Squad Template</field>
            <field name="model">auction.auction</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">auction_module.report_auction_blank_template</field>
            <field name="report_file">auction_module.report_auction_blank_template</field>
            <field name="paperformat_id" ref="auction_module.paperformat_a4_roster"/>
            <field name="print_report_name">'%s Squad Template' % ((object.team_id.name or 'Team'))</field>
        </record>

        <!-- Player card list print – Vanilla (not bound to Print menu; use Print Player Cards action instead) -->
        <record id="action_report_player_card" model="ir.actions.report">
            <field name="name">Player Card</field>
            <field name="model">auction.team.player</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">auction_module.report_player_card_list</field>
            <field name="report_file">auction_module.report_player_card_list</field>
            <field name="paperformat_id" ref="auction_module.paperformat_card_landscape"/>
            <field name="print_report_name">"Player Card - %s" % (object.tournament_id.name)</field>
            <field name="groups_id" eval="[(4, ref('auction_module.group_auction_player_card_print'))]"/>
        </record>

        <!-- Player card list print – Butterscotch -->
        <record id="action_report_player_card_butterscotch" model="ir.actions.report">
