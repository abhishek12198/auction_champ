            <field name="report_type">qweb-pdf</field>
            <field name="report_name">auction_module.report_player_card_list_strawberry</field>
            <field name="report_file">auction_module.report_player_card_list_strawberry</field>
            <field name="paperformat_id" ref="auction_module.paperformat_card_landscape"/>
            <field name="print_report_name">"Player Card - %s" % (object.tournament_id.name)</field>
            <field name="groups_id" eval="[(4, ref('auction_module.group_auction_player_card_print'))]"/>
        </record>

        <record id="action_report_player_card_cherry" model="ir.actions.report">
