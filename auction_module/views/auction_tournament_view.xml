<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_auction_tournament_search" model="ir.ui.view">
            <field name="name">auction.tournament.search</field>
            <field name="model">auction.tournament</field>
            <field name="arch" type="xml">
                <search string="Tournament">
                    <field name="name" filter_domain="[('name','ilike',self)]" string="Name"/>
                </search>
            </field>
        </record>

        <record id="view_auction_tournament_tree" model="ir.ui.view">
            <field name="name">auction.tournament.tree</field>
            <field name="model">auction.tournament</field>
            <field name="arch" type="xml">
                <tree string="Team">
                    <field name="name"/>
                    <field name="tournament_type"/>
                </tree>
            </field>
        </record>

        <record id="view_auction_tournament_form" model="ir.ui.view">
            <field name="name">auction.tournament.form</field>
            <field name="model">auction.tournament</field>
            <field name="arch" type="xml">
                <form string="Tournament">
                    <header>
                        <button name="action_deactivate_tournament"
                                type="object"
                                string="Deactivate Tournament"
                                class="btn-danger"
                                confirm="This will archive the tournament and ALL its related records (players, teams, auctions, history). This cannot be undone easily. Are you sure?"
                                attrs="{'invisible': [('active', '=', False)]}"/>
                        <button name="action_remove_duplicates"


                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-clone">
                            </button>
                    </header>
                    <sheet>
                        <field name="active" invisible="1"/>
                        <field name="registration_open" invisible="1"/>
                        <field name="live_board_active" invisible="1"/>
                        <field name="break_time_active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                attrs="{'invisible': [('active', '=', True)]}"/>

                        <!-- ── Smart buttons ── -->
                        <div class="oe_button_box" name="button_box">
                            <!-- Toggle registration open/closed -->
                            <button name="action_toggle_registration"
                                    type="object"
                                    class="oe_stat_button"
                                    attrs="{'invisible': [('registration_open', '=', False)]}"
                                    icon="fa-check-circle"
                                    help="Registration is OPEN — click to close it">
                                <div class="o_stat_info">
                                    <span class="o_stat_text text-success">Registration</span>
                                    <span class="o_stat_text text-success" style="font-size:10px">OPEN &#8212; Click to Close</span>
                                </div>
                            </button>
                            <button name="action_toggle_registration"
                                    type="object"
                                    class="oe_stat_button"
                                    attrs="{'invisible': [('registration_open', '=', True)]}"
                                    icon="fa-ban"
                                    help="Registration is CLOSED — click to open it">
                                <div class="o_stat_info">
                                    <span class="o_stat_text text-danger">Registration</span>
                                    <span class="o_stat_text text-danger" style="font-size:10px">CLOSED &#8212; Click to Open</span>
                                </div>
                            </button>
                            <!-- Live Board toggle -->
                            <button name="action_toggle_live_board"
                                    type="object"
                                    class="oe_stat_button"
                                    attrs="{'invisible': [('live_board_active', '=', False)]}"
                                    icon="fa-broadcast-tower"
                                    help="Live Board is ACTIVE — click to stop it">
                                <div class="o_stat_info">
                                    <span class="o_stat_text text-success">Live Board</span>
                                    <span class="o_stat_text text-success" style="font-size:10px">LIVE &#8212; Click to Stop</span>
                                </div>
                            </button>
                            <button name="action_toggle_live_board"
                                    type="object"
                                    class="oe_stat_button"
                                    attrs="{'invisible': [('live_board_active', '=', True)]}"
                                    icon="fa-pause-circle"
                                    help="Live Board is STOPPED — click to start it">
                                <div class="o_stat_info">
                                    <span class="o_stat_text text-danger">Live Board</span>
                                    <span class="o_stat_text text-danger" style="font-size:10px">STOPPED &#8212; Click to Start</span>
                                </div>
                            </button>
                            <!-- Break Time toggle -->
                            <button name="action_toggle_break_time"
                                    type="object"
                                    class="oe_stat_button"
                                    attrs="{'invisible': [('break_time_active', '=', False)]}"
                                    icon="fa-coffee"
                                    help="Break Time is ACTIVE — click to resume live board">
                                <div class="o_stat_info">
                                    <span class="o_stat_text text-warning">Break Time</span>
                                    <span class="o_stat_text text-warning" style="font-size:10px">ON &#8212; Click to Resume</span>
                                </div>
                            </button>
                            <button name="action_toggle_break_time"
                                    type="object"
                                    class="oe_stat_button"
                                    attrs="{'invisible': [('break_time_active', '=', True)]}"
                                    icon="fa-coffee"
                                    help="Show a Break Time screen on the live board">
                                <div class="o_stat_info">
                                    <span class="o_stat_text text-muted">Break Time</span>
                                    <span class="o_stat_text text-muted" style="font-size:10px">OFF &#8212; Click to Start</span>
                                </div>
                            </button>
                            <!-- Registered player count stat button -->
                            <button class="oe_stat_button" type="object"
                                    name="action_toggle_registration"
                                    icon="fa-users"
                                    help="Players registered (Draft state)">
                                <field name="registered_player_count" widget="statinfo"
                                       string="Registered"/>
                                <div class="o_stat_info" attrs="{'invisible': [('max_registrations', '=', 0)]}">
                                    <span class="o_stat_text text-muted" style="font-size:10px;">
                                        of <field name="max_registrations" nolabel="1" style="display:inline"/> max
                                    </span>
                                </div>
                            </button>
                            <!-- Open the public form in a new tab -->
                            <button name="action_open_registration_link"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-share-alt">
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Preview Form</span>
                                    <span class="o_stat_text text-muted" style="font-size:10px">Open in New Tab</span>
                                </div>
                            </button>
                            <!-- Remove duplicate players -->
                            <!-- Clear On-Stage Players -->
                            <button name="action_clear_stage"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-times-circle"
                                    confirm="This will clear all players currently on stage. Continue?"
                                    help="Remove the on-stage flag from all players (resets the live auction display)">
                                <div class="o_stat_info">
                                    <span class="o_stat_text text-danger">Clear Stage</span>
                                    <span class="o_stat_text text-danger" style="font-size:10px">Reset On-Stage</span>
                                </div>
                            </button>

                        </div>

                        <!-- ── Header: Logo + Title ── -->
                        <div class="d-flex align-items-start mb-3">
                            <field name="logo" widget="image" class="oe_avatar mr-3"
                                   options="{'preview_image': 'logo', 'size': [128, 128]}"/>
                            <div class="flex-grow-1">
                                <div class="oe_title">
                                    <label for="name" class="oe_edit_only"/>
                                    <h1>
                                        <field name="name" placeholder="e.g. IPL Auction 2025"/>
                                    </h1>
                                    <label for="description" class="oe_edit_only"/>
                                    <h4 class="text-muted">
                                        <field name="description" placeholder="Short description of the tournament"/>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <!-- ── Core Settings: 2-column grid ── -->
                        <group>
                            <group string="Tournament Info">
                                <field name="tournament_type" widget="radio" options="{'horizontal': True}"/>
                                <field name="tournament_date"/>
                                <field name="organizer_uid"/>
                                <field name="organizer_uids" widget="many2many_tags"
                                       options="{'color_field': 'color'}"/>
                            </group>
                            <group string="Auction Configuration">
                                <field name="team_max_points"/>
                                <field name="player_appearance_algorithm" widget="radio"/>
                            </group>
                        </group>

                        <!-- ── Notebook ── -->
                        <notebook>

                            <!-- Tab 1: Teams -->
                            <page string="Teams" name="teams">
                                <field name="team_ids" widget="many2many">
                                    <kanban class="o_kanban_mobile">
                                        <field name="name"/>
                                        <field name="logo"/>
                                        <field name="manager"/>
                                        <field name="id"/>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div class="oe_kanban_global_click o_kanban_record">
                                                    <div class="o_kanban_image">
                                                        <img alt="Avatar" t-att-src="kanban_image('auction.team', 'logo', record.id.raw_value)"/>
                                                    </div>
                                                    <div class="o_kanban_details">
                                                        <strong t-esc="record.name.raw_value"/>
                                                        <div t-if="record.manager.raw_value">
                                                            <span class="text-muted">Owner: </span>
                                                            <field name="manager"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>

                            <!-- Tab 2: Points & Bid Slabs -->
                            <page string="Points &amp; Bid Slabs" name="points_slabs">
                                <separator string="Bid Point Slabs"/>
                                <p class="text-muted o_form_label">
                                    Define the bidding increments at each point level. Teams can raise bids in steps defined here.
                                </p>
                                <field name="points_split_ids" nolabel="1">
                                    <tree editable="bottom">
                                        <field name="points" string="Starting Points"/>
                                        <field name="no_of_calls" string="Bid Step (No. of Calls)"/>
                                    </tree>
                                </field>
                            </page>

                            <!-- Tab 3: Presentation & Theme -->
                            <page string="Presentation &amp; Theme" name="presentation">
                                <separator string="Auction Display Theme"/>
                                <group>
                                    <group>
                                        <field name="player_display_template" widget="radio"
                                               options="{'horizontal': True}"/>
                                        <field name="sold_display_seconds"/>
                                        <field name="next_player_countdown"/>
                                        <field name="preset_points"
                                               placeholder="e.g. 100,200,500,1000,1500"
                                               help="Comma-separated point values shown as quick-select buttons in the Sell Player modal"/>
                                        <field name="enable_jersey_section"/>
                                    </group>
                                </group>

                                <separator string="Player Self-Registration"/>
                                <group>
                                    <group string="Registration Link">
                                        <field name="registration_url" widget="CopyClipboardChar"
                                               readonly="1" string="Share URL"/>
                                    </group>
                                    <group>
                                        <p class="text-muted" style="margin-top:6px;">
                                            Share this link with players so they can fill in their own
                                            profile. Registrations arrive as <strong>Draft</strong> players.
                                        </p>
                                    </group>
                                </group>

                                <group attrs="{'invisible': [('player_appearance_algorithm', '!=', 'linear')]}">
                                    <separator string="Projector View"/>
                                    <group string="Projector URL">
                                        <field name="projector_url" widget="CopyClipboardChar"
                                               readonly="1" string="Share URL"/>
                                    </group>
                                    <group>
                                        <p class="text-muted" style="margin-top:6px;">
                                            Open this URL on a projector or large screen during a
                                            <strong>Manual</strong> auction. It updates in real-time
                                            as you select players from the deck.
                                        </p>
                                    </group>
                                </group>
                                <group>
                                    <group string="Registration Limit">
                                        <field name="max_registrations"
                                               help="Set the maximum number of players that can register. Registration closes automatically once this limit is reached. Set to 0 for unlimited."/>
                                    </group>
                                    <group>
                                        <p class="text-muted" style="margin-top:6px;">
                                            Set to <strong>0</strong> for unlimited registrations.
                                            Once the limit is reached, registration is automatically closed.
                                        </p>
                                    </group>
                                </group>

                                <separator string="Payment Section"/>
                                <p class="text-muted o_form_label" style="margin-bottom:12px;">
                                    Configure what players see in the <strong>Payment Proof</strong>
                                    section of the registration form. Add a QR code so they can scan
                                    and pay, then attach the screenshot.
                                </p>
                                <group>
                                    <group string="Payment QR / Scanner">
                                        <field name="payment_qr_image" widget="image" nolabel="1"
                                               options="{'preview_image': 'payment_qr_image', 'size': [200, 200]}"/>
                                        <p class="text-muted" style="margin-top:8px; font-size:12px;">
                                            Upload your UPI / payment QR code (PNG recommended, square format).
                                            Players can scan it directly from the registration page.
                                        </p>
                                    </group>
                                    <group string="Payment Instructions">
                                        <field name="payment_instruction" nolabel="1"
                                               placeholder="e.g. Pay ₹500 via UPI to 9876543210@paytm. Add your name as payment reference, then attach the screenshot below."/>
                                        <p class="text-muted" style="margin-top:8px; font-size:12px;">
                                            This text is shown as an instruction box above the upload
                                            area on the registration page.
                                        </p>
                                    </group>
                                </group>

                            </page>

                            <!-- Tab 4: Venue -->
                            <page string="Venue" name="venue">
                                <group>
                                    <field name="venue" nolabel="1"
                                           placeholder="Enter the venue name, address, city and any other location details..."/>
                                </group>
                            </page>

                            <!-- Tab 5: Rules & Regulations -->
                            <page string="Rules &amp; Regulations" name="rules">
                                <field name="rules_regulations" nolabel="1"/>
                            </page>

                            <!-- Tab 6: Advertisers / Sponsors -->
                            <page string="Advertisers" name="advertisers">
                                <p class="text-muted" style="margin-bottom:12px;">
                                    Upload sponsor or advertiser images here. They will
                                    <strong>rotate on the live board</strong> footer at all times, and appear
                                    <strong>prominently during Break Time</strong> on the auction screen.
                                    Recommended image size: <strong>800 × 300 px</strong> (landscape).
                                </p>
                                <field name="advertiser_ids" nolabel="1">
                                    <tree editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name" string="Advertiser / Sponsor"/>
                                        <field name="image" widget="image"
                                               options="{'preview_image': 'image', 'size': [120, 45]}"
                                               string="Banner / Logo"/>
                                        <field name="active"/>
                                    </tree>
                                </field>
                            </page>

                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_auction_tournament_kanban" model="ir.ui.view">
            <field name="name">auction.tournament.kanban</field>
            <field name="model">auction.tournament</field>
            <field name="arch" type="xml">
                <kanban class="o_auction_tournament_kanban" default_order="tournament_date desc">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="logo"/>
                    <field name="description"/>
                    <field name="tournament_type"/>
                    <field name="tournament_date"/>
                    <field name="venue"/>
                    <field name="active"/>
                    <field name="live_board_active"/>
                    <field name="registered_player_count"/>
                    <field name="team_max_points"/>
                    <field name="organizer_uid"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="o_atk_card oe_kanban_global_click">

                                <!-- Header: logo + name + type badge -->
                                <div class="o_atk_header">
                                    <div class="o_atk_logo_wrap">
                                        <t t-if="record.logo.raw_value">
                                            <img t-att-src="kanban_image('auction.tournament','logo', record.id.raw_value)"
                                                 class="o_atk_logo" alt="Logo"/>
                                        </t>
                                        <t t-else="">
                                            <div class="o_atk_logo_placeholder">
                                                <i class="fa fa-trophy"/>
                                            </div>
                                        </t>
                                    </div>
                                    <div class="o_atk_title_block">
                                        <div class="o_atk_name" t-esc="record.name.value"/>
                                        <div class="o_atk_desc" t-esc="record.description.value"/>
                                        <div class="o_atk_badges">
                                            <span t-attf-class="o_atk_type_badge o_atk_type_#{record.tournament_type.raw_value}">
                                                <i t-attf-class="fa fa-#{record.tournament_type.raw_value == 'cricket' ? 'dot-circle-o' : 'futbol-o'}"/>
                                                <t t-esc="record.tournament_type.value"/>
                                            </span>
                                            <t t-if="record.live_board_active.raw_value">
                                                <span class="o_atk_live_badge">
                                                    <i class="fa fa-circle o_atk_live_dot"/> LIVE
                                                </span>
                                            </t>
                                            <t t-if="!record.active.raw_value">
                                                <span class="o_atk_archived_badge">Archived</span>
                                            </t>
                                        </div>
                                    </div>
                                </div>

                                <!-- Stats row -->
                                <div class="o_atk_stats">
                                    <div class="o_atk_stat">
                                        <i class="fa fa-calendar o_atk_stat_icon"/>
                                        <span t-if="record.tournament_date.raw_value"
                                              t-esc="record.tournament_date.value"/>
                                        <span t-else="" class="text-muted">No date set</span>
                                    </div>
                                    <div class="o_atk_stat">
                                        <i class="fa fa-users o_atk_stat_icon"/>
                                        <t t-esc="record.registered_player_count.raw_value"/>
                                        <span class="o_atk_stat_label"> Players</span>
                                    </div>
                                    <div class="o_atk_stat">
                                        <i class="fa fa-star o_atk_stat_icon"/>
                                        <t t-esc="record.team_max_points.raw_value || 0"/>
                                        <span class="o_atk_stat_label"> Pts/Team</span>
                                    </div>
                                </div>

                                <!-- Venue -->
                                <div t-if="record.venue.raw_value" class="o_atk_venue">
                                    <i class="fa fa-map-marker o_atk_stat_icon"/>
                                    <span t-esc="record.venue.value"/>
                                </div>

                                <!-- Footer: organizer -->
                                <div class="o_atk_footer">
                                    <span t-if="record.organizer_uid.raw_value" class="o_atk_organizer">
                                        <i class="fa fa-user-circle-o"/> <t t-esc="record.organizer_uid.value"/>
                                    </span>
                                    <span class="o_atk_footer_right">
                                        <i class="fa fa-angle-right"/>
                                    </span>
                                </div>

                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_auction_tournament" model="ir.actions.act_window">
            <field name="name">Tournament</field>
            <field name="res_model">auction.tournament</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="view_auction_tournament_search"/>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create your first Tournament
              </p><p>
                Set up tournaments, manage teams and run live auctions.
              </p>
            </field>
        </record>

        <!-- ── Tournament Settings view for Auction Users (non-admin) ─────────────
             mode="primary" makes this a standalone form usable by explicit view_id.
             Inherits the base form and:
               • Hides the Deactivate Tournament button
               • Makes restricted fields readonly (type, algorithm, organizers, theme)
               • Hides the Points & Bid Slabs notebook tab
               • Keeps team_max_points (balance) editable
        ──────────────────────────────────────────────────────────────────────── -->
        <record id="view_auction_tournament_user_form" model="ir.ui.view">
            <field name="name">auction.tournament.form.user</field>
            <field name="model">auction.tournament</field>
            <field name="inherit_id" ref="auction_module.view_auction_tournament_form"/>
            <field name="mode">primary</field>
            <field name="arch" type="xml">

                <!-- Hide Deactivate Tournament button -->
                <button name="action_deactivate_tournament" position="attributes">
                    <attribute name="invisible">1</attribute>
                </button>

                <!-- Make name and description readonly (reg URL is derived from the name) -->
                <field name="name" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <field name="description" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>

                <!-- Make Tournament Type readonly -->
                <field name="tournament_type" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>

                <!-- Make Player Appearance Algorithm readonly -->
                <field name="player_appearance_algorithm" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>

                <!-- Make Organizer readonly -->
                <field name="organizer_uid" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>

                <!-- Make Organizers (many2many) readonly -->
                <field name="organizer_uids" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>

                <!-- Hide Points & Bid Slabs tab entirely -->
                <page name="points_slabs" position="attributes">
                    <attribute name="invisible">1</attribute>
                </page>

                <!-- Make all editable fields in Presentation & Theme tab readonly -->
                <field name="player_display_template" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <field name="sold_display_seconds" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <field name="next_player_countdown" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <field name="preset_points" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <field name="enable_jersey_section" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <field name="max_registrations" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <field name="payment_qr_image" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <field name="payment_instruction" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>

            </field>
        </record>

    </data>
</odoo>
