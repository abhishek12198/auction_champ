<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="player_template_modal_content" name="Player Modal Content">

    <!-- Same external dependencies as auction_player_template_new.xml -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
          crossorigin="anonymous"/>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1"/>
    <link href="https://fonts.googleapis.com/css2?family=Teko:wght@600&amp;family=Poppins:wght@400;500;600;700&amp;display=swap"
          rel="stylesheet"/>
    <link rel="stylesheet" href="/auction_module/static/src/assets/css/style.css"/>

    <style>
        /* ── Drawer shell ────────────────────────────────── */
        .player-modal-content {
            width: 100%;
            padding: 0;
            font-family: 'Poppins', sans-serif;
        }

        /* ── Readability: larger fonts for auction-floor / big-screen viewing ── */
        .player-modal-content .stroke-only {
            font-size: clamp(6rem, 14vw, 11rem);
            line-height: 1;
        }
        .player-modal-content .player-name {
            font-size: clamp(1.6rem, 3.5vw, 2.8rem);
            line-height: 1.2;
            white-space: normal;
        }
        .player-modal-content .player-possition {
            font-size: clamp(1.2rem, 2.5vw, 2rem);
        }
        .player-modal-content .player-tier-badge {
            font-size: clamp(0.9rem, 1.4vw, 1.2rem) !important;
            padding: 6px 18px !important;
        }
        .player-modal-content .player-profession-header p {
            font-size: clamp(1rem, 1.6vw, 1.3rem);
            margin-bottom: 0;
        }
        .player-modal-content .player-attr-label,
        .player-modal-content .player-attr-value {
            font-size: clamp(1rem, 1.6vw, 1.25rem);
        }
        .player-modal-content .player-attr-grid {
            row-gap: 18px;
        }
        .player-modal-content .auction-single-buttons button {
            font-size: clamp(0.95rem, 1.4vw, 1.15rem);
            padding: 0.85rem 2rem;
        }

        /* ── Layout adjustments inside drawer ───────────── */
        .player-modal-content .container {
            padding: 0 1.5rem;
            max-width: 100%;
        }
        .player-modal-content .auction-single {
            gap: 1.5rem !important;
            padding: 1rem 0;
        }
        .player-modal-content .sp-image {
            max-width: 320px;
            height: 480px;
        }
        .player-modal-content .player-profession {
            max-width: 100%;
        }
        .player-modal-content .player-profession-body {
            padding: 1.5rem;
        }
        .player-modal-content .single-header img {
            max-width: 110px;
            height: auto;
        }

        /* ── Responsive ──────────────────────────────────── */
        @media (max-width: 992px) {
            .player-modal-content .sp-image {
                max-width: 260px;
                height: 390px;
            }
        }
        @media (max-width: 768px) {
            .player-modal-content .auction-single {
                flex-direction: column !important;
                align-items: center !important;
            }
            .player-modal-content .col-sm-3,
            .player-modal-content .col-4,
            .player-modal-content .col-lg-5 {
                max-width: 100% !important;
                flex-basis: 100% !important;
            }
            .player-modal-content .sp-image {
                max-width: 220px;
                height: 320px;
            }
            .player-modal-content .single-player-details {
                text-align: center;
            }
            .player-modal-content .auction-single-buttons {
                flex-direction: column;
                width: 100%;
            }
            .player-modal-content .auction-single-buttons button {
                width: 100%;
            }
        }
    </style>

    <div class="player-modal-content">

        <!-- ── Banner — identical to auction_player_template_new.xml ── -->
        <header class="single-header">
            <div class="py-3 text-center">
                <img src="/auction_module/static/src/assets/images/logo.svg" alt="Logo"/>
            </div>
            <div class="container">
                <div class="position-relative" style="column-gap: 8px">
                    <div class="team-name d-flex justify-content-center justify-content-sm-end align-items-center">
                        <div class="d-none d-sm-block bg-white" style="min-height: 58px">
                            <div>
                                <h3><span t-esc="player.tournament_id.name"/></h3>
                                <p><span t-esc="player.tournament_id.description"/></p>
                            </div>
                        </div>
                        <img t-att-src="image_data_uri(player.tournament_id.logo)"
                             alt="team-logo" width="91" height="91"
                             class="team-single-logo"/>
                    </div>
                </div>
            </div>
        </header>

        <!-- ── Player card — mirrors auction_player_template_new.xml ── -->
        <div class="container">
            <div class="row auction-single justify-content-center justify-content-lg-between gap-4">

                <!-- Serial · Name · Role · Tier -->
                <div class="col-sm-3 single-player-details">
                    <h3 class="stroke-only"><span t-esc="player.sl_no"/></h3>
                    <h6 class="player-name"><span t-esc="player.name.upper()"/></h6>
                    <p class="player-possition"><span t-esc="player.role"/></p>
                    <t t-if="player.tier_id">
                        <span class="player-tier-badge"
                              t-att-style="'background-color: ' + (player.tier_id.color or '#3498db') + '; color: #fff; padding: 6px 18px; border-radius: 16px; font-size: 1.1rem; font-weight: 700; display: inline-block; margin-top: 10px; letter-spacing: 1px; text-transform: uppercase;'">
                            <t t-esc="player.tier_id.name"/>
                        </span>
                    </t>
                </div>

                <!-- Player photo -->
                <div class="col-sm-3">
                    <div class="position-relative single-player-image">
                        <div class="sp-image m-auto">
                            <div class="sp-image-before"
                                 t-att-style="'--tier-color: ' + (player.tier_id.color if player.tier_id else '#01cfff')"/>
                            <img t-att-src="image_data_uri(player.photo)" alt="player-image"/>
                        </div>
                    </div>
                </div>

                <!-- Attributes panel -->
                <div class="col-4 col-lg-5">
                    <div class="player-profession m-auto">
                        <div class="player-profession-header">
                            <p>Player Attributes</p>
                        </div>
                        <div class="player-profession-body">
                            <div class="player-attr-grid">
                                <t t-if="player.batting_style">
                                    <span class="player-attr-label">Batting Style</span>
                                    <span class="player-attr-value"><t t-esc="player.batting_style"/></span>
                                </t>
                                <t t-if="player.bowling_style">
                                    <span class="player-attr-label">Bowling Style</span>
                                    <span class="player-attr-value"><t t-esc="player.bowling_style"/></span>
                                </t>
                                <t t-if="player.blood_group">
                                    <span class="player-attr-label">Blood Group 🩸</span>
                                    <span class="player-attr-value" style="color:#e53935; font-weight:600;">
                                        <t t-esc="player.blood_group"/>
                                    </span>
                                </t>
                                <t t-if="player.contact">
                                    <span class="player-attr-label">Mobile No</span>
                                    <span class="player-attr-value"><t t-esc="player.contact"/></span>
                                </t>
                                <t t-if="player.p_category">
                                    <span class="player-attr-label">Category</span>
                                    <span class="player-attr-value"><t t-esc="player.p_category"/></span>
                                </t>
                                <t t-if="player.address">
                                    <span class="player-attr-label">Location</span>
                                    <span class="player-attr-value"><t t-esc="player.address"/></span>
                                </t>
                            </div>
                        </div>
                    </div>

                    <div class="auction-single-buttons d-flex align-items-center justify-content-center gap-3 mt-4">
                        <button onclick="setPlayerUnsold(this)">Set as unsold</button>
                        <button class="sell" onclick="sellPlayerToTeam(this)">Sell to Team</button>
                    </div>
                </div>

            </div>
        </div>

        <!-- ── Next Player ── -->
        <div class="next-player m-auto pb-5">
            <button class="next-player-btn" onclick="closePlayerDrawer()">
                Next Player
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="white">
                    <path d="M6 18L14.5 12 6 6V18ZM16 6V18H18V6H16Z"/>
                </svg>
            </button>
        </div>

    </div>
</template>

</odoo>

