<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_auction_team_player_search" model="ir.ui.view">
            <field name="name">auction.team.player.search</field>
            <field name="model">auction.team.player</field>
            <field name="arch" type="xml">
                <search string="Player">
                    <field name="sl_no" filter_domain="[('sl_no','=',self)]" string="Sl No"/>
                    <field name="name" filter_domain="['|',('contact','ilike',self),('name','ilike',self)]" string="Name/Contact"/>
                    <field name="assigned_team_id" filter_domain="[('assigned_team_id','ilike',self)]" string="Team"/>
                    <filter string="Domestic Players" name="domestic" domain="[('player_type', '=', 'domestic')]"/>
                    <filter string="Foreign Players" name="inactive" domain="[('player_type', '=', 'foreign')]"/>
                    <filter string="Inactive Players" name="inactive" domain="[('active', '=', False)]"/>

                    <group expand="0" string="Group By">
                        <filter name="group_team" string="Team" domain="[]" context="{'group_by': 'assigned_team_id'}"/>

                    </group>
                </search>
            </field>
        </record>

        <record id="view_auction_team_player_kanban" model="ir.ui.view">
            <field name="name">auction.team.player.kanban</field>
            <field name="model">auction.team.player</field>
            <field name="arch" type="xml">

                <kanban class="o_kanban_mobile" default_order="assigned_team_id, icon_player desc, sl_no">

                    <!-- Fields -->
                    <field name="sl_no"/>
                    <field name="id"/>
                    <field name="name"/>
                    <field name="contact"/>
                    <field name="role"/>
                    <field name="batting_style"/>
                    <field name="bowling_style"/>
                    <field name="icon_player"/>
                    <field name="amount_paid"/>
                    <field name="photo"/>
                    <field name="tournament_id"/>
                    <field name="state"/>
                    <field name="assigned_team_id"/>
                    <field name="tier_id"/>
                    <field name="tier_color"/>
                    <field name="p_category"/>
                    <field name="blood_group"/>

                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click player-kanban-card"
                                 t-att-style="'border-top: 5px solid ' + (record.tier_color.raw_value || '#2252b5') + ';'">

                                <!-- ── PHOTO SECTION ── -->
                                <div class="pkc-photo">
                                    <img t-att-src="kanban_image('auction.team.player', 'photo', record.id.raw_value)" alt="Player Photo"/>

                                    <!-- Serial Number Stamp -->
                                    <div class="pkc-sl-stamp">
                                        <t t-esc="record.sl_no.raw_value"/>
                                    </div>

                                    <!-- State Ribbon -->
                                    <div t-attf-class="pkc-state-ribbon pkc-state-#{record.state.raw_value}">
                                        <t t-esc="record.state.value"/>
                                    </div>
                                </div>

                                <!-- ── CARD BODY ── -->
                                <div class="pkc-body">

                                    <!-- Player Name -->
                                    <div class="pkc-name" t-esc="record.name.raw_value"/>

                                    <!-- Badges: Role + Tier -->
                                    <div class="pkc-badges">
                                        <t t-if="record.role.raw_value">
                                            <span class="pkc-role-badge" t-esc="record.role.raw_value"/>
                                        </t>
                                        <t t-if="record.tier_id.raw_value">
                                            <span class="pkc-tier-badge"
                                                  t-att-style="'background:' + (record.tier_color.raw_value || '#2252b5') + ';'"
                                                  t-esc="record.tier_id.value"/>
                                        </t>
                                        <t t-if="record.icon_player.raw_value">
                                            <span class="pkc-icon-badge">⭐ Icon</span>
                                        </t>
                                    </div>

                                    <div class="pkc-divider"/>

                                    <!-- Info Rows -->
                                    <t t-if="record.assigned_team_id.raw_value">
                                        <div class="pkc-info-row">
                                            <i class="fa fa-shield"/> <span t-esc="record.assigned_team_id.value"/>
                                        </div>
                                    </t>
                                    <t t-if="record.contact.raw_value">
                                        <div class="pkc-info-row">
                                            <i class="fa fa-phone"/> <span t-esc="record.contact.raw_value"/>
                                        </div>
                                    </t>
                                    <t t-if="record.batting_style.raw_value">
                                        <div class="pkc-info-row">
                                            <i class="fa fa-circle-o"/> <span t-esc="record.batting_style.raw_value"/>
                                        </div>
                                    </t>
                                    <t t-if="record.bowling_style.raw_value">
                                        <div class="pkc-info-row">
                                            <i class="fa fa-dot-circle-o"/> <span t-esc="record.bowling_style.raw_value"/>
                                        </div>
                                    </t>
                                    <t t-if="record.blood_group.raw_value">
                                        <div class="pkc-info-row pkc-blood">
                                            <i class="fa fa-tint"/> <span t-esc="record.blood_group.raw_value"/>
                                        </div>
                                    </t>
                                    <t t-if="record.p_category.raw_value">
                                        <div class="pkc-info-row">
                                            <i class="fa fa-tag"/> <span t-esc="record.p_category.raw_value"/>
                                        </div>
                                    </t>

                                    <!-- ── ACTION BAR ── -->
                                    <div class="kanban-action-bar">

                                        <!-- Sell Player -->
                                        <button name="%(auction_module.action_auction_sell_player)d"
                                                type="action"
                                                class="kanban-icon-btn sell"
                                                title="Sell Player to Team"
                                                attrs="{'invisible': [('state', '!=', 'auction')]}">
                                            <i class="fa fa-gavel"/>
                                        </button>

                                        <!-- Set Unsold -->
                                        <button name="action_unsold"
                                                type="object"
                                                class="kanban-icon-btn unsold"
                                                title="Mark Player as Unsold"
                                                attrs="{'invisible': [('state', '!=', 'auction')]}"
                                                confirm="This will set the player to Unsold and later you can bring back to Auction.">
                                            <i class="fa fa-ban"/>
                                        </button>

                                        <!-- Set Icon Player -->
                                        <button name="%(auction_module.action_auction_set_key_player)d"
                                                type="action"
                                                class="kanban-icon-btn icon"
                                                title="Set as Icon Player"
                                                attrs="{'invisible': ['|',('state', '!=', 'auction'),('icon_player', '=', True)]}">
                                            <i class="fa fa-star"/>
                                        </button>

                                        <!-- Revoke Icon Player -->
                                        <button name="action_revoke_key_player"
                                                type="object"
                                                class="kanban-icon-btn revoke"
                                                title="Revoke Icon Player"
                                                attrs="{'invisible': ['|',('state', '!=', 'sold'),('icon_player', '!=', True)]}"
                                                confirm="This will revoke the player from Icon Player list and bring back to Auction.">
                                            <i class="fa fa-star-o"/>
                                        </button>

                                        <!-- Recall to Auction -->
                                        <button name="action_recall_auction_sold"
                                                type="object"
                                                class="kanban-icon-btn recall"
                                                title="Recall Player to Auction"
                                                attrs="{'invisible': ['|',('state', '!=', 'sold'),('icon_player', '=', True)]}"
                                                confirm="This will recall the player to Auction.">
                                            <i class="fa fa-refresh"/>
                                        </button>

                                    </div>
                                </div>

                            </div>
                        </t>
                    </templates>
                </kanban>

            </field>
        </record>




        <record id="view_auction_team_player_tree" model="ir.ui.view">
            <field name="name">auction.team.tree</field>
            <field name="model">auction.team.player</field>
            <field name="arch" type="xml">

                <tree string="Player" default_order="icon_player desc, sl_no">
                    <field name="sl_no"/>
                    <field name="name" class="text-uppercase"/>
                    <field name="contact"/>
                    <field name="role"/>
                    <field name="tier_id"/>
                    <field name="amount_paid" widget="boolean_toggle"/>
                    <field name="photo_url" invisible="1"/>
                    <field name="blood_group"/>

                    <field name="tournament_id"/>
                    <field name="state"/>
                    <field name="assigned_team_id" invisible="1"/>
                    <field name="icon_player" invisible="1"/>
                    <field name="sl_no" widget="handle"/>
                    <button name="%(auction_module.action_auction_sell_player)d" string="Sell to Team" type="action" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'auction')]}"></button>
                    <button name="action_unsold" string="Set to Unsold" type="object"   attrs="{'invisible': [('state', '!=', 'auction')]}" confirm="This will set the player to Unsold and later you can bring back to Auction. Click on Ok to continue. Otherwise click on Cancel"></button>
                    <button name="action_auction" string="Bring to Auction" type="object"  attrs="{'invisible': [('state', '!=', 'unsold')]}" confirm="This will bring the player back to Auction from Unsold mode. Click on Ok to continue. Otherwise click on Cancel"></button>
                    <button name="action_revoke_key_player" string="Revoke Icon Player" attrs="{'invisible': ['|',('state', '!=', 'sold'),('icon_player', '!=', True)]}"  class="btn btn-secondary oe_kanban_button" type="object"  confirm="This will revoke the player from the icon player list and bring to auction. Click on Ok to continue. Otherwise click on Cancel"/>
                    <button name="action_recall_auction_sold" string="Recall to Auction" attrs="{'invisible': ['|',('state', '!=', 'sold'),('icon_player', '=', True)]}"  class="btn btn-secondary oe_kanban_button" type="object"  confirm="This will recall the sold player and bring to auction. Click on Ok to continue. Otherwise click on Cancel"/>
                </tree>
            </field>
        </record>


