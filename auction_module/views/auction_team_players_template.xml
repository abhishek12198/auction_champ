<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="auction_team_players_template" name="Players">
  <html lang="en" t-att-data-theme="theme">
    <head>
      <meta charset="UTF-8"/>
      <link rel="shortcut icon" t-att-href="'/web/image/res.company/%d/favicon' % res_company.id" type="image/x-icon"/>
      <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
      <link href="/auction_module/static/src/assets/css/bootstrap.min.css" rel="stylesheet"/>
      <link rel="preconnect" href="https://fonts.googleapis.com"/>
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1"/>
      <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700;900&amp;family=Barlow+Condensed:wght@400;500;600;700;800&amp;family=Teko:wght@500;600;700&amp;display=swap"
            rel="stylesheet" media="print" onload="this.media='all'"/>
      <noscript><link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700;900&amp;family=Barlow+Condensed:wght@400;500;600;700;800&amp;family=Teko:wght@500;600;700&amp;display=swap" rel="stylesheet"/></noscript>
      <title>Squad</title>

      <style>
        /* Sports display font used by the Butterscotch theme */
        @font-face {
          font-family: 'Baseball Club Solid';
          src: url('/auction_module/static/src/assets/fonts/BaseballClubSolid.otf') format('opentype');
          font-weight: normal;
          font-style: normal;
          font-display: swap;
        }
        /* ── CSS variables — identical token set as Bid Summary ── */
        :root,
        [data-theme="vanilla"] {
          --bg:#050c1a; --bg2:#0b1529; --bg3:#0d1f3c;
          --acc:#E8A020; --acc2:#FFD166; --glow:rgba(232,160,32,.30);
          --bdr:rgba(232,160,32,.18); --bdr2:rgba(255,255,255,.08);
          --tx:#EEF4FF; --tx-d:rgba(238,244,255,.55); --tx-m:rgba(238,244,255,.30);
          --hf:'Orbitron',sans-serif; --bf:'Barlow Condensed',sans-serif; --nf:'Teko',sans-serif;
          --card-bg:rgba(11,21,41,.85); --card-bdr:rgba(232,160,32,.15);
        }
        [data-theme="butterscotch"] {
          --bg:#06060f; --bg2:#0f0f20; --bg3:#1a1430;
          --acc:#F5C842; --acc2:#FF9F1C; --glow:rgba(245,200,66,.30);
          --bdr:rgba(245,200,66,.18); --bdr2:rgba(255,255,255,.08);
          --tx:#fff; --tx-d:rgba(255,255,255,.55); --tx-m:rgba(255,255,255,.30);
          --hf:'Baseball Club Solid','Teko',sans-serif; --bf:'Barlow Condensed',sans-serif; --nf:'Teko',sans-serif;
          --card-bg:rgba(15,15,32,.85); --card-bdr:rgba(245,200,66,.15);
        }
        [data-theme="strawberry"] {
          --bg:#0d0610; --bg2:#1a0a18; --bg3:#26102a;
          --acc:#E91E63; --acc2:#F48FB1; --glow:rgba(233,30,99,.30);
          --bdr:rgba(233,30,99,.20); --bdr2:rgba(255,255,255,.08);
          --tx:#FFF0F5; --tx-d:rgba(255,240,245,.55); --tx-m:rgba(255,240,245,.30);
          --hf:'Orbitron',sans-serif; --bf:'Barlow Condensed',sans-serif; --nf:'Teko',sans-serif;
          --card-bg:rgba(26,10,24,.85); --card-bdr:rgba(233,30,99,.15);
        }
        [data-theme="cherry"] {
          --bg:#0d0000; --bg2:#1a0508; --bg3:#2a080e;
          --acc:#DC143C; --acc2:#FF6B6B; --glow:rgba(220,20,60,.30);
          --bdr:rgba(220,20,60,.20); --bdr2:rgba(255,255,255,.08);
          --tx:#FFF5F5; --tx-d:rgba(255,245,245,.55); --tx-m:rgba(255,245,245,.30);
          --hf:'Orbitron',sans-serif; --bf:'Barlow Condensed',sans-serif; --nf:'Teko',sans-serif;
          --card-bg:rgba(26,5,8,.85); --card-bdr:rgba(220,20,60,.15);
        }

        *, *::before, *::after { box-sizing: border-box; }
        html { min-height: 100%; background: var(--bg); }
        body {
          margin: 0;
          min-height: 100vh;
          background:
            radial-gradient(circle at 12% 18%, var(--glow) 0, transparent 28%),
            radial-gradient(circle at 88% 10%, rgba(255,255,255,.05) 0, transparent 22%),
            linear-gradient(180deg, var(--bg) 0%, var(--bg2) 45%, var(--bg3) 100%);
          color: var(--tx);
          font-family: var(--bf);
          font-weight: 500;
          overflow-x: hidden;
        }
        body::before {
          content: '';
          position: fixed;
          inset: 0;
          pointer-events: none;
          background:
            linear-gradient(120deg, rgba(255,255,255,.03) 0%, transparent 22%, transparent 78%, rgba(255,255,255,.02) 100%),
            repeating-linear-gradient(180deg, rgba(255,255,255,.015) 0 1px, transparent 1px 52px);
          opacity: .55;
        }
        a { color: inherit; text-decoration: none; }
        button { font: inherit; color: inherit; }
        img { display: block; max-width: 100%; }

        /* ── Page header ── */
        .tp-header {
          position: sticky;
          top: 0;
          z-index: 100;
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 0 18px;
          height: 64px;
          background: linear-gradient(135deg, rgba(4,10,22,.94), rgba(9,18,34,.90));
          border-bottom: 1px solid var(--bdr2);
          backdrop-filter: blur(16px);
          box-shadow: 0 4px 24px rgba(0,0,0,.35);
        }
        .tp-header img.logo { height: 40px; width: auto; object-fit: contain; }

        /* ── Action buttons in header ── */
        .tp-header-actions { display: flex; align-items: center; gap: 10px; }
        .tp-back-btn {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          height: 38px;
          padding: 0 16px;
          font-size: .9rem;
          text-transform: uppercase;
          letter-spacing: .11em;
          font-family: var(--bf);
          font-weight: 700;
          color: var(--tx);
          background: rgba(255,255,255,.06);
          border: 1px solid var(--bdr);
          border-radius: 999px;
          box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 8px 20px rgba(0,0,0,.18);
          transition: transform .2s, box-shadow .2s, border-color .2s;
          white-space: nowrap;
          text-decoration: none;
        }
        .tp-back-btn:hover {
          transform: translateY(-1px);
          border-color: rgba(255,255,255,.22);
          box-shadow: 0 10px 28px rgba(0,0,0,.22), 0 0 0 1px var(--bdr);
          color: var(--tx);
        }
        .tp-snap-btn {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          height: 38px;
          padding: 0 16px;
          font-size: .9rem;
          font-family: var(--bf);
          font-weight: 700;
          letter-spacing: .08em;
          text-transform: uppercase;
          cursor: pointer;
          border: none;
          border-radius: 999px;
          background: linear-gradient(135deg, var(--acc), var(--acc2));
          color: #07101f;
          box-shadow: 0 6px 18px var(--glow);
          transition: transform .15s, box-shadow .2s, opacity .2s;
        }
        .tp-snap-btn:hover { transform: translateY(-1px); box-shadow: 0 10px 28px var(--glow); }
        .tp-snap-btn:active { transform: translateY(0); }

        /* ── Team hero banner ── */
        .tp-team-hero {
          background: linear-gradient(180deg, rgba(255,255,255,.04), transparent);
          border-bottom: 1px solid var(--bdr);
          padding: 28px 0 22px;
          backdrop-filter: blur(8px);
        }
        .tp-team-logo-ring {
          width: 88px; height: 88px;
          border-radius: 50%;
          border: 2px solid var(--bdr);
          box-shadow: 0 0 24px var(--glow), 0 0 0 5px rgba(255,255,255,.04);
          object-fit: cover;
          background: var(--card-bg);
        }
        .tp-team-name {
          font-family: var(--hf);
          font-size: 2rem;
          font-weight: 900;
          color: var(--tx);
          letter-spacing: .08em;
          text-transform: uppercase;
          margin: 0;
          line-height: 1.1;
        }
        .tp-team-meta { font-size: .82rem; color: var(--tx-d); letter-spacing: .08em; text-transform: uppercase; margin: 0; }
        .tp-team-meta span { color: var(--acc2); }
        .tp-player-count {
          display: inline-flex;
          align-items: center;
          gap: 6px;
          background: rgba(255,255,255,.06);
          color: var(--acc);
          border: 1px solid var(--bdr);
          border-radius: 999px;
          padding: 5px 16px;
          font-family: var(--bf);
          font-size: .82rem;
          font-weight: 700;
          letter-spacing: .1em;
          text-transform: uppercase;
        }

        /* ── Section divider label ── */
        .tp-section-label {
          font-family: var(--hf);
          font-size: .9rem;
          letter-spacing: .18em;
          color: var(--acc);
          text-transform: uppercase;
          padding-bottom: 8px;
          border-bottom: 1px solid var(--bdr);
          margin-bottom: 20px;
          display: inline-block;
        }

        /* ── Player card ── */
        .tp-card {
          background: var(--card-bg);
          border: 1px solid var(--card-bdr);
          border-radius: 18px;
          overflow: hidden;
          box-shadow: 0 8px 24px rgba(0,0,0,.3);
          backdrop-filter: blur(18px);
          display: flex;
          flex-direction: column;
          height: 100%;
          transition: transform .2s, box-shadow .2s;
          position: relative;
        }
        .tp-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 16px 40px rgba(0,0,0,.4), 0 0 0 1px var(--bdr);
        }
        .tp-card::before {
          content: '';
          position: absolute;
          left: 0; top: 0; bottom: 0;
          width: 3px;
          background: linear-gradient(180deg, var(--acc), var(--acc2));
          border-radius: 18px 0 0 18px;
        }

        /* ── Card photo strip ── */
        .tp-card-photo-wrap {
          position: relative;
          background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(0,0,0,.12));
          height: 210px;
          overflow: hidden;
          flex-shrink: 0;
          display: flex;
          align-items: center;
          justify-content: center;
        }
        .tp-card-photo { width: 100%; height: 100%; object-fit: contain; object-position: center top; display: block; }
        .tp-card-photo-placeholder {
          width: 100%; height: 100%;
          display: flex; align-items: center; justify-content: center;
          font-size: 4rem; opacity: .2; color: var(--acc);
        }
        .tp-card-photo-wrap::after {
          content: '';
          position: absolute;
          bottom: 0; left: 0; right: 0;
          height: 48px;
          background: linear-gradient(transparent, var(--card-bg));
          pointer-events: none;
        }

        /* ── Tier badge ── */
        .tp-tier-badge {
          position: absolute;
          top: 10px; right: 10px;
          padding: 3px 10px;
          border-radius: 12px;
          font-size: .68rem;
          font-family: var(--bf);
          font-weight: 700;
          letter-spacing: .06em;
          text-transform: uppercase;
          z-index: 2;
          box-shadow: 0 2px 8px rgba(0,0,0,.4);
        }

        /* ICON crown badge */
        .tp-icon-crown {
          position: absolute;
          top: 8px; left: 10px;
          background: rgba(0,0,0,.7);
          color: var(--acc2);
          border-radius: 10px;
          padding: 3px 8px;
          font-size: .68rem;
          font-family: var(--bf);
          font-weight: 800;
          letter-spacing: .08em;
          text-transform: uppercase;
          z-index: 2;
          border: 1px solid rgba(255,215,0,.35);
        }

        /* ── Card body ── */
        .tp-card-body {
          padding: 14px 16px 10px 20px;
          flex: 1;
          display: flex;
          flex-direction: column;
          gap: 8px;
        }
        .tp-player-name {
          font-family: var(--hf);
          font-size: .92rem;
          font-weight: 900;
          letter-spacing: .06em;
          color: var(--tx);
          text-transform: uppercase;
          margin: 0;
          line-height: 1.15;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }

        /* ── Tags row ── */
        .tp-tags { display: flex; flex-wrap: wrap; gap: 5px; }
        .tp-tag {
          display: inline-block;
          padding: 3px 10px;
          border-radius: 999px;
          font-size: .68rem;
          font-family: var(--bf);
          font-weight: 600;
          letter-spacing: .08em;
          text-transform: uppercase;
          background: rgba(255,255,255,.06);
          color: var(--tx-d);
          border: 1px solid var(--bdr2);
          white-space: nowrap;
        }
        .tp-tag-orange { background: rgba(255,152,0,.1); color: #ffaa44; border-color: rgba(255,152,0,.25); }

        /* ── Stats row ── */
        .tp-stats { display: flex; gap: 6px; flex-wrap: wrap; }
        .tp-stat {
          flex: 1 0 70px;
          background: rgba(255,255,255,.04);
          border: 1px solid var(--bdr2);
          border-radius: 8px;
          padding: 5px 8px;
          text-align: center;
        }
        .tp-stat-label {
          font-size: .6rem;
          color: var(--tx-m);
          text-transform: uppercase;
          letter-spacing: .06em;
          font-family: var(--bf);
          margin: 0;
        }
        .tp-stat-value {
          font-size: .88rem;
          font-family: var(--nf);
          font-weight: 700;
          color: var(--tx);
          margin: 0;
          line-height: 1.2;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }

        /* ── Card footer ── */
        .tp-card-foot {
          background: rgba(0,0,0,.2);
          border-top: 1px solid var(--bdr2);
          padding: 10px 20px;
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 10px;
        }
        .tp-pts-badge {
          display: inline-flex;
          align-items: center;
          gap: 5px;
          background: rgba(255,255,255,.06);
          color: var(--acc);
          border: 1px solid var(--bdr);
          border-radius: 999px;
          padding: 4px 12px;
          font-family: var(--nf);
          font-size: .95rem;
          font-weight: 700;
          letter-spacing: .06em;
        }
        .tp-pts-badge .pts-icon { font-size: .9rem; }
        .tp-pts-label { font-size: .62rem; opacity: .7; margin-left: 2px; }
        .tp-icon-label {
          display: inline-flex;
          align-items: center;
          gap: 5px;
          background: rgba(255,215,0,.1);
          color: var(--acc2);
          border: 1px solid rgba(255,215,0,.3);
          border-radius: 999px;
          padding: 4px 12px;
          font-family: var(--bf);
          font-size: .78rem;
          font-weight: 700;
          letter-spacing: .06em;
        }
        .tp-contact { display: inline-flex; align-items: center; gap: 5px; font-size: .78rem; color: var(--tx-d); text-decoration: none; }
        .tp-contact:hover { color: var(--acc); }

        /* ── Empty state ── */
        .tp-empty { text-align: center; padding: 80px 20px; }
        .tp-empty-icon { font-size: 4rem; color: var(--acc); opacity: .25; margin-bottom: 16px; }
        .tp-empty h4 { color: var(--tx-d); font-weight: 600; margin-bottom: 8px; }
        .tp-empty p { color: var(--tx-m); font-size: .9rem; }

        /* ── Responsive ── */
        @media (max-width: 576px) {
          .tp-header { padding: 0 12px; height: 56px; }
          .tp-team-name { font-size: 1.5rem; }
        }

        /* ── Card grid — hidden on mobile/tablet ── */
        @media (max-width: 768px) { .tp-card-grid { display: none !important; } }
        @media (min-width: 769px) { .tp-squad-list { display: none !important; } }

        /* ── Compact list (mobile/tablet ≤ 768px) ── */
        .tp-squad-list { }
        .tp-list-section-label {
          font-family: var(--hf);
          font-size: .78rem;
          letter-spacing: .18em;
          color: var(--acc);
          text-transform: uppercase;
          padding-bottom: 6px;
          border-bottom: 1px solid var(--bdr);
          margin-bottom: 10px;
          display: block;
        }
        .tp-list-row {
          display: flex;
          align-items: center;
          gap: 12px;
          padding: 9px 12px;
          border-radius: 12px;
          border: 1px solid var(--card-bdr);
          background: var(--card-bg);
          backdrop-filter: blur(18px);
          margin-bottom: 6px;
          transition: background .15s;
        }
        .tp-list-row:hover { background: rgba(255,255,255,.08); }
        .tp-list-thumb {
          width: 46px; height: 46px;
          border-radius: 8px;
          object-fit: cover;
          object-position: top center;
          border: 1px solid var(--bdr);
          flex: 0 0 46px;
        }
        .tp-list-thumb-ph {
          width: 46px; height: 46px;
          border-radius: 8px;
          border: 1px solid var(--bdr2);
          background: rgba(255,255,255,.05);
          display: flex; align-items: center; justify-content: center;
          font-size: 1.4rem; opacity: .35;
          flex: 0 0 46px;
          color: var(--acc);
        }
        .tp-list-body { flex: 1 1 0; min-width: 0; }
        .tp-list-name {
          font-family: var(--hf);
          font-size: .76rem;
          font-weight: 900;
          color: var(--tx);
          text-transform: uppercase;
          letter-spacing: .05em;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
          line-height: 1.2;
        }
        .tp-list-meta {
          font-size: .68rem;
          color: var(--tx-d);
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
          margin-top: 2px;
          font-family: var(--bf);
          letter-spacing: .04em;
          text-transform: uppercase;
        }
        .tp-list-pts {
          flex: 0 0 auto;
          font-family: var(--nf);
          font-size: 1.1rem;
          font-weight: 700;
          color: var(--acc);
          background: rgba(255,255,255,.06);
          border: 1px solid var(--bdr);
          border-radius: 8px;
          padding: 4px 10px;
          text-align: center;
          min-width: 54px;
          line-height: 1.1;
        }
        .tp-list-pts-lbl {
          font-size: .52rem;
          color: var(--tx-m);
          display: block;
          text-align: center;
          text-transform: uppercase;
          letter-spacing: .06em;
          font-family: var(--bf);
        }
        .tp-list-icon-badge {
          font-size: .6rem;
          color: var(--acc2);
          background: rgba(255,215,0,.1);
          border: 1px solid rgba(255,215,0,.3);
          border-radius: 4px;
          padding: 2px 5px;
          margin-left: 4px;
          vertical-align: middle;
          font-family: var(--bf);
          font-weight: 700;
          letter-spacing: .06em;
          text-transform: uppercase;
        }

        /* ── Snapshot-specific overrides ── */
        #screenshot_container { max-width: 1280px; margin: 0 auto; }
        #screenshot_container .tp-card-photo-wrap { height: 180px; position: relative; overflow: hidden; }
      </style>
    </head>

    <body>
      <!-- ── Page header ──────────────────────────────────────────────────── -->
      <header class="tp-header">
        <img src="/auction_module/static/src/assets/images/logo.svg" alt="Logo" height="52" class="logo"/>
        <div class="tp-header-actions">
          <a t-att-href="'/' + (tournament.slug if tournament else '') + '/auction/show/team/balance'" class="tp-back-btn">
            <!-- Chart/summary icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <rect x="14" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <rect x="3" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M14 17.5h7M17.5 14v7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Bid Summary
          </a>
          <t t-if="players">
            <button type="button"
                    t-att-data-filename="'%s_squad.png' % (team.name,)"
                    class="tp-snap-btn o_take_screenshot">
              <!-- Camera SVG icon -->
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M23 19C23 19.5304 22.7893 20.0391 22.4142 20.4142C22.0391 20.7893 21.5304 21 21 21H3C2.46957 21 1.96086 20.7893 1.58579 20.4142C1.21071 20.0391 1 19.5304 1 19V8C1 7.46957 1.21071 6.96086 1.58579 6.58579C1.96086 6.21071 2.46957 6 3 6H7L9 3H15L17 6H21C21.5304 6 22.0391 6.21071 22.4142 6.58579C22.7893 6.96086 23 7.46957 23 8V19Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="13" r="4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Squad Snapshot
            </button>
          </t>
        </div>
      </header>

      <!-- screenshot_container wraps team banner + squad so the snapshot captures everything -->
      <div id="screenshot_container" style="background:var(--bg);">

      <!-- ── Team hero ────────────────────────────────────────────────────── -->
      <section class="tp-team-hero">
        <div class="container">
          <div class="d-flex flex-wrap align-items-center gap-4" style="row-gap:14px;">

            <!-- Logo -->
            <img t-att-src="image_data_uri(team.logo)" alt="Team Logo" class="tp-team-logo-ring"/>

            <!-- Name + meta -->
            <div style="flex:1; min-width:180px;">
              <h1 class="tp-team-name"><t t-esc="team.name"/></h1>
              <p class="tp-team-meta">
                Manager: <span><t t-esc="team.manager or '—'"/></span>
                <t t-if="tournament">
                  &#160;&#183;&#160; <span><t t-esc="tournament.name"/></span>
                </t>
              </p>
            </div>

            <!-- Player count pill -->
            <div>
              <span class="tp-player-count">
                &#128100; <t t-esc="len(players)"/> Player<t t-if="len(players) != 1">s</t>
              </span>
            </div>

          </div>
        </div>
      </section>

      <!-- ── Squad grid ───────────────────────────────────────────────────── -->
      <section class="mt-4 mb-5">
        <div class="container">

          <t t-if="players">
            <!-- ── Compact list — shown on ≤ 768px ── -->
            <div class="tp-squad-list">
              <t t-set="icon_list" t-value="[p for p in players if p.get('is_icon')]"/>
              <t t-if="icon_list">
                <span class="tp-list-section-label">&#9733; Icon Players</span>
                <t t-foreach="icon_list" t-as="player">
                  <div class="tp-list-row">
                    <t t-if="player.get('photo')">
                      <img t-att-src="image_data_uri(player.get('photo'))" alt="Photo" class="tp-list-thumb"/>
                    </t>
                    <t t-else=""><div class="tp-list-thumb-ph">&#128100;</div></t>
                    <div class="tp-list-body">
                      <div class="tp-list-name">
                        <t t-esc="player.get('name', '—')"/>
                        <span class="tp-list-icon-badge">&#9733; ICON</span>
                      </div>
                      <div class="tp-list-meta">
                        <t t-if="player.get('role')"><t t-esc="player.get('role')"/></t>
                        <t t-if="player.get('p_type')"> · <t t-esc="player.get('p_type')"/></t>
                        <t t-if="player.get('tier_name')"> · <t t-esc="player.get('tier_name')"/></t>
                      </div>
                    </div>
                    <div class="tp-list-pts">
                      ICON<span class="tp-list-pts-lbl">Player</span>
                    </div>
                  </div>
                </t>
              </t>

              <t t-set="auc_list" t-value="[p for p in players if not p.get('is_icon')]"/>
              <t t-if="auc_list">
                <span class="tp-list-section-label" t-att-style="'margin-top:14px;' if icon_list else ''">&#127942; Auctioned Squad</span>
                <t t-foreach="auc_list" t-as="player">
                  <div class="tp-list-row">
                    <t t-if="player.get('photo')">
                      <img t-att-src="image_data_uri(player.get('photo'))" alt="Photo" class="tp-list-thumb"/>
                    </t>
                    <t t-else=""><div class="tp-list-thumb-ph">&#128100;</div></t>
                    <div class="tp-list-body">
                      <div class="tp-list-name"><t t-esc="player.get('name', '—')"/></div>
                      <div class="tp-list-meta">
                        <t t-if="player.get('role')"><t t-esc="player.get('role')"/></t>
                        <t t-if="player.get('p_type')"> · <t t-esc="player.get('p_type')"/></t>
                        <t t-if="player.get('tier_name')"> · <t t-esc="player.get('tier_name')"/></t>
                      </div>
                    </div>
                    <div class="tp-list-pts">
                      <t t-esc="player.get('point', '—')"/>
                      <span class="tp-list-pts-lbl">pts</span>
                    </div>
                  </div>
                </t>
              </t>
            </div>

            <!-- ── Card grid — shown on > 768px ── -->
            <div class="tp-card-grid">
              <t t-set="icon_list" t-value="[p for p in players if p.get('is_icon')]"/>
              <t t-if="icon_list">
                <div class="mb-4">
                  <span class="tp-section-label">&#9733; Icon Players</span>
                  <div class="row g-3">
                    <t t-foreach="icon_list" t-as="player">
                      <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <t t-call="auction_module.tp_player_card"/>
                      </div>
                    </t>
                  </div>
                </div>
              </t>

              <t t-set="auc_list" t-value="[p for p in players if not p.get('is_icon')]"/>
              <t t-if="auc_list">
                <div>
                  <span class="tp-section-label">&#127942; Auctioned Squad</span>
                  <div class="row g-3">
                    <t t-foreach="auc_list" t-as="player">
                      <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <t t-call="auction_module.tp_player_card"/>
                      </div>
                    </t>
                  </div>
                </div>
              </t>
            </div>
          </t>

          <!-- Empty state -->
          <t t-else="">
            <div class="tp-empty">
              <div class="tp-empty-icon">&#127942;</div>
              <h4>Squad not yet assembled</h4>
              <p>This team has not recruited any players yet.<br/>
                 Check back once the auction begins.</p>
            </div>
          </t>

        </div>
      </section>

      <!-- end screenshot_container -->
      </div>

      <!-- html2canvas (local copy, no CDN needed) -->
      <script src="/auction_module/static/src/lib/html2canvas.min.js"></script>

      <!-- Screenshot handler -->
      <script>
        document.addEventListener('click', function(ev) {
          var btn = ev.target.closest('.o_take_screenshot');
          if (!btn) return;
          ev.preventDefault();
          ev.stopPropagation();

          var container = document.getElementById('screenshot_container');
          if (!container) { console.error('screenshot_container not found'); return; }

          var fileName = btn.dataset.filename || 'squad.png';
          btn.style.visibility = 'hidden';

          /* Fix photo proportions — html2canvas ignores object-fit, so we
             compute contained dimensions and apply them as explicit px values. */
          var photoImgs = container.querySelectorAll('.tp-card-photo');
          var restoreList = [];
          photoImgs.forEach(function(img) {
            if (!img.naturalWidth || !img.naturalHeight) return;
            var wrap = img.closest('.tp-card-photo-wrap');
            if (!wrap) return;
            var wrapW = wrap.offsetWidth;
            var wrapH = wrap.offsetHeight;
            var scale = Math.min(wrapW / img.naturalWidth, wrapH / img.naturalHeight);
            var dispW = Math.round(img.naturalWidth  * scale);
            var dispH = Math.round(img.naturalHeight * scale);
            /* Save originals */
            restoreList.push({img: img, style: img.getAttribute('style') || ''});
            /* Center within wrap using absolute positioning */
            img.style.position   = 'absolute';
            img.style.top        = Math.round((wrapH - dispH) / 2) + 'px';
            img.style.left       = Math.round((wrapW - dispW) / 2) + 'px';
            img.style.width      = dispW + 'px';
            img.style.height     = dispH + 'px';
            img.style.objectFit  = 'unset';
          });

          html2canvas(container, {
            scale: 2,
            useCORS: true,
            allowTaint: true,
            backgroundColor: getComputedStyle(document.body).getPropertyValue('--bg').trim() || '#050c1a',
            scrollX: 0,
            scrollY: 0,
            windowWidth: 1280,
            windowHeight: container.scrollHeight,
          }).then(function(canvas) {
            /* Restore original image styles */
            restoreList.forEach(function(r) {
              r.img.setAttribute('style', r.style);
            });
            btn.style.visibility = 'visible';
            var link = document.createElement('a');
            link.href = canvas.toDataURL('image/png');
            link.download = fileName;
            link.click();
          }).catch(function(err) {
            btn.style.visibility = 'visible';
            console.error('Screenshot failed', err);
          });
        });
      </script>

    </body>
  </html>
</template>

<!-- ── Reusable player card sub-template ───────────────────────────────── -->
<template id="tp_player_card" name="Team Player Card">
  <div class="tp-card">

    <!-- Photo strip -->
    <div class="tp-card-photo-wrap">
      <t t-if="player.get('photo')">
        <img t-att-src="image_data_uri(player.get('photo'))"
             alt="Player photo" class="tp-card-photo"/>
      </t>
      <t t-else="">
        <div class="tp-card-photo-placeholder">&#128100;</div>
      </t>

      <!-- Tier badge -->
      <t t-if="player.get('tier_name')">
        <span class="tp-tier-badge"
              t-attf-style="background:#{player.get('tier_color','#01cfff')}22; color:#{player.get('tier_color','#01cfff')}; border:1.5px solid #{player.get('tier_color','#01cfff')}55;">
          <t t-esc="player.get('tier_name')"/>
        </span>
      </t>

      <!-- Icon crown -->
      <t t-if="player.get('is_icon')">
        <span class="tp-icon-crown">&#9733; ICON</span>
      </t>
    </div>

    <!-- Card body -->
    <div class="tp-card-body">

      <!-- Name -->
      <p class="tp-player-name"><t t-esc="player.get('name', '—')"/></p>

      <!-- Tags: role, p_type, p_category -->
      <div class="tp-tags">
        <t t-if="player.get('role')">
          <span class="tp-tag"><t t-esc="player.get('role')"/></span>
        </t>
        <t t-if="player.get('p_type')">
          <span class="tp-tag"><t t-esc="player.get('p_type')"/></span>
        </t>
        <t t-if="player.get('p_category')">
          <span class="tp-tag tp-tag-orange"><t t-esc="player.get('p_category')"/></span>
        </t>
      </div>

      <!-- Stats: batting + bowling style -->
      <t t-if="player.get('batting_style') or player.get('bowling_style')">
        <div class="tp-stats">
          <t t-if="player.get('batting_style')">
            <div class="tp-stat">
              <p class="tp-stat-label">Batting</p>
              <p class="tp-stat-value"><t t-esc="player.get('batting_style')"/></p>
            </div>
          </t>
          <t t-if="player.get('bowling_style')">
            <div class="tp-stat">
              <p class="tp-stat-label">Bowling</p>
              <p class="tp-stat-value"><t t-esc="player.get('bowling_style')"/></p>
            </div>
          </t>
        </div>
      </t>

    </div>

    <!-- Card footer: points + contact -->
    <div class="tp-card-foot">

      <!-- Points -->
      <t t-if="player.get('point') == 'ICON'">
        <span class="tp-icon-label">&#9733; Icon Player</span>
      </t>
      <t t-else="">
        <span class="tp-pts-badge">
          <span class="pts-icon">&#128176;</span>
          <t t-esc="player.get('point', 0)"/>
          <span class="tp-pts-label">pts</span>
        </span>
      </t>

      <!-- Contact -->
      <t t-if="player.get('contact')">
        <a t-attf-href="tel:#{player.get('contact')}" class="tp-contact">
          &#128222; <t t-esc="player.get('contact')"/>
        </a>
      </t>

    </div>

  </div>
</template>

