<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- vanilla card body (called per-doc by dispatcher) -->
    <template id="report_player_card_vanilla_page">
        <html lang="en">
            <head>
                <link rel="preconnect" href="https://fonts.googleapis.com" />
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1" />
                <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=Oswald:wght@400;500;600;700&amp;family=Barlow:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
                <title>Player Card</title>
                <style>@font-face{font-family:'Varsity Team';src:url('/auction_module/static/src/assets/fonts/VarsityTeam-Bold.otf') format('opentype');font-weight:normal;font-style:normal;}</style>
            </head>
            <body style="margin:0; padding:10px; font-family:'Barlow',sans-serif; background-color:#0c1a3c; background-image:-webkit-radial-gradient(14% -10%, circle, rgba(96,140,255,0.42) 0%, rgba(96,140,255,0) 40%), -webkit-radial-gradient(86% -10%, circle, rgba(96,140,255,0.38) 0%, rgba(96,140,255,0) 40%), -webkit-radial-gradient(50% 125%, circle, rgba(253,206,51,0.15) 0%, rgba(253,206,51,0) 52%), -webkit-linear-gradient(top, #16295a 0%, #0c1a3c 52%, #0a1330 100%);">
                <div style="max-width:832px; margin:0 auto; border-radius:14px; background-color:#0b1533; background-image:-webkit-linear-gradient(top,#0e1c40 0%,#0a1533 100%); box-shadow:0 0 0 2px rgba(253,206,51,0.6), 0 0 0 5px rgba(0,0,0,0.6), 0 16px 40px rgba(0,0,0,0.55);">

                    <!-- HEADER -->
                    <div style="border-radius:14px 14px 0 0; border-bottom:2px solid rgba(253,206,51,0.85); background-color:#1b3f8f; background-image:-webkit-radial-gradient(92% -60%, circle, rgba(253,206,51,0.30) 0%, rgba(253,206,51,0) 60%), -webkit-linear-gradient(left, #12306e 0%, #2252b5 55%, #1b3f8f 100%);">
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                        <td style="vertical-align:middle; padding:11px 18px; width:60px;">
                                            <div style="width:48px; height:48px; padding:3px; border-radius:8px; background-color:rgba(255,255,255,0.14); box-shadow:0 0 0 1px rgba(253,206,51,0.5); text-align:center;">
                                                <img t-att-src="image_data_uri(doc.tournament_id.logo)" alt="Logo" style="height:42px; width:42px; object-fit:contain; display:inline-block; border-radius:5px; vertical-align:middle;"/>
                                            </div>
                                        </td>
                                <td style="vertical-align:middle; padding:11px 0;">
                                    <div style="color:#ffffff; font-family:'Varsity Team','Bebas Neue',sans-serif; font-size:1.7rem; letter-spacing:1.4px; text-transform:uppercase; line-height:1; text-shadow:0 2px 6px rgba(0,0,0,0.45); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:34ch;" t-esc="doc.tournament_id.name"/>
                                    <div style="color:#fdce33; font-size:0.68rem; font-weight:600; margin-top:3px; letter-spacing:2px; text-transform:uppercase;" t-esc="doc.tournament_id.description"/>
                                </td>
                                <td style="vertical-align:middle; text-align:right; padding:11px 20px; white-space:nowrap;">
                                    <span style="display:inline-block; padding:5px 14px; border-radius:20px; background-color:rgba(0,0,0,0.28); box-shadow:0 0 0 1px rgba(253,206,51,0.6); color:#fdce33; font-family:'Oswald',sans-serif; font-size:0.68rem; font-weight:700; letter-spacing:3px; text-transform:uppercase;">Player Card</span>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <!-- BODY -->
                    <table style="width:100%; border-collapse:collapse;">
                        <tr>
                            <td style="width:264px; min-width:264px; vertical-align:top; padding:0;">
                                <div style="padding:14px 11px 14px 14px; background-color:#0d1e46; background-image:-webkit-radial-gradient(50% 4%, circle, rgba(96,140,255,0.34) 0%, rgba(96,140,255,0) 55%), -webkit-linear-gradient(top,#13285c 0%,#0b1734 100%); border-right:2px solid rgba(253,206,51,0.3);">
                                    <div t-att-style="'border-radius:10px; overflow:hidden; border-top:5px solid ' + (doc.tier_id.color if doc.tier_id else '#3aa0ff') + '; border-bottom:5px solid ' + (doc.tier_id.color if doc.tier_id else '#3aa0ff') + '; box-shadow:0 0 0 2px #fdce33, 0 0 0 5px rgba(0,0,0,0.5), 0 8px 22px rgba(0,0,0,0.5);'">
                                        <img t-att-src="image_data_uri(doc.photo_card or doc.photo)" alt="Player Photo" style="width:100%; height:300px; object-fit:cover; object-position:top center; display:block;"/>
                                    </div>
                                </div>
                            </td>

                            <td style="vertical-align:top; padding:0;">
                                <div style="position:relative; min-height:328px; background-color:#0d1834; background-image:-webkit-radial-gradient(100% 0%, circle, rgba(96,140,255,0.20) 0%, rgba(96,140,255,0) 50%), -webkit-linear-gradient(top left, #182a56 0%, #0d1834 100%);">

                                    <div style="position:absolute; top:15px; right:18px; width:56px; height:56px; border-radius:50%; background-color:#173a86; background-image:-webkit-linear-gradient(top left,#2a5fd0,#12306e); box-shadow:0 0 0 3px #fdce33, 0 0 0 6px rgba(0,0,0,0.55), 0 6px 16px rgba(0,0,0,0.5); text-align:center; line-height:56px;">
                                        <span style="color:#fdce33; font-family:'Varsity Team','Bebas Neue',sans-serif; font-size:1.7rem; vertical-align:middle;"><t t-esc="doc.sl_no"/></span>
                                    </div>

                                    <div style="padding:18px 78px 16px 24px;">
                                        <div style="color:#ffffff; font-family:'Varsity Team','Bebas Neue',sans-serif; font-size:2.5rem; line-height:0.98; letter-spacing:1px; text-transform:uppercase; text-shadow:0 3px 9px rgba(0,0,0,0.5); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" t-esc="doc.name.upper()"/>
                                        <div style="margin-top:6px;">
                                            <t t-if="doc.role">
                                                <span style="display:inline-block; color:#0a1330; background-color:#fdce33; background-image:-webkit-linear-gradient(left,#fdce33,#f5b301); font-family:'Oswald',sans-serif; font-size:0.78rem; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; padding:3px 14px; border-radius:4px; white-space:nowrap;"><t t-esc="doc.role"/></span>
                                            </t>
                                            <t t-if="doc.tier_id">
                                                <span t-att-style="'display:inline-block; margin-left:6px; background-color:' + (doc.tier_id.color or '#3aa0ff') + '; color:#fff; padding:4px 14px; border-radius:20px; font-family:Oswald,sans-serif; font-size:0.68rem; font-weight:600; letter-spacing:1.3px; text-transform:uppercase; box-shadow:0 0 0 1px rgba(255,255,255,0.25); white-space:nowrap;'"><t t-esc="doc.tier_id.name"/></span>
                                            </t>
                                        </div>


                                        <table style="width:100%; border-collapse:collapse; margin:13px 0 2px;">
                                            <tr><td style="height:2px; padding:0; background-color:#fdce33; background-image:-webkit-linear-gradient(left,#fdce33 0%,rgba(253,206,51,0) 82%);"></td></tr>
                                        </table>

                                        <table style="width:100%; border-collapse:collapse;">
                                <t t-if="doc.tournament_id.tournament_type == 'cricket' and doc.batting_style">
                                    <tr>
                                        <td style="color:#9fb4dd; font-family:'Oswald',sans-serif; font-size:0.7rem; font-weight:500; letter-spacing:0.8px; text-transform:uppercase; padding:7px 10px 7px 0; white-space:nowrap; width:42%; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;">Batting Style</td>
                                        <td style="color:#ffffff; font-size:0.85rem; font-weight:600; padding:7px 0; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;"><t t-esc="doc.batting_style"/></td>
                                    </tr>
                                </t>
                                <t t-if="doc.tournament_id.tournament_type == 'cricket' and doc.bowling_style">
                                    <tr>
                                        <td style="color:#9fb4dd; font-family:'Oswald',sans-serif; font-size:0.7rem; font-weight:500; letter-spacing:0.8px; text-transform:uppercase; padding:7px 10px 7px 0; white-space:nowrap; width:42%; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;">Bowling Style</td>
                                        <td style="color:#ffffff; font-size:0.85rem; font-weight:600; padding:7px 0; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;"><t t-esc="doc.bowling_style"/></td>
                                    </tr>
                                </t>
                                <t t-if="doc.blood_group">
                                    <tr>
                                        <td style="color:#9fb4dd; font-family:'Oswald',sans-serif; font-size:0.7rem; font-weight:500; letter-spacing:0.8px; text-transform:uppercase; padding:7px 10px 7px 0; white-space:nowrap; width:42%; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;">Blood Group</td>
                                        <td style="color:#ff6b6b; font-size:0.85rem; font-weight:600; font-weight:700; padding:7px 0; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;"><t t-esc="doc.blood_group"/></td>
                                    </tr>
                                </t>
                                <t t-if="doc.p_category">
                                    <tr>
                                        <td style="color:#9fb4dd; font-family:'Oswald',sans-serif; font-size:0.7rem; font-weight:500; letter-spacing:0.8px; text-transform:uppercase; padding:7px 10px 7px 0; white-space:nowrap; width:42%; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;">Player Category</td>
                                        <td style="color:#ffffff; font-size:0.85rem; font-weight:600; padding:7px 0; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;"><t t-esc="doc.p_category"/></td>
                                    </tr>
                                </t>
                                <t t-if="doc.address">
                                    <tr>
                                        <td style="color:#9fb4dd; font-family:'Oswald',sans-serif; font-size:0.7rem; font-weight:500; letter-spacing:0.8px; text-transform:uppercase; padding:7px 10px 7px 0; white-space:nowrap; width:42%; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;">Location</td>
                                        <td style="color:#ffffff; font-size:0.85rem; font-weight:600; padding:7px 0; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;"><t t-esc="doc.address"/></td>
                                    </tr>
                                </t>
                                <t t-if="doc.contact">
                                    <tr>
                                        <td style="color:#9fb4dd; font-family:'Oswald',sans-serif; font-size:0.7rem; font-weight:500; letter-spacing:0.8px; text-transform:uppercase; padding:7px 10px 7px 0; white-space:nowrap; width:42%; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;">Mobile</td>
                                        <td style="color:#ffffff; font-size:0.85rem; font-weight:600; padding:7px 0; border-bottom:1px solid rgba(253,206,51,0.15); vertical-align:middle;"><t t-esc="doc.masked_contact"/></td>
                                    </tr>
                                </t>
                                        </table>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <!-- FOOTER -->
                    <div style="text-align:center; padding:7px 20px; border-radius:0 0 14px 14px; border-top:2px solid rgba(253,206,51,0.85); background-color:#2252b5; background-image:-webkit-linear-gradient(left,#12306e,#2252b5,#12306e);">
                        <span style="font-size:0.6rem; letter-spacing:3px; text-transform:uppercase;"><span style="color:rgba(253,206,51,0.6); font-weight:400;">Powered by&#160;</span><img src="data:image/svg+xml;base64," alt="Auction Champ" style="height:16px; vertical-align:middle; display:inline-block; margin-left:4px;"/></span>
                    </div>

                </div>
            </body>
        </html>
    </template>

    <!-- ── Dispatcher: bound to the Print button, picks theme per doc ── -->
    <template id="report_player_card_list">
        <t t-foreach="docs" t-as="doc">
            <t t-if="doc.tournament_id.player_display_template == 'butterscotch'">
                <page t-call="web.basic_layout">
                    <t t-call="auction_module.report_player_card_butterscotch_page"/>
                </page>
            </t>
            <t t-elif="doc.tournament_id.player_display_template == 'strawberry'">
                <page t-call="web.basic_layout">
                    <t t-call="auction_module.report_player_card_strawberry_page"/>
                </page>
            </t>
            <t t-elif="doc.tournament_id.player_display_template == 'cherry'">
                <page t-call="web.basic_layout">
                    <t t-call="auction_module.report_player_card_cherry_page"/>
                </page>
            </t>
            <t t-elif="doc.tournament_id.player_display_template == 'pistah'">
                <page t-call="web.basic_layout">
                    <t t-call="auction_module.report_player_card_pistah_page"/>
                </page>
            </t>
            <t t-else="">
                <page t-call="web.basic_layout">
                    <t t-call="auction_module.report_player_card_vanilla_page"/>
                </page>
            </t>
        </t>
    </template>

</odoo>

