<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="player_template_butterscotch" name="Player Auction – Butterscotch">
    <html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1" />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&amp;family=Barlow+Condensed:wght@400;500;600;700&amp;display=swap"
      rel="stylesheet"
    />
    <title>Player Showcase</title>
    <style>
      /* ── Reset ─────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --gold:        #F5C842;
        --gold-dark:   #C8960C;
        --amber:       #FF9F1C;
        --gold-glow:   rgba(245,200,66,0.28);
        --navy:        #070B14;
        --navy-card:   #0C1120;
        --border:      rgba(245,200,66,0.22);
        --border-hot:  rgba(245,200,66,0.55);
        --dim:         rgba(255,255,255,0.48);
        --white:       #ffffff;
      }

      html, body {
        height: 100vh;
        overflow: hidden;
        background: var(--navy);
        color: var(--white);
        font-family: 'Barlow Condensed', sans-serif;
      }

      /* ══════════════════════════════════════════
         HEADER
      ══════════════════════════════════════════ */
      .hud-header {
        position: relative;
        z-index: 20;
        display: grid;
        grid-template-columns: 1fr 100px 1fr;
        align-items: center;
        height: 84px;
        padding: 0 36px;
        background: var(--navy-card);
        border-bottom: 2px solid var(--gold);
      }
      /* subtle diagonal gold shimmer in header */
      .hud-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, transparent 38%, rgba(245,200,66,0.05) 50%, transparent 62%);
        pointer-events: none;
      }

      .hud-tourn-info { display: flex; flex-direction: column; justify-content: center; }
      .hud-tourn-name {
        font-family: 'Oswald', sans-serif;
        font-size: 1.55rem; font-weight: 700;
        color: var(--gold);
        text-transform: uppercase;
        letter-spacing: 3px;
        line-height: 1;
      }
      .hud-tourn-desc {
        margin-top: 4px;
        font-size: 0.72rem; font-weight: 500;
        letter-spacing: 1.8px;
        text-transform: uppercase;
        color: var(--dim);
      }

      .hud-logo-center { display: flex; justify-content: center; align-items: center; }
      .hud-logo-center img {
        width: 66px; height: 66px;
        object-fit: contain;
        filter: brightness(0) invert(1) sepia(0.5) saturate(400%) hue-rotate(10deg)
                brightness(1.05) drop-shadow(0 0 10px rgba(245,200,66,0.5));
      }

      .hud-tourn-logo { display: flex; justify-content: flex-end; align-items: center; }
      .hud-tourn-logo img {
        max-height: 66px; max-width: 150px;
        object-fit: contain;
        object-position: right center;
      }

      /* ══════════════════════════════════════════
         ARENA — two-panel full-height split
      ══════════════════════════════════════════ */
      .hud-arena {
        display: grid;
        grid-template-columns: 53% 1fr;
        height: calc(100vh - 84px);
        overflow: hidden;
      }

      /* ── LEFT: photo panel ────────────────── */
      .hud-photo-col {
        position: relative;
        overflow: hidden;
        background: #050810;
      }

      .hud-photo-col .hud-photo-img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: top center;
      }

      /* right-edge fade so photo area blends into info panel */
      .hud-photo-col::after {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(
          to right,
          transparent 60%,
          rgba(7,11,20,0.5) 82%,
          var(--navy) 100%
        );
        z-index: 2;
        pointer-events: none;
      }

      /* bottom scrim for overlaid name */
      .hud-photo-col::before {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0; height: 42%;
        background: linear-gradient(to top, rgba(7,11,20,0.96) 0%, transparent 100%);
        z-index: 3;
        pointer-events: none;
      }

      /* huge serial watermark centred behind photo */
      .hud-serial-watermark {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        font-family: 'Oswald', sans-serif;
        font-size: clamp(11rem, 22vw, 20rem);
        font-weight: 700;
        color: rgba(245,200,66,0.05);
        line-height: 1;
        letter-spacing: -6px;
        user-select: none;
        pointer-events: none;
        z-index: 1;
      }

      /* serial badge — top-left of photo */
      .hud-serial-badge {
        position: absolute;
        top: 22px; left: 24px;
        z-index: 5;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }
      .hud-serial-label {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 0.6rem; font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--dim);
        line-height: 1;
      }
      .hud-serial-number {
        font-family: 'Oswald', sans-serif;
        font-size: 4.8rem; font-weight: 700;
        color: var(--gold);
        line-height: 1;
        text-shadow: 0 0 28px rgba(245,200,66,0.45);
      }

      /* name + role overlay at bottom of photo */
      .hud-photo-overlay {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        padding: 22px 28px 26px;
        z-index: 4;
      }
      .hud-player-name {
        font-family: 'Oswald', sans-serif;
        font-size: clamp(2.2rem, 4vw, 3.6rem);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 4px;
        color: var(--white);
        line-height: 1;
        text-shadow: 0 2px 20px rgba(0,0,0,0.9);
      }
      /* angled badge for role — sports HUD style */
      .hud-role-tag {
        display: inline-block;
        margin-top: 10px;
        padding: 5px 22px 5px 14px;
        background: linear-gradient(135deg, var(--gold-dark), var(--amber));
        color: var(--navy);
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 0.82rem; font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 50%, calc(100% - 10px) 100%, 0 100%);
      }

      /* gold vertical accent line on left edge of photo */
      .hud-photo-col-accent {
        position: absolute;
        top: 0; left: 0;
        width: 4px; height: 100%;
        background: linear-gradient(to bottom, var(--gold), var(--amber), transparent);
        z-index: 6;
      }

      /* ── RIGHT: info panel ────────────────── */
      .hud-info-col {
        display: flex;
        flex-direction: column;
        background: var(--navy-card);
        border-left: 1px solid rgba(245,200,66,0.12);
        overflow: hidden;
      }

      /* tier strip */
      .hud-tier-strip {
        flex-shrink: 0;
        padding: 14px 28px 13px;
        background: rgba(245,200,66,0.03);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .hud-tier-label-dim {
        font-size: 0.68rem; font-weight: 600;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--dim);
      }
      /* hexagon-clipped tier badge */
      .hud-tier-hex {
        display: inline-flex;
        align-items: center;
        padding: 6px 26px 6px 20px;
        font-family: 'Oswald', sans-serif;
        font-size: 1rem; font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        clip-path: polygon(10px 0%, calc(100% - 10px) 0%, 100% 50%, calc(100% - 10px) 100%, 10px 100%, 0% 50%);
      }

      /* stats area */
      .hud-stats {
        flex: 1;
        padding: 18px 28px 10px;
        display: flex;
        flex-direction: column;
        gap: 9px;
        overflow-y: auto;
      }
      .hud-stats-heading {
        font-family: 'Oswald', sans-serif;
        font-size: 0.78rem; font-weight: 600;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: var(--gold);
        padding-bottom: 9px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 2px;
      }

      .hud-stat-row {
        display: grid;
        grid-template-columns: 108px 1fr;
        align-items: stretch;
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border);
        border-radius: 3px;
        overflow: hidden;
        transition: border-color .2s, background .2s;
      }
      .hud-stat-row:hover {
        border-color: rgba(245,200,66,0.48);
        background: rgba(245,200,66,0.04);
      }
      .hud-stat-key {
        padding: 9px 12px;
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 0.7rem; font-weight: 700;
        letter-spacing: 1.8px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(245,200,66,0.06);
        border-right: 1px solid var(--border);
        display: flex;
        align-items: center;
      }
      .hud-stat-val {
        padding: 9px 16px;
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1rem; font-weight: 600;
        letter-spacing: 0.5px;
        color: var(--white);
        display: flex;
        align-items: center;
      }

      /* ── action buttons ─────────────────────── */
      .hud-actions {
        flex-shrink: 0;
        padding: 14px 28px;
        display: flex;
        gap: 12px;
        border-top: 1px solid var(--border);
        background: rgba(245,200,66,0.025);
      }
      .hud-btn {
        flex: 1;
        padding: 13px 10px;
        font-family: 'Oswald', sans-serif;
        font-size: 0.95rem; font-weight: 600;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        border: none;
        border-radius: 3px;
        cursor: pointer;
        transition: all .22s;
      }
      .hud-btn-unsold {
        background: rgba(255,255,255,0.06);
        border: 1.5px solid rgba(255,255,255,0.18);
        color: rgba(255,255,255,0.72);
      }
      .hud-btn-unsold:hover {
        background: rgba(255,255,255,0.11);
        border-color: rgba(255,255,255,0.38);
        color: var(--white);
      }
      .hud-btn-sell {
        background: linear-gradient(135deg, var(--gold-dark) 0%, var(--amber) 100%);
        color: var(--navy);
        font-weight: 700;
        box-shadow: 0 4px 18px rgba(245,200,66,0.28);
        /* angled right edge */
        clip-path: polygon(0 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
        padding-right: 22px;
      }
      .hud-btn-sell:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 26px rgba(245,200,66,0.46);
      }
      .hud-btn-sell:disabled { opacity: .4; cursor: not-allowed; }

      /* ── next player bar ────────────────────── */
      .hud-next-bar {
        flex-shrink: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 12px 28px 14px;
        border-top: 1px solid var(--border);
        background: var(--navy-card);
      }
      .hud-next-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 48px;
        background: linear-gradient(135deg, rgba(245,200,66,0.09), rgba(255,159,28,0.06));
        border: 1px solid var(--border);
        color: var(--gold);
        font-family: 'Oswald', sans-serif;
        font-size: 1.05rem; font-weight: 600;
        letter-spacing: 4px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all .22s;
        /* parallelogram cut */
        clip-path: polygon(14px 0%, 100% 0%, calc(100% - 14px) 100%, 0% 100%);
        border-radius: 0;
      }
      .hud-next-btn:hover {
        background: linear-gradient(135deg, rgba(245,200,66,0.18), rgba(255,159,28,0.13));
        box-shadow: 0 0 22px var(--gold-glow);
        transform: scale(1.03);
      }
      .hud-next-btn svg { transition: transform .22s; }
      .hud-next-btn:hover svg { transform: translateX(4px); }

      /* ── responsive ─────────────────────────── */
      @media (max-width: 900px) {
        html, body { height: auto; overflow: auto; }
        .hud-arena {
          grid-template-columns: 1fr;
          height: auto;
        }
        .hud-photo-col { height: 56vw; min-height: 260px; }
        .hud-photo-col::after { display: none; }
        .hud-serial-watermark { font-size: 7rem; }
        .hud-player-name { font-size: 1.8rem; }
        .hud-header { grid-template-columns: 1fr 80px 1fr; }
      }
    </style>
  </head>

  <body t-att-data-player-id="player.id">

    <!-- ══════════════════════════════════════
         HEADER
    ══════════════════════════════════════ -->
    <header class="hud-header">
      <div class="hud-tourn-info">
        <div class="hud-tourn-name"><t t-esc="player.tournament_id.name"/></div>
        <div class="hud-tourn-desc"><t t-esc="player.tournament_id.description"/></div>
      </div>
      <div class="hud-logo-center">
        <img src="/auction_module/static/src/assets/images/logo.svg" alt="Auction Champ" />
      </div>
      <div class="hud-tourn-logo">
        <img t-att-src="image_data_uri(player.tournament_id.logo)" alt="Tournament Logo" />
      </div>
    </header>

    <!-- ══════════════════════════════════════
         ARENA
    ══════════════════════════════════════ -->
    <div class="hud-arena" data-player-zone="">

      <!-- ── LEFT: Photo panel ── -->
      <div class="hud-photo-col">
        <!-- left accent bar -->
        <div class="hud-photo-col-accent"></div>

        <!-- giant serial watermark behind photo -->
        <div class="hud-serial-watermark"><t t-esc="player.sl_no"/></div>

        <!-- photo fills full column height -->
        <img class="hud-photo-img"
             t-att-src="image_data_uri(player.photo)"
             alt="Player Photo"
             id="loadImage" />

        <!-- serial badge — top left -->
        <div class="hud-serial-badge">
          <span class="hud-serial-label">No.</span>
          <span class="hud-serial-number"><t t-esc="player.sl_no"/></span>
        </div>

        <!-- player name + role overlaid at bottom -->
        <div class="hud-photo-overlay">
          <div class="hud-player-name" data-sm-name=""><t t-esc="player.name.upper()"/></div>
          <t t-if="player.role">
            <div class="hud-role-tag" data-sm-role=""><t t-esc="player.role"/></div>
          </t>
        </div>
      </div>

      <!-- ── RIGHT: Info panel ── -->
      <div class="hud-info-col">

        <!-- tier strip -->
        <div class="hud-tier-strip">
          <t t-if="player.tier_id">
            <span class="hud-tier-hex"
                  t-att-style="'background:' + (player.tier_id.color or '#C8960C') + '30; color:' + (player.tier_id.color or '#F5C842') + ';'">
              <t t-esc="player.tier_id.name"/>
            </span>
          </t>
          <t t-else="">
            <span class="hud-tier-label-dim">Auction Tier</span>
          </t>
        </div>

        <!-- stats -->
        <div class="hud-stats">
          <div class="hud-stats-heading">Player Profile</div>

          <t t-if="player.batting_style">
            <div class="hud-stat-row">
              <span class="hud-stat-key">Batting</span>
              <span class="hud-stat-val"><t t-esc="player.batting_style"/></span>
            </div>
          </t>
          <t t-if="player.bowling_style">
            <div class="hud-stat-row">
              <span class="hud-stat-key">Bowling</span>
              <span class="hud-stat-val"><t t-esc="player.bowling_style"/></span>
            </div>
          </t>
          <t t-if="player.blood_group">
            <div class="hud-stat-row">
              <span class="hud-stat-key">Blood Group</span>
              <span class="hud-stat-val" style="color:#f87171; font-weight:700;">
                <t t-esc="player.blood_group"/>
              </span>
            </div>
          </t>
          <t t-if="player.contact">
            <div class="hud-stat-row">
              <span class="hud-stat-key">Mobile</span>
              <span class="hud-stat-val"><t t-esc="player.contact"/></span>
            </div>
          </t>
          <t t-if="player.p_category">
            <div class="hud-stat-row">
              <span class="hud-stat-key">Category</span>
              <span class="hud-stat-val"><t t-esc="player.p_category"/></span>
            </div>
          </t>
          <t t-if="player.address">
            <div class="hud-stat-row">
              <span class="hud-stat-key">Location</span>
              <span class="hud-stat-val"><t t-esc="player.address"/></span>
            </div>
          </t>
        </div>

        <!-- action buttons -->
        <div class="hud-actions">
          <button class="hud-btn hud-btn-unsold" onclick="setPlayerUnsold()">Set Unsold</button>
          <button class="hud-btn hud-btn-sell" onclick="openSellModal()">Sell to Team</button>
        </div>

        <!-- next player -->
        <div class="hud-next-bar">
          <button class="hud-next-btn" onclick="changeImage()">
            Next Player
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6 18L14.5 12 6 6V18ZM16 6V18H18V6H16Z"/>
            </svg>
          </button>
        </div>

      </div><!-- /hud-info-col -->
    </div><!-- /hud-arena -->

    <script>
      async function changeImage() {
        var toast = document.getElementById('ac-next-toast');
        var bar   = document.getElementById('ac-next-bar');
        if (toast) {
          toast.style.display  = 'flex';
          toast.style.opacity  = '1';
          bar.style.transition = 'none';
          bar.style.width      = '0%';
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              bar.style.transition = 'width 1.2s cubic-bezier(.4,0,.2,1)';
              bar.style.width      = '80%';
            });
          });
        }
        try {
          var resp = await fetch(window.location.href, {cache: 'no-store'});
          if (!resp.ok) throw new Error('HTTP ' + resp.status);
          var html = await resp.text();
          var parser = new DOMParser();
          var newDoc = parser.parseFromString(html, 'text/html');
          var pid = newDoc.body.getAttribute('data-player-id');
          if (pid) document.body.setAttribute('data-player-id', pid);
          var zone    = document.querySelector('[data-player-zone]');
          var newZone = newDoc.querySelector('[data-player-zone]');
          if (zone &amp;&amp; newZone) { zone.innerHTML = newZone.innerHTML; }
          if (toast) {
            bar.style.transition = 'width 0.15s ease';
            bar.style.width      = '100%';
            setTimeout(function() {
              toast.style.opacity = '0';
              setTimeout(function() { toast.style.display = 'none'; }, 400);
            }, 250);
          }
        } catch(e) {
          console.error('Next player load failed:', e);
          window.location.reload();
        }
      }

      document.addEventListener("keydown", function(event) {
        if (event.code === "Space") {
          event.preventDefault();
          changeImage();
        }
      });

      function setPlayerUnsold() {
        var modal = document.getElementById('unsoldConfirmModal');
        modal.style.display = 'flex';
      }

      (function() {
        document.addEventListener('DOMContentLoaded', function() {
          document.getElementById('unsoldModalCancel').addEventListener('click', function() {
            document.getElementById('unsoldConfirmModal').style.display = 'none';
          });
          document.getElementById('unsoldModalConfirm').addEventListener('click', function() {
            document.getElementById('unsoldConfirmModal').style.display = 'none';
            var playerId = parseInt(document.body.getAttribute('data-player-id'));
            if (!playerId) {
              showUnsoldToast('Error: Player ID not found', true);
              return;
            }
            fetch('/web/dataset/call_kw', {
              method: 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify({
                jsonrpc: '2.0',
                method: 'call',
                params: {
                  model: 'auction.team.player',
                  method: 'action_unsold',
                  args: [[playerId]],
                  kwargs: {}
                }
              })
            }).then(function(response) {
              return response.json();
            }).then(function(result) {
              if (result.error) {
                showUnsoldToast('Failed to mark player as unsold', true);
              } else {
                var secs = (result.result &amp;&amp; result.result.display_seconds > 0) ? result.result.display_seconds : 5;
                showUnsoldStamp(secs, '#F5C842', '#090912');
              }
            }).catch(function() {
              showUnsoldToast('Failed to mark player as unsold', true);
            });
          });
        });
      })();

      function showUnsoldToast(message, isError) {
        var toast = document.getElementById('unsoldToast');
        toast.textContent = message;
        toast.style.background = isError ? '#8B0000' : '#1b5e20';
        toast.style.display = 'block';
        setTimeout(function() { toast.style.display = 'none'; }, 3500);
      }

      function showUnsoldStamp(displaySeconds, stampColor, stampText) {
        if (!document.getElementById('_unsoldStampCSS')) {
          var s = document.createElement('style');
          s.id = '_unsoldStampCSS';
          s.textContent = '@keyframes _unsoldDrop{0%{transform:rotate(-22deg) scale(2.4);opacity:0}100%{transform:rotate(-22deg) scale(1);opacity:.92}}@keyframes _unsoldFadeIn{from{opacity:0}to{opacity:1}}';
          document.head.appendChild(s);
        }
        var img = document.getElementById('loadImage');
        var r = img.getBoundingClientRect();
        var ov = document.createElement('div');
        ov.style.cssText = 'position:fixed;z-index:9500;top:'+r.top+'px;left:'+r.left+'px;width:'+r.width+'px;height:'+r.height+'px;background:rgba(0,0,0,0.48);display:flex;align-items:center;justify-content:center;animation:_unsoldFadeIn .35s ease;pointer-events:none;';
        var stamp = document.createElement('div');
        stamp.style.cssText = 'background:'+stampColor+';color:'+stampText+';font-size:clamp(1.8rem,5vw,3.2rem);font-weight:900;letter-spacing:6px;padding:8px 36px;border:5px solid rgba(255,255,255,0.85);border-radius:6px;box-shadow:0 0 0 3px '+stampColor+',0 8px 40px rgba(0,0,0,.5);opacity:0;animation:_unsoldDrop .5s cubic-bezier(.34,1.3,.64,1) .15s forwards;text-shadow:2px 3px 8px rgba(0,0,0,.4);';
        stamp.textContent = 'UNSOLD';
        var barWrap = document.createElement('div');
