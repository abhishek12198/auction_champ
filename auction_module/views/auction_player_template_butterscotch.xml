<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="player_template_butterscotch" name="Player Auction – Butterscotch">
    <html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
      crossorigin="anonymous"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1" />
    <link
      href="https://fonts.googleapis.com/css2?family=Teko:wght@400;600;700&amp;family=Rajdhani:wght@500;600;700&amp;display=swap"
      rel="stylesheet"
    />
    <title>Player Showcase</title>
    <style>
      /* ── Base ─────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --gold:        #F5C842;
        --gold-dark:   #C8960C;
        --gold-glow:   rgba(245, 200, 66, 0.35);
        --amber:       #FF9F1C;
        --bg-deep:     #090912;
        --bg-card:     rgba(255, 255, 255, 0.04);
        --border-gold: rgba(245, 200, 66, 0.45);
        --text-dim:    rgba(255,255,255,0.55);
        --white:       #ffffff;
      }

      html, body {
        min-height: 100vh;
        background: var(--bg-deep);
        color: var(--white);
        font-family: 'Rajdhani', sans-serif;
        overflow-x: hidden;
      }

      /* ── Ambient light blobs ───────────────────────────────── */
      body::before {
        content: '';
        position: fixed;
        top: -220px; left: -220px;
        width: 700px; height: 700px;
        background: radial-gradient(circle, rgba(245,200,66,.18) 0%, transparent 70%);
        pointer-events: none; z-index: 0;
      }
      body::after {
        content: '';
        position: fixed;
        bottom: -200px; right: -200px;
        width: 600px; height: 600px;
        background: radial-gradient(circle, rgba(255,159,28,.14) 0%, transparent 70%);
        pointer-events: none; z-index: 0;
      }

      /* ── Header ─────────────────────────────────────────────── */
      .bs-header {
        position: relative; z-index: 10;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding: 16px 40px;
        background: rgba(9,9,18,.85);
        border-bottom: 1px solid var(--border-gold);
        backdrop-filter: blur(12px);
      }

      /* Left: tournament name + description */
      .bs-header-info {
        display: flex; flex-direction: column; justify-content: center;
      }
      .bs-header-info h2 {
        font-family: 'Teko', sans-serif;
        font-size: 1.8rem; font-weight: 700;
        color: var(--gold);
        line-height: 1; text-transform: uppercase; letter-spacing: 2px;
        margin: 0;
      }
      .bs-header-info p {
        font-size: .85rem; color: var(--text-dim);
        letter-spacing: 1px; margin: 0;
      }

      /* Center: Auction Champ logo */
      .bs-header-center {
        display: flex; justify-content: center; align-items: center;
      }
      .bs-header-center .brand-logo {
        width: 110px; height: 110px;
        object-fit: contain;
        filter: brightness(0) invert(1) sepia(0.6) saturate(400%) hue-rotate(10deg)
                brightness(1.05) drop-shadow(0 0 14px rgba(245,200,66,0.55));
      }

      /* Right: tournament logo */
      .bs-header-logo {
        display: flex; justify-content: flex-end; align-items: center;
      }
      .bs-header-logo img {
        width: 100%;
        max-height: 110px;
        object-fit: contain;
        object-position: right center;
        opacity: .95;
      }

      @media (max-width: 640px) {
        .bs-header {
          grid-template-columns: 1fr;
          grid-template-rows: auto auto auto;
          text-align: center;
          gap: 8px;
          padding: 14px 20px;
        }
        .bs-header-center .brand-logo { width: 80px; height: 80px; }
        .bs-header-logo { justify-content: center; }
      }

      /* ── Main layout ─────────────────────────────────────────── */
      .bs-stage {
        position: relative; z-index: 5;
        display: grid;
        grid-template-columns: 260px 1fr 340px;
        gap: 28px;
        max-width: 1300px;
        margin: 36px auto;
        padding: 0 24px;
        align-items: start;
      }

      /* ── Left column – identity ──────────────────────────────── */
      .bs-identity {
        display: flex; flex-direction: column;
        gap: 14px;
      }

      .bs-serial {
        font-family: 'Teko', sans-serif;
        font-size: 7rem; font-weight: 700;
        line-height: 1;
        background: linear-gradient(135deg, var(--gold) 30%, var(--amber) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: none;
        filter: drop-shadow(0 0 18px var(--gold-glow));
      }

      .bs-divider {
        height: 2px;
        background: linear-gradient(90deg, var(--gold), var(--amber), transparent);
        border-radius: 2px;
      }

      .bs-player-name {
        font-family: 'Teko', sans-serif;
        font-size: 2.6rem; font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--white);
        line-height: 1.1;
      }

      .bs-role {
        font-size: 1rem; font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--amber);
      }

      .bs-tier-badge {
        display: inline-block;
        padding: 6px 20px;
        border-radius: 30px;
        font-size: .95rem; font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        border: 1px solid var(--border-gold);
        box-shadow: 0 0 14px var(--gold-glow);
        width: fit-content;
      }

      /* ── Center column – player image ───────────────────────── */
      .bs-photo-wrap {
        display: flex; justify-content: center; align-items: flex-start;
      }

      .bs-photo-frame {
        position: relative;
        width: 320px;
      }

      /* corner ornaments */
      .bs-photo-frame::before,
      .bs-photo-frame::after {
        content: '';
        position: absolute;
        width: 40px; height: 40px;
        border-color: var(--gold);
        border-style: solid;
        z-index: 3;
      }
      .bs-photo-frame::before {
        top: -6px; left: -6px;
        border-width: 3px 0 0 3px;
      }
      .bs-photo-frame::after {
        bottom: -6px; right: -6px;
        border-width: 0 3px 3px 0;
      }

      .bs-photo-inner {
        position: relative;
        border-radius: 6px;
        overflow: hidden;
        background: linear-gradient(160deg, #1c1a2e, #0e0c1a);
        box-shadow:
          0 0 0 2px var(--gold-dark),
          0 0 50px rgba(245,200,66,.2),
          0 24px 60px rgba(0,0,0,.7);
      }

      /* Tier-colored glow line at bottom */
      .bs-photo-inner::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 6px;
        background: var(--tier-color, var(--gold));
        box-shadow: 0 0 20px var(--tier-color, var(--gold));
      }

      .bs-photo-inner img {
        display: block;
        width: 100%;
        aspect-ratio: 380/553;
        object-fit: cover;
        object-position: top center;
      }

      /* spotlight overlay */
      .bs-photo-inner::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to bottom,
          transparent 55%,
          rgba(9,9,18,.85) 100%
        );
        z-index: 1;
        pointer-events: none;
      }

      /* ── Right column – attributes ──────────────────────────── */
      .bs-attrs-panel {
        display: flex; flex-direction: column; gap: 12px;
      }

      .bs-attrs-title {
        font-family: 'Teko', sans-serif;
        font-size: 1.4rem; font-weight: 600;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: var(--gold);
        border-bottom: 1px solid var(--border-gold);
        padding-bottom: 8px;
      }

      .bs-attr-row {
        display: flex; align-items: stretch;
        background: var(--bg-card);
        border: 1px solid var(--border-gold);
        border-radius: 6px;
        overflow: hidden;
        transition: border-color .2s;
      }
      .bs-attr-row:hover { border-color: var(--gold); }

      .bs-attr-key {
        flex: 0 0 130px;
        padding: 10px 14px;
        font-size: .8rem; font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(245,200,66,.07);
        display: flex; align-items: center;
        border-right: 1px solid var(--border-gold);
      }

      .bs-attr-val {
        flex: 1;
        padding: 10px 16px;
        font-size: .95rem; font-weight: 600;
        color: var(--white);
        display: flex; align-items: center;
      }

      /* ── Action row ─────────────────────────────────────────── */
      .bs-actions {
        position: relative; z-index: 5;
        display: flex; justify-content: center; align-items: center;
        gap: 20px;
        margin: 8px 0 0;
      }

      .bs-btn {
        padding: 12px 32px;
        border-radius: 4px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 1rem; font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        cursor: pointer;
        border: none;
        transition: all .25s;
      }

      .bs-btn-unsold {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,.3);
        color: var(--white);
      }
      .bs-btn-unsold:hover {
        border-color: var(--amber);
        color: var(--amber);
        box-shadow: 0 0 14px rgba(255,159,28,.3);
      }

      .bs-btn-sell {
        background: linear-gradient(135deg, var(--gold-dark), var(--amber));
        color: #0a0a1a;
        box-shadow: 0 4px 20px rgba(245,200,66,.35);
      }
      .bs-btn-sell:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(245,200,66,.5);
      }
      .bs-btn-sell:disabled { opacity: .4; cursor: not-allowed; }

      /* ── Next-player strip ──────────────────────────────────── */
      .bs-next-strip {
        position: relative; z-index: 5;
        display: flex; justify-content: center;
        padding: 24px 0 40px;
      }

      .bs-next-btn {
        display: inline-flex; align-items: center; gap: 10px;
        padding: 14px 40px;
        background: linear-gradient(135deg, rgba(245,200,66,.12), rgba(255,159,28,.08));
        border: 1px solid var(--border-gold);
        border-radius: 50px;
        color: var(--gold);
        font-family: 'Teko', sans-serif;
        font-size: 1.4rem; font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all .25s;
      }
      .bs-next-btn:hover {
        background: linear-gradient(135deg, rgba(245,200,66,.22), rgba(255,159,28,.15));
        box-shadow: 0 0 28px var(--gold-glow);
        transform: scale(1.03);
      }
      .bs-next-btn svg { transition: transform .25s; }
      .bs-next-btn:hover svg { transform: translateX(4px); }

      /* ── Responsive fallback ────────────────────────────────── */
      @media (max-width: 1024px) {
        .bs-stage {
          grid-template-columns: 1fr 1fr;
          grid-template-rows: auto auto;
        }
        .bs-photo-wrap { grid-column: 1 / -1; justify-content: center; }
        .bs-photo-frame { width: 280px; }
      }

      @media (max-width: 640px) {
        .bs-stage { grid-template-columns: 1fr; padding: 0 16px; }
        .bs-serial { font-size: 5rem; }
        .bs-player-name { font-size: 2rem; }
        .bs-photo-frame { width: 240px; }
      }
    </style>
  </head>

  <body t-att-data-player-id="player.id">

    <!-- ── HEADER ───────────────────────────────────────────── -->
    <header class="bs-header">
      <!-- Left: tournament name + description -->
      <div class="bs-header-info">
        <h2><t t-esc="player.tournament_id.name"/></h2>
        <p><t t-esc="player.tournament_id.description"/></p>
      </div>

      <!-- Center: Auction Champ logo (prominent) -->
      <div class="bs-header-center">
        <img src="/auction_module/static/src/assets/images/logo.svg" alt="Auction Champ Logo" class="brand-logo" />
      </div>

      <!-- Right: tournament logo -->
      <div class="bs-header-logo">
        <img t-att-src="image_data_uri(player.tournament_id.logo)" alt="Tournament Logo" />
      </div>
    </header>

    <!-- ── MAIN STAGE ──────────────────────────────────────── -->
    <div class="bs-stage">

      <!-- Left: identity -->
      <div class="bs-identity">
        <div class="bs-serial"><t t-esc="player.sl_no"/></div>
        <div class="bs-divider"></div>
        <div class="bs-player-name"><t t-esc="player.name.upper()"/></div>
        <div class="bs-role"><t t-esc="player.role"/></div>
        <t t-if="player.tier_id">
          <span class="bs-tier-badge"
                t-att-style="'background-color: ' + (player.tier_id.color or '#C8960C') + '26; color: ' + (player.tier_id.color or '#F5C842') + '; border-color: ' + (player.tier_id.color or '#F5C842') + '80;'">
            <t t-esc="player.tier_id.name"/>
          </span>
        </t>

        <!-- Action buttons placed under identity on wide screens -->
        <div class="bs-actions mt-4">
          <button class="bs-btn bs-btn-unsold" onclick="setPlayerUnsold()">Set Unsold</button>
          <button class="bs-btn bs-btn-sell" onclick="openSellModal()">Sell to Team</button>
        </div>
      </div>

      <!-- Center: photo -->
      <div class="bs-photo-wrap">
        <div class="bs-photo-frame">
          <div class="bs-photo-inner"
               t-att-style="'--tier-color: ' + (player.tier_id.color if player.tier_id else '#F5C842')">
            <img t-att-src="image_data_uri(player.photo)" alt="Player Photo" id="loadImage" />
          </div>
        </div>
      </div>

      <!-- Right: attributes panel -->
      <div class="bs-attrs-panel">
        <div class="bs-attrs-title">Player Attributes</div>

        <t t-if="player.batting_style">
          <div class="bs-attr-row">
            <span class="bs-attr-key">Batting</span>
            <span class="bs-attr-val"><t t-esc="player.batting_style"/></span>
          </div>
        </t>
        <t t-if="player.bowling_style">
          <div class="bs-attr-row">
            <span class="bs-attr-key">Bowling</span>
            <span class="bs-attr-val"><t t-esc="player.bowling_style"/></span>
          </div>
        </t>
        <t t-if="player.blood_group">
          <div class="bs-attr-row">
            <span class="bs-attr-key">Blood Group</span>
            <span class="bs-attr-val" style="color:#f87171; font-weight:700;"><t t-esc="player.blood_group"/></span>
          </div>
        </t>
        <t t-if="player.contact">
          <div class="bs-attr-row">
            <span class="bs-attr-key">Mobile</span>
            <span class="bs-attr-val"><t t-esc="player.contact"/></span>
          </div>
        </t>
        <t t-if="player.p_category">
          <div class="bs-attr-row">
            <span class="bs-attr-key">Category</span>
            <span class="bs-attr-val"><t t-esc="player.p_category"/></span>
          </div>
        </t>
        <t t-if="player.address">
          <div class="bs-attr-row">
            <span class="bs-attr-key">Location</span>
            <span class="bs-attr-val"><t t-esc="player.address"/></span>
          </div>
        </t>
      </div>

    </div><!-- /bs-stage -->

    <!-- ── NEXT PLAYER ─────────────────────────────────────── -->
    <div class="bs-next-strip">
      <button class="bs-next-btn" onclick="changeImage()">
        Next Player
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 18L14.5 12 6 6V18ZM16 6V18H18V6H16Z"/>
        </svg>
      </button>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM"
      crossorigin="anonymous"
    ></script>

    <script>
      function changeImage() {
        window.location.reload();
      }

      document.addEventListener("keydown", function(event) {
        if (event.code === "Space") {
          event.preventDefault();
          changeImage();
        }
      });

      function setPlayerUnsold() {
        var modal = document.getElementById('unsoldConfirmModal');
        modal.style.display = 'flex';
      }

      (function() {
        document.addEventListener('DOMContentLoaded', function() {
          document.getElementById('unsoldModalCancel').addEventListener('click', function() {
            document.getElementById('unsoldConfirmModal').style.display = 'none';
          });
          document.getElementById('unsoldModalConfirm').addEventListener('click', function() {
            document.getElementById('unsoldConfirmModal').style.display = 'none';
            var playerId = parseInt(document.body.getAttribute('data-player-id'));
            if (!playerId) {
              showUnsoldToast('Error: Player ID not found', true);
              return;
            }
            fetch('/web/dataset/call_kw', {
              method: 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify({
                jsonrpc: '2.0',
                method: 'call',
                params: {
                  model: 'auction.team.player',
                  method: 'action_unsold',
                  args: [[playerId]],
                  kwargs: {}
                }
              })
            }).then(function(response) {
              return response.json();
            }).then(function(result) {
              if (result.error) {
                showUnsoldToast('Failed to mark player as unsold', true);
              } else {
                var secs = (result.result &amp;&amp; result.result.display_seconds > 0) ? result.result.display_seconds : 5;
                showUnsoldStamp(secs, '#F5C842', '#090912');
              }
            }).catch(function() {
              showUnsoldToast('Failed to mark player as unsold', true);
            });
          });
        });
      })();

      function showUnsoldToast(message, isError) {
        var toast = document.getElementById('unsoldToast');
        toast.textContent = message;
        toast.style.background = isError ? '#8B0000' : '#1b5e20';
        toast.style.display = 'block';
        setTimeout(function() { toast.style.display = 'none'; }, 3500);
      }

      function showUnsoldStamp(displaySeconds, stampColor, stampText) {
        if (!document.getElementById('_unsoldStampCSS')) {
          var s = document.createElement('style');
          s.id = '_unsoldStampCSS';
          s.textContent = '@keyframes _unsoldDrop{0%{transform:rotate(-22deg) scale(2.4);opacity:0}100%{transform:rotate(-22deg) scale(1);opacity:.92}}@keyframes _unsoldFadeIn{from{opacity:0}to{opacity:1}}';
          document.head.appendChild(s);
        }
        var img = document.getElementById('loadImage');
        var r = img.getBoundingClientRect();
        var ov = document.createElement('div');
        ov.style.cssText = 'position:fixed;z-index:9500;top:'+r.top+'px;left:'+r.left+'px;width:'+r.width+'px;height:'+r.height+'px;background:rgba(0,0,0,0.48);display:flex;align-items:center;justify-content:center;animation:_unsoldFadeIn .35s ease;pointer-events:none;';
        var stamp = document.createElement('div');
        stamp.style.cssText = 'background:'+stampColor+';color:'+stampText+';font-size:clamp(1.8rem,5vw,3.2rem);font-weight:900;letter-spacing:6px;padding:8px 36px;border:5px solid rgba(255,255,255,0.85);border-radius:6px;box-shadow:0 0 0 3px '+stampColor+',0 8px 40px rgba(0,0,0,.5);opacity:0;animation:_unsoldDrop .5s cubic-bezier(.34,1.3,.64,1) .15s forwards;text-shadow:2px 3px 8px rgba(0,0,0,.4);';
        stamp.textContent = 'UNSOLD';
        var barWrap = document.createElement('div');
        barWrap.style.cssText = 'position:absolute;bottom:12px;left:16px;right:16px;';
        var barTrack = document.createElement('div');
        barTrack.style.cssText = 'background:rgba(255,255,255,0.25);border-radius:4px;height:6px;overflow:hidden;';
        var bar = document.createElement('div');
        bar.style.cssText = 'height:100%;width:100%;background:'+stampColor+';border-radius:4px;transition:width '+displaySeconds+'s linear;';
        barTrack.appendChild(bar);
        barWrap.appendChild(barTrack);
        ov.appendChild(stamp);
        ov.appendChild(barWrap);
        document.body.appendChild(ov);
        requestAnimationFrame(function() { requestAnimationFrame(function() { bar.style.width = '0%'; }); });
        setTimeout(function() { if (ov.parentNode) ov.parentNode.removeChild(ov); changeImage(); }, displaySeconds * 1000);
      }

      function openBidSummary() {
        document.getElementById('bidSummaryFrame').src = '/auction/show/team/balance';
        document.getElementById('bidSummaryDrawer').style.right = '0';
        document.getElementById('bidSummaryTabArrow').innerHTML = '&#x2192;';
        document.getElementById('bidSummaryOverlay').style.display = 'block';
        document.body.style.overflow = 'hidden';
      }
      function closeBidSummary() {
        document.getElementById('bidSummaryDrawer').style.right = '-1150px';
        document.getElementById('bidSummaryTabArrow').innerHTML = '&#x2190;';
        document.getElementById('bidSummaryOverlay').style.display = 'none';
        document.body.style.overflow = '';
      }
      function toggleBidSummary() {
        var r = document.getElementById('bidSummaryDrawer').style.right;
        if (r === '0px' || r === '0') { closeBidSummary(); } else { openBidSummary(); }
      }
    </script>
      <!-- Bid Summary Drawer — Butterscotch Theme -->
      <div id="bidSummaryDrawer" style="position:fixed; top:0; right:-1150px; width:1150px; max-width:96vw; height:100vh; z-index:9800; display:flex; flex-direction:column; background:rgba(9,9,18,0.99); border-left:3px solid #F5C842; box-shadow:-6px 0 40px rgba(245,200,66,0.2); transition:right .35s cubic-bezier(.4,0,.2,1);">
        <!-- Fold/unfold tab -->
        <div onclick="toggleBidSummary()" style="position:absolute; left:-44px; top:50%; transform:translateY(-50%); width:44px; height:130px; background:linear-gradient(180deg,#6b4f00,#C8960C); border-radius:8px 0 0 8px; cursor:pointer; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; box-shadow:-4px 2px 14px rgba(245,200,66,0.3); z-index:1; border:1px solid rgba(245,200,66,0.25);">
          <span id="bidSummaryTabArrow" style="color:#F5C842; font-size:1.2rem; line-height:1;">&#x2190;</span>
          <span style="color:#F5C842; writing-mode:vertical-rl; transform:rotate(180deg); font-size:0.58rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; opacity:0.9;">Summary</span>
        </div>
        <div style="padding:16px 20px; background:rgba(9,9,18,0.99); color:#fff; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; border-bottom:2px solid #F5C842;">
