<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="page_not_found" name="Auction – Page Not Found">
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <link rel="shortcut icon" t-att-href="'/web/image/res.company/%d/favicon' % res_company.id" type="image/x-icon"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>404 – Page Not Found</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=Barlow+Condensed:wght@400;600;700&amp;family=Poppins:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #070c18;
      --bg2:      #0b1120;
      --accent:   #3b72e8;
      --accent2:  #5d93ff;
      --gold:     #f5c842;
      --text:     #e8f0fe;
      --muted:    rgba(232,240,254,0.50);
      --surface:  rgba(255,255,255,0.04);
      --border:   rgba(255,255,255,0.08);
      --glow:     rgba(59,114,232,0.40);
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'Poppins', sans-serif;
      overflow: hidden;
    }

    /* ── Animated starfield background ── */
    .nf-bg {
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 50% -10%, rgba(59,114,232,0.18) 0%, transparent 70%),
        radial-gradient(ellipse 60% 40% at 80% 110%, rgba(93,147,255,0.10) 0%, transparent 60%),
        var(--bg);
      z-index: 0;
    }

    /* floating particles */
    .nf-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle, rgba(255,255,255,0.18) 1px, transparent 1px),
        radial-gradient(circle, rgba(255,255,255,0.10) 1px, transparent 1px);
      background-size: 120px 120px, 200px 200px;
      background-position: 0 0, 60px 60px;
      animation: drift 18s linear infinite;
      opacity: 0.5;
    }

    @keyframes drift {
      from { transform: translateY(0); }
      to   { transform: translateY(-120px); }
    }

    /* ── Page layout ── */
    .nf-wrap {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 2rem 1.5rem;
      text-align: center;
    }

    /* ── Glowing 404 number ── */
    .nf-code {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(7rem, 22vw, 14rem);
      line-height: 1;
      letter-spacing: 0.04em;
      background: linear-gradient(135deg, var(--accent) 0%, var(--gold) 55%, var(--accent2) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 40px var(--glow));
      animation: pulse-glow 3s ease-in-out infinite;
      user-select: none;
    }

    @keyframes pulse-glow {
      0%, 100% { filter: drop-shadow(0 0 30px var(--glow)); }
      50%       { filter: drop-shadow(0 0 65px rgba(59,114,232,0.70)); }
    }

    /* ── Sport icon bounce ── */
    .nf-icon {
      font-size: 3.2rem;
      margin: -0.5rem 0 0.5rem;
      display: block;
      animation: bounce 1.8s ease-in-out infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      45%      { transform: translateY(-14px); }
      60%      { transform: translateY(-8px); }
    }

    /* ── Card container ── */
    .nf-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2.2rem 2.8rem 2.4rem;
      max-width: 520px;
      width: 100%;
      backdrop-filter: blur(12px);
      box-shadow: 0 8px 48px rgba(0,0,0,0.55), 0 0 0 1px rgba(59,114,232,0.12);
      margin-top: 0.5rem;
    }

    .nf-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.85rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--text);
      margin-bottom: 0.65rem;
      text-transform: uppercase;
    }

    .nf-title span {
      color: var(--gold);
    }

    .nf-desc {
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 0.5rem;
    }

    /* ── Divider ── */
    .nf-divider {
      width: 48px;
      height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--gold));
      border-radius: 4px;
      margin: 1.2rem auto;
    }

    /* ── URL display ── */
    .nf-url-box {
      background: rgba(0,0,0,0.35);
      border: 1px solid rgba(59,114,232,0.22);
      border-radius: 10px;
      padding: 0.6rem 1rem;
      font-size: 0.8rem;
      color: rgba(93,147,255,0.75);
      font-family: monospace;
      word-break: break-all;
      margin-bottom: 1.6rem;
    }

    .nf-url-box::before {
      content: '⚠ ';
      color: var(--gold);
    }

    /* ── Buttons ── */
    .nf-actions {
      display: flex;
      gap: 0.9rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .nf-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.65rem 1.5rem;
      border-radius: 10px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: transform 0.18s, box-shadow 0.18s, background 0.18s;
    }

    .nf-btn:hover { transform: translateY(-2px); }

    .nf-btn-primary {
      background: linear-gradient(135deg, var(--accent), #2558cc);
      color: #fff;
      box-shadow: 0 4px 20px rgba(59,114,232,0.40);
    }
    .nf-btn-primary:hover { box-shadow: 0 6px 28px rgba(59,114,232,0.60); }

    .nf-btn-ghost {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border);
    }
    .nf-btn-ghost:hover { background: var(--surface); color: var(--text); }

    /* ── Footer tag ── */
    .nf-foot {
      margin-top: 2.4rem;
      font-size: 0.75rem;
      color: rgba(255,255,255,0.18);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <div class="nf-bg"></div>

  <div class="nf-wrap">
    <div class="nf-code">404</div>
    <span class="nf-icon">🏏</span>

    <div class="nf-card">
      <div class="nf-title">Clean <span>Bowled!</span></div>
      <p class="nf-desc">
        The page you're looking for isn't in the playing arena.<br/>
        The link may have expired, the tournament may have changed,<br/>
        or the URL might have a typo.
      </p>

      <div class="nf-divider"></div>

      <div class="nf-url-box" id="nf-path">Loading URL…</div>

      <div class="nf-actions">
        <a href="javascript:history.back()" class="nf-btn nf-btn-primary">
          &#8592; Go Back
        </a>
        <a href="/" class="nf-btn nf-btn-ghost">
          🏠 Home
        </a>
      </div>
    </div>

    <div class="nf-foot">Auction Champ &#160;·&#160; Page Not Found</div>
  </div>

  <script>
    (function () {
      var el = document.getElementById('nf-path');
      if (el) { el.textContent = window.location.pathname; }
    })();
  </script>
</body>
</html>
</template>

</odoo>
