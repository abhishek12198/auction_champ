<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="player_template_cherry" name="Player Auction – Cherry">
    <html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
      crossorigin="anonymous"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1" />
    <link
      href="https://fonts.googleapis.com/css2?family=Teko:wght@400;600;700&amp;family=Rajdhani:wght@400;500;600;700&amp;display=swap"
      rel="stylesheet"
    />
    <title>Player Showcase</title>
    <style>
      /* ── Base ─────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --cherry:       #DC143C;
        --cherry-dark:  #8B0000;
        --cherry-bright:#FF1744;
        --cherry-glow:  rgba(220, 20, 60, 0.30);
        --border-red:   rgba(220, 20, 60, 0.40);
        --bg:           #0d0d0d;
        --bg-surface:   #181818;
        --bg-card:      #1e1e1e;
        --bg-card2:     #242424;
        --white:        #ffffff;
        --text-main:    #f5f5f5;
        --text-dim:     rgba(245, 245, 245, 0.55);
        --divider:      rgba(220, 20, 60, 0.35);
      }

      html, body {
        min-height: 100vh;
        background: var(--bg);
        color: var(--text-main);
        font-family: 'Rajdhani', sans-serif;
        overflow-x: hidden;
      }

      /* ── Dramatic red scanline vignette ────────────────────── */
      body::before {
        content: '';
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background:
          radial-gradient(ellipse at top left, rgba(220,20,60,.12) 0%, transparent 55%),
          radial-gradient(ellipse at bottom right, rgba(139,0,0,.14) 0%, transparent 55%);
        pointer-events: none; z-index: 0;
      }

      /* ── Header ─────────────────────────────────────────────── */
      .ch-header {
        position: relative; z-index: 10;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding: 16px 40px;
        background: linear-gradient(135deg, #0a0a0a 0%, #1a0608 50%, #0a0a0a 100%);
        border-bottom: 3px solid var(--cherry);
        box-shadow: 0 4px 32px rgba(220,20,60,.30), inset 0 -1px 0 rgba(220,20,60,.2);
      }

      /* red top stripe */
      .ch-header::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, transparent, var(--cherry), var(--cherry-bright), var(--cherry), transparent);
      }

      .ch-header-info { display: flex; flex-direction: column; }
      .ch-header-info h2 {
        font-family: 'Teko', sans-serif;
        font-size: 1.8rem; font-weight: 700;
        color: var(--white);
        line-height: 1; text-transform: uppercase; letter-spacing: 2px; margin: 0;
      }
      .ch-header-info p {
        font-size: .85rem; color: rgba(255,255,255,.65);
        letter-spacing: 1px; margin: 0;
      }

      .ch-header-center { display: flex; justify-content: center; align-items: center; }
      .ch-header-center .brand-logo {
        width: 110px; height: 110px;
        object-fit: contain;
        filter: brightness(0) invert(1) sepia(0.8) saturate(600%) hue-rotate(320deg) brightness(1.1) drop-shadow(0 0 14px rgba(220,20,60,0.6));
      }

      .ch-header-logo { display: flex; justify-content: flex-end; align-items: center; }
      .ch-header-logo img {
        width: 100%;
        max-height: 110px;
        object-fit: contain;
        object-position: right center;
        opacity: .92;
        filter: drop-shadow(0 0 8px rgba(220,20,60,.25));
      }

      /* ── Main layout ─────────────────────────────────────────── */
      .ch-stage {
        position: relative; z-index: 5;
        display: grid;
        grid-template-columns: 260px 1fr 340px;
        gap: 28px;
        max-width: 1300px;
        margin: 36px auto;
        padding: 0 24px;
        align-items: start;
      }

      /* ── Left – identity ─────────────────────────────────────── */
      .ch-identity { display: flex; flex-direction: column; gap: 12px; }

      .ch-serial {
        font-family: 'Teko', sans-serif;
        font-size: 7rem; font-weight: 700; line-height: 1;
        background: linear-gradient(135deg, var(--cherry) 20%, var(--white) 80%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 18px var(--cherry-glow));
      }

      .ch-divider {
        height: 3px;
        background: linear-gradient(90deg, var(--cherry), var(--cherry-bright), transparent);
        border-radius: 2px;
        box-shadow: 0 0 8px rgba(220,20,60,.5);
      }

      .ch-player-name {
        font-family: 'Teko', sans-serif;
        font-size: 2.6rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 2px;
        color: var(--white); line-height: 1.1;
      }

      .ch-role {
        font-size: 1rem; font-weight: 700;
        letter-spacing: 3px; text-transform: uppercase;
        color: var(--cherry);
      }

      .ch-tier-badge {
        display: inline-block;
        padding: 6px 20px; border-radius: 30px;
        font-size: .95rem; font-weight: 700;
        letter-spacing: 2px; text-transform: uppercase;
        width: fit-content;
      }

      /* ── Center – photo ──────────────────────────────────────── */
      .ch-photo-wrap { display: flex; justify-content: center; align-items: flex-start; }

      .ch-photo-frame { position: relative; width: 320px; }

      /* corner ornaments */
      .ch-photo-frame::before, .ch-photo-frame::after {
        content: '';
        position: absolute;
        width: 40px; height: 40px;
        border-color: var(--cherry);
        border-style: solid;
        z-index: 3;
      }
      .ch-photo-frame::before { top: -6px; left: -6px; border-width: 3px 0 0 3px; box-shadow: -3px -3px 8px rgba(220,20,60,.4); }
      .ch-photo-frame::after  { bottom: -6px; right: -6px; border-width: 0 3px 3px 0; box-shadow: 3px 3px 8px rgba(220,20,60,.4); }

      .ch-photo-inner {
        position: relative; border-radius: 6px; overflow: hidden;
        background: var(--bg-surface);
        box-shadow:
          0 0 0 2px var(--cherry),
          0 0 40px rgba(220,20,60,.20),
          0 24px 60px rgba(0,0,0,.6);
      }
      /* tier-coloured bottom bar */
      .ch-photo-inner::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0; height: 6px;
        background: var(--tier-color, var(--cherry));
        box-shadow: 0 0 20px var(--tier-color, var(--cherry));
      }
      .ch-photo-inner img {
        display: block; width: 100%;
        aspect-ratio: 380/553;
        object-fit: cover; object-position: top center;
      }
      /* dark vignette overlay */
      .ch-photo-inner::before {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(to bottom, transparent 55%, rgba(0,0,0,.55) 100%);
        z-index: 1; pointer-events: none;
      }

      /* ── Right – attributes ──────────────────────────────────── */
      .ch-attrs-panel { display: flex; flex-direction: column; gap: 10px; }

      .ch-attrs-title {
        font-family: 'Teko', sans-serif;
        font-size: 1.4rem; font-weight: 600;
        letter-spacing: 4px; text-transform: uppercase;
        color: var(--cherry);
        border-bottom: 2px solid var(--divider);
        padding-bottom: 8px;
      }

      .ch-attr-row {
        display: flex; align-items: stretch;
        background: var(--bg-card);
        border: 1px solid var(--border-red);
        border-radius: 8px; overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.3);
        transition: border-color .2s, box-shadow .2s;
      }
      .ch-attr-row:hover {
        border-color: var(--cherry);
        box-shadow: 0 4px 16px rgba(220,20,60,.20);
      }

      .ch-attr-key {
        flex: 0 0 130px; padding: 10px 14px;
        font-size: .8rem; font-weight: 700;
        letter-spacing: 1.5px; text-transform: uppercase;
        color: var(--white);
        background: var(--cherry);
        display: flex; align-items: center;
      }

      .ch-attr-val {
        flex: 1; padding: 10px 16px;
        font-size: .95rem; font-weight: 600;
        color: var(--text-main);
        display: flex; align-items: center;
        background: var(--bg-card);
      }

      /* ── Action buttons ──────────────────────────────────────── */
      .ch-actions {
        position: relative; z-index: 5;
        display: flex; justify-content: center; align-items: center;
        gap: 16px; margin-top: 16px;
      }

      .ch-btn {
        padding: 12px 32px; border-radius: 50px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 1rem; font-weight: 700;
        letter-spacing: 1px; text-transform: uppercase;
        cursor: pointer; border: none; transition: all .25s;
      }

      .ch-btn-unsold {
        background: transparent;
        border: 2px solid var(--border-red);
        color: var(--cherry);
      }
      .ch-btn-unsold:hover {
        border-color: var(--cherry);
        background: rgba(220,20,60,.10);
      }

      .ch-btn-sell {
        background: linear-gradient(135deg, var(--cherry-dark), var(--cherry-bright));
        color: var(--white);
        box-shadow: 0 4px 18px rgba(220,20,60,.45);
      }
      .ch-btn-sell:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(220,20,60,.60);
      }
      .ch-btn-sell:disabled { opacity: .4; cursor: not-allowed; }

      /* ── Next-player strip ──────────────────────────────────── */
      .ch-next-strip {
        position: relative; z-index: 5;
        display: flex; justify-content: center;
        padding: 24px 0 40px;
      }

      .ch-next-btn {
        display: inline-flex; align-items: center; gap: 10px;
        padding: 14px 44px;
        background: linear-gradient(135deg, var(--cherry-dark), var(--cherry-bright));
        border: none; border-radius: 50px;
        color: var(--white);
        font-family: 'Teko', sans-serif;
        font-size: 1.4rem; font-weight: 600;
        letter-spacing: 3px; text-transform: uppercase;
        cursor: pointer; transition: all .25s;
        box-shadow: 0 6px 24px rgba(220,20,60,.45);
      }
      .ch-next-btn:hover {
        transform: scale(1.04);
        box-shadow: 0 10px 32px rgba(220,20,60,.65);
      }
      .ch-next-btn svg { transition: transform .25s; }
      .ch-next-btn:hover svg { transform: translateX(4px); }

      /* ── Responsive ──────────────────────────────────────────── */
      @media (max-width: 1024px) {
        .ch-stage { grid-template-columns: 1fr 1fr; }
        .ch-photo-wrap { grid-column: 1 / -1; justify-content: center; }
        .ch-photo-frame { width: 280px; }
      }
      @media (max-width: 640px) {
        .ch-stage { grid-template-columns: 1fr; padding: 0 16px; }
        .ch-header { grid-template-columns: 1fr; text-align: center; gap: 8px; padding: 14px 20px; }
        .ch-header-logo { justify-content: center; }
        .ch-header-center .brand-logo { width: 80px; height: 80px; }
        .ch-serial { font-size: 5rem; }
        .ch-player-name { font-size: 2rem; }
        .ch-photo-frame { width: 240px; }
      }
    </style>
  </head>

  <body t-att-data-player-id="player.id">

    <!-- ── HEADER ───────────────────────────────────────────── -->
    <header class="ch-header">
      <div class="ch-header-info">
        <h2><t t-esc="player.tournament_id.name"/></h2>
        <p><t t-esc="player.tournament_id.description"/></p>
      </div>
      <div class="ch-header-center">
        <img src="/auction_module/static/src/assets/images/logo.svg" alt="Auction Champ Logo" class="brand-logo" />
      </div>
      <div class="ch-header-logo">
        <img t-att-src="image_data_uri(player.tournament_id.logo)" alt="Tournament Logo" />
      </div>
    </header>

    <!-- ── MAIN STAGE ──────────────────────────────────────── -->
    <div class="ch-stage">

      <!-- Left: identity -->
      <div class="ch-identity">
        <div class="ch-serial"><t t-esc="player.sl_no"/></div>
        <div class="ch-divider"></div>
        <div class="ch-player-name"><t t-esc="player.name.upper()"/></div>
        <div class="ch-role"><t t-esc="player.role"/></div>
        <t t-if="player.tier_id">
          <span class="ch-tier-badge"
                t-att-style="'background-color: ' + (player.tier_id.color or '#DC143C') + '28; color: ' + (player.tier_id.color or '#DC143C') + '; border: 1.5px solid ' + (player.tier_id.color or '#DC143C') + '80;'">
            <t t-esc="player.tier_id.name"/>
          </span>
        </t>
        <div class="ch-actions">
          <button class="ch-btn ch-btn-unsold" onclick="setPlayerUnsold()">Set Unsold</button>
          <button class="ch-btn ch-btn-sell" onclick="openSellModal()">Sell to Team</button>
        </div>
      </div>

      <!-- Center: photo -->
      <div class="ch-photo-wrap">
        <div class="ch-photo-frame">
          <div class="ch-photo-inner"
               t-att-style="'--tier-color: ' + (player.tier_id.color if player.tier_id else '#DC143C')">
            <img t-att-src="image_data_uri(player.photo)" alt="Player Photo" id="loadImage" />
          </div>
        </div>
      </div>

      <!-- Right: attributes -->
      <div class="ch-attrs-panel">
        <div class="ch-attrs-title">Player Attributes</div>
        <t t-if="player.batting_style">
          <div class="ch-attr-row">
            <span class="ch-attr-key">Batting</span>
            <span class="ch-attr-val"><t t-esc="player.batting_style"/></span>
          </div>
        </t>
        <t t-if="player.bowling_style">
          <div class="ch-attr-row">
            <span class="ch-attr-key">Bowling</span>
            <span class="ch-attr-val"><t t-esc="player.bowling_style"/></span>
          </div>
        </t>
        <t t-if="player.blood_group">
          <div class="ch-attr-row">
            <span class="ch-attr-key">Blood Group</span>
            <span class="ch-attr-val" style="color:#FF1744; font-weight:700;"><t t-esc="player.blood_group"/></span>
          </div>
        </t>
        <t t-if="player.contact">
          <div class="ch-attr-row">
            <span class="ch-attr-key">Mobile</span>
            <span class="ch-attr-val"><t t-esc="player.contact"/></span>
          </div>
        </t>
        <t t-if="player.p_category">
          <div class="ch-attr-row">
            <span class="ch-attr-key">Category</span>
            <span class="ch-attr-val"><t t-esc="player.p_category"/></span>
          </div>
        </t>
        <t t-if="player.address">
          <div class="ch-attr-row">
            <span class="ch-attr-key">Location</span>
            <span class="ch-attr-val"><t t-esc="player.address"/></span>
          </div>
        </t>
      </div>

    </div><!-- /ch-stage -->

    <!-- ── NEXT PLAYER ─────────────────────────────────────── -->
    <div class="ch-next-strip">
      <button class="ch-next-btn" onclick="changeImage()">
        Next Player
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 18L14.5 12 6 6V18ZM16 6V18H18V6H16Z"/>
        </svg>
      </button>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM"
      crossorigin="anonymous"
    ></script>

    <script>
      function changeImage() { window.location.reload(); }

      document.addEventListener("keydown", function(event) {
        if (event.code === "Space") { event.preventDefault(); changeImage(); }
      });

      function setPlayerUnsold() {
        var modal = document.getElementById('unsoldConfirmModal');
        modal.style.display = 'flex';
      }

      (function() {
        document.addEventListener('DOMContentLoaded', function() {
          document.getElementById('unsoldModalCancel').addEventListener('click', function() {
            document.getElementById('unsoldConfirmModal').style.display = 'none';
          });
          document.getElementById('unsoldModalConfirm').addEventListener('click', function() {
            document.getElementById('unsoldConfirmModal').style.display = 'none';
            var playerId = parseInt(document.body.getAttribute('data-player-id'));
            if (!playerId) { showUnsoldToast('Error: Player ID not found', true); return; }
            fetch('/web/dataset/call_kw', {
              method: 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify({
                jsonrpc: '2.0', method: 'call',
                params: { model: 'auction.team.player', method: 'action_unsold', args: [[playerId]], kwargs: {} }
              })
            }).then(r => r.json()).then(function(result) {
              if (result.error) showUnsoldToast('Failed to mark player as unsold', true);
              else {
                var secs = (result.result &amp;&amp; result.result.display_seconds > 0) ? result.result.display_seconds : 5;
                showUnsoldStamp(secs, '#DC143C', '#fff');
              }
            }).catch(function() { showUnsoldToast('Failed to mark player as unsold', true); });
          });
        });
      })();

      function showUnsoldToast(message, isError) {
        var toast = document.getElementById('unsoldToast');
        toast.textContent = message;
        toast.style.background = isError ? '#8B0000' : '#1b5e20';
        toast.style.display = 'block';
        setTimeout(function() { toast.style.display = 'none'; }, 3500);
      }

      function showUnsoldStamp(displaySeconds, stampColor, stampText) {
        if (!document.getElementById('_unsoldStampCSS')) {
          var s = document.createElement('style');
          s.id = '_unsoldStampCSS';
          s.textContent = '@keyframes _unsoldDrop{0%{transform:rotate(-22deg) scale(2.4);opacity:0}100%{transform:rotate(-22deg) scale(1);opacity:.92}}@keyframes _unsoldFadeIn{from{opacity:0}to{opacity:1}}';
          document.head.appendChild(s);
        }
        var img = document.getElementById('loadImage');
        var r = img.getBoundingClientRect();
        var ov = document.createElement('div');
        ov.style.cssText = 'position:fixed;z-index:9500;top:'+r.top+'px;left:'+r.left+'px;width:'+r.width+'px;height:'+r.height+'px;background:rgba(0,0,0,0.48);display:flex;align-items:center;justify-content:center;animation:_unsoldFadeIn .35s ease;pointer-events:none;';
        var stamp = document.createElement('div');
        stamp.style.cssText = 'background:'+stampColor+';color:'+stampText+';font-size:clamp(1.8rem,5vw,3.2rem);font-weight:900;letter-spacing:6px;padding:8px 36px;border:5px solid rgba(255,255,255,0.85);border-radius:6px;box-shadow:0 0 0 3px '+stampColor+',0 8px 40px rgba(0,0,0,.5);opacity:0;animation:_unsoldDrop .5s cubic-bezier(.34,1.3,.64,1) .15s forwards;text-shadow:2px 3px 8px rgba(0,0,0,.4);';
        stamp.textContent = 'UNSOLD';
        var barWrap = document.createElement('div');
        barWrap.style.cssText = 'position:absolute;bottom:12px;left:16px;right:16px;';
        var barTrack = document.createElement('div');
        barTrack.style.cssText = 'background:rgba(255,255,255,0.25);border-radius:4px;height:6px;overflow:hidden;';
        var bar = document.createElement('div');
        bar.style.cssText = 'height:100%;width:100%;background:'+stampColor+';border-radius:4px;transition:width '+displaySeconds+'s linear;';
        barTrack.appendChild(bar);
        barWrap.appendChild(barTrack);
        ov.appendChild(stamp);
        ov.appendChild(barWrap);
        document.body.appendChild(ov);
        requestAnimationFrame(function() { requestAnimationFrame(function() { bar.style.width = '0%'; }); });
        setTimeout(function() { if (ov.parentNode) ov.parentNode.removeChild(ov); changeImage(); }, displaySeconds * 1000);
      }

      function openBidSummary() {
        document.getElementById('bidSummaryFrame').src = '/auction/show/team/balance';
        document.getElementById('bidSummaryDrawer').style.right = '0';
        document.getElementById('bidSummaryTabArrow').innerHTML = '&#x2192;';
        document.getElementById('bidSummaryOverlay').style.display = 'block';
        document.body.style.overflow = 'hidden';
      }
      function closeBidSummary() {
        document.getElementById('bidSummaryDrawer').style.right = '-1150px';
        document.getElementById('bidSummaryTabArrow').innerHTML = '&#x2190;';
        document.getElementById('bidSummaryOverlay').style.display = 'none';
        document.body.style.overflow = '';
      }
      function toggleBidSummary() {
        var r = document.getElementById('bidSummaryDrawer').style.right;
        if (r === '0px' || r === '0') { closeBidSummary(); } else { openBidSummary(); }
      }
    </script>
      <!-- Bid Summary Drawer — Cherry Theme -->
      <div id="bidSummaryDrawer" style="position:fixed; top:0; right:-1150px; width:1150px; max-width:96vw; height:100vh; z-index:9800; display:flex; flex-direction:column; background:#1e1e1e; border-left:3px solid #DC143C; box-shadow:-6px 0 40px rgba(220,20,60,0.3); transition:right .35s cubic-bezier(.4,0,.2,1);">
        <!-- Fold/unfold tab -->
        <div onclick="toggleBidSummary()" style="position:absolute; left:-44px; top:50%; transform:translateY(-50%); width:44px; height:130px; background:linear-gradient(180deg,#5a0010,#8B0000); border-radius:8px 0 0 8px; cursor:pointer; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; box-shadow:-4px 2px 14px rgba(220,20,60,0.4); z-index:1; border:1px solid rgba(220,20,60,0.3);">
          <span id="bidSummaryTabArrow" style="color:#f5a0a0; font-size:1.2rem; line-height:1;">&#x2190;</span>
          <span style="color:#f5a0a0; writing-mode:vertical-rl; transform:rotate(180deg); font-size:0.58rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; opacity:0.9;">Summary</span>
        </div>
        <div style="padding:16px 20px; background:linear-gradient(135deg,#0a0a0a,#2a0a10); color:#f5f5f5; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; border-bottom:2px solid #DC143C;">
          <span style="font-size:1.05rem; font-weight:700; letter-spacing:.3px;">&#x1F4CA; Auction Bid Summary</span>
          <button onclick="closeBidSummary()" style="background:rgba(220,20,60,0.15); border:1px solid rgba(220,20,60,0.4); color:#f5f5f5; width:32px; height:32px; border-radius:6px; font-size:1.2rem; cursor:pointer; display:flex; align-items:center; justify-content:center; line-height:1;">&#x2715;</button>
        </div>
