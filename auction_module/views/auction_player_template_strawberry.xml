<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="player_template_strawberry" name="Player Auction – Strawberry">
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1"/>
  <link href="https://fonts.googleapis.com/css2?family=Antonio:wght@400;700&amp;family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&amp;display=swap" rel="stylesheet"/>
  <title>Player Showcase – Strawberry</title>
  <style>
    /* ── Reset ──────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --berry:        #C2185B;
      --berry-dark:   #880E4F;
      --berry-bright: #E91E63;
      --berry-glow:   rgba(194,24,91,0.20);
      --border-berry: rgba(194,24,91,0.22);
      --bg:           #FFF0F5;
      --bg-petal:     #FCE4EC;
      --bg-card:      #ffffff;
      --dark:         #1a0a12;
      --text-mid:     #5a2040;
      --text-dim:     rgba(26,10,18,0.48);
      --divider:      rgba(194,24,91,0.16);
    }
    html, body {
      height: 100vh; overflow: hidden;
      background: var(--bg); color: var(--dark);
      font-family: 'Barlow', sans-serif;
    }

    /* ══════════════════════════════════════════════════════════
       HEADER
    ══════════════════════════════════════════════════════════ */
    .sw-header {
      position: relative; z-index: 20;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px; padding: 0 32px;
      background: var(--bg-card);
      border-bottom: 3px solid var(--berry);
      box-shadow: 0 2px 16px rgba(194,24,91,0.10);
    }
    .sw-header::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, transparent 0%, var(--berry-dark) 20%, var(--berry) 45%, var(--berry-bright) 55%, var(--berry) 80%, transparent 100%);
    }
    .sw-header-brand { flex: 0 0 auto; display: flex; align-items: center; gap: 10px; }
    .sw-brand-logo   { height: 40px; width: auto; object-fit: contain; filter: sepia(1) saturate(8) hue-rotate(300deg) brightness(0.65) drop-shadow(0 1px 4px rgba(194,24,91,.30)); }
    .sw-brand-text   { display: flex; flex-direction: column; }
    .sw-brand-name   { font-family: 'Antonio', sans-serif; font-size: .9rem; letter-spacing: 2.5px; text-transform: uppercase; color: var(--dark); line-height: 1; }
    .sw-brand-sub    { font-size: .58rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--berry); }
    .sw-header-center { flex: 1; display: flex; justify-content: center; align-items: center; gap: 12px; }
    .sw-tourn-logo   { height: 48px; width: auto; object-fit: contain; border-radius: 6px; border: 1.5px solid var(--border-berry); padding: 3px; box-shadow: 0 2px 10px var(--berry-glow); }
    .sw-tourn-info   { display: flex; flex-direction: column; gap: 2px; }
    .sw-tourn-name   { font-family: 'Antonio', sans-serif; font-size: 1.05rem; letter-spacing: 2px; text-transform: uppercase; color: var(--dark); line-height: 1; }
    .sw-tourn-desc   { font-size: .6rem; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-dim); }
    .sw-live-badge   { display: flex; align-items: center; gap: 7px; padding: 5px 14px; border-radius: 28px; background: rgba(194,24,91,.07); border: 1.5px solid rgba(194,24,91,.28); font-family: 'Antonio', sans-serif; font-size: .8rem; letter-spacing: 3px; text-transform: uppercase; color: var(--berry); }
    .sw-live-dot     { width: 8px; height: 8px; border-radius: 50%; background: var(--berry-bright); box-shadow: 0 0 8px var(--berry-bright), 0 0 16px var(--berry-glow); animation: swPulse 1.4s ease-in-out infinite; }
    @keyframes swPulse {
      0%,100% { opacity:1; transform:scale(1); }
      50%      { opacity:.38; transform:scale(.72); }
    }

    /* ══════════════════════════════════════════════════════════
       STAGE — two-panel split
    ══════════════════════════════════════════════════════════ */
    .sw-stage {
      position: relative; z-index: 5;
      height: calc(100vh - 64px);
      display: grid; grid-template-columns: 48% 52%;
      overflow: hidden;
    }

    /* ── PHOTO COLUMN ───────────────────────────────────────── */
    .sw-photo-col {
      position: relative; overflow: hidden;
      background: linear-gradient(160deg, #fce4ec 0%, #f8bbd0 45%, #f48fb1 100%);
    }
    /* Berry accent strip on left edge */
    .sw-photo-col::before {
      content: '';
      position: absolute; top: 0; left: 0; bottom: 0; width: 6px; z-index: 4;
      background: linear-gradient(to bottom, var(--berry-dark), var(--berry-bright), var(--berry-dark));
    }
    /* Soft fade to blend into white info column */
    .sw-photo-col::after {
      content: ''; position: absolute; inset: 0; z-index: 3; pointer-events: none;
      background: linear-gradient(to right, transparent 58%, rgba(255,240,245,.72) 86%, var(--bg-card) 100%);
    }
    /* Serial watermark */
    .sw-photo-wm {
      position: absolute; z-index: 2; bottom: -16px; right: 8px;
      font-family: 'Antonio', sans-serif; font-size: 24rem; font-weight: 700; line-height: .85;
      color: rgba(194,24,91,.07); pointer-events: none; user-select: none; letter-spacing: -12px;
    }
    .sw-photo {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: contain; object-position: center bottom; z-index: 1;
    }
    /* Corner bracket ornaments */
    .sw-corner { position: absolute; z-index: 5; width: 36px; height: 36px; }
    .sw-corner-tl { top:14px; left:20px; border-top:3px solid var(--berry); border-left:3px solid var(--berry); box-shadow:-2px -2px 10px rgba(194,24,91,.18); }
    .sw-corner-tr { top:14px; right:14px; border-top:3px solid var(--berry); border-right:3px solid var(--berry); box-shadow:2px -2px 10px rgba(194,24,91,.18); }
    .sw-corner-bl { bottom:14px; left:20px; border-bottom:3px solid var(--berry); border-left:3px solid var(--berry); box-shadow:-2px 2px 10px rgba(194,24,91,.18); }
    .sw-corner-br { bottom:14px; right:14px; border-bottom:3px solid var(--berry); border-right:3px solid var(--berry); box-shadow:2px 2px 10px rgba(194,24,91,.18); }

    /* ── INFO COLUMN ─────────────────────────────────────────── */
    .sw-info-col {
      display: flex; flex-direction: column;
      background: var(--bg-card);
      border-left: 1px solid rgba(194,24,91,.10);
      overflow: hidden;
    }

    /* ── IDENTITY CARD ──────────────────────────────────────── */
    .sw-identity {
      flex-shrink: 0;
      display: flex; align-items: center; gap: 20px;
      padding: 20px 28px 18px;
      background: linear-gradient(135deg, #fce4ec 0%, #fff0f5 55%, #fce4ec 100%);
      border-bottom: 2px solid rgba(194,24,91,.15);
      box-shadow: 0 2px 12px rgba(194,24,91,.07);
    }
    .sw-serial-block { flex-shrink: 0; display: flex; flex-direction: column; align-items: center; line-height: 1; }
    .sw-serial-hash  { font-family: 'Antonio', sans-serif; font-size: 1.1rem; color: rgba(194,24,91,.45); }
    .sw-serial-num   { font-family: 'Antonio', sans-serif; font-size: 3.8rem; line-height: .88; color: var(--berry); filter: drop-shadow(0 2px 6px rgba(194,24,91,.22)); }
    .sw-id-vsep      { flex-shrink: 0; width: 2px; height: 58px; background: linear-gradient(to bottom, transparent, var(--berry), transparent); margin: 0 4px; }
    .sw-id-info      { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 7px; }
    .sw-player-name  { font-family: 'Antonio', sans-serif; font-size: 1.95rem; text-transform: uppercase; letter-spacing: 2.5px; color: var(--dark); line-height: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sw-badges       { display: flex; align-items: center; flex-wrap: wrap; gap: 7px; }
    .sw-role-tag     { font-size: .68rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--berry); background: rgba(194,24,91,.09); border: 1.5px solid rgba(194,24,91,.26); border-radius: 20px; padding: 3px 11px; }
    .sw-tier-badge   { font-size: .68rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; border-radius: 20px; padding: 3px 11px; }

    /* ── STATS SECTION ──────────────────────────────────────── */
    .sw-stats-wrap {
      flex: 1; overflow-y: auto; padding: 18px 28px 12px;
      scrollbar-width: thin; scrollbar-color: rgba(194,24,91,.25) transparent;
    }
    .sw-stats-title {
      font-family: 'Antonio', sans-serif; font-size: 1rem; letter-spacing: 4px;
      text-transform: uppercase; color: var(--berry);
      border-bottom: 2px solid rgba(194,24,91,.14); padding-bottom: 8px; margin-bottom: 12px;
    }
    .sw-stat-row {
      display: flex; align-items: stretch; border-radius: 8px; overflow: hidden; margin-bottom: 8px;
      border: 1px solid rgba(194,24,91,.13); transition: border-color .2s, box-shadow .2s;
    }
    .sw-stat-row:hover { border-color: var(--berry); box-shadow: 0 2px 12px rgba(194,24,91,.09); }
    .sw-stat-key { flex: 0 0 114px; padding: 10px 14px; font-size: .68rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #fff; background: var(--berry); display: flex; align-items: center; }
    .sw-stat-val { flex: 1; padding: 10px 16px; font-size: .9rem; font-weight: 500; color: var(--dark); display: flex; align-items: center; background: var(--bg-card); }
    .sw-stat-val.blood { color: #c62828; font-weight: 700; }
    .sw-base-price {
      display: flex; align-items: center; justify-content: space-between;
      margin: 8px 0 0; padding: 12px 18px;
      background: linear-gradient(135deg, rgba(194,24,91,.07) 0%, rgba(233,30,99,.10) 100%);
      border: 1.5px solid rgba(194,24,91,.20); border-radius: 8px;
    }
    .sw-base-label { font-family: 'Antonio', sans-serif; font-size: .85rem; letter-spacing: 2.5px; text-transform: uppercase; color: var(--berry); }
    .sw-base-val   { font-family: 'Antonio', sans-serif; font-size: 1.5rem; letter-spacing: 1px; color: var(--berry-dark); }

    /* ── ACTIONS BAR ────────────────────────────────────────── */
    .sw-actions {
      flex-shrink: 0; display: flex; align-items: center; gap: 14px;
      height: 76px; padding: 0 28px;
      background: linear-gradient(90deg, #fff0f5 0%, #fce4ec 50%, #fff0f5 100%);
      border-top: 1.5px solid rgba(194,24,91,.16);
      box-shadow: inset 0 1px 0 rgba(194,24,91,.09), 0 -2px 12px rgba(194,24,91,.05);
    }
    .sw-btn {
      flex: 1; height: 48px;
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      border: none; cursor: pointer;
      font-family: 'Antonio', sans-serif; font-size: .88rem; letter-spacing: 2px; text-transform: uppercase;
      border-radius: 50px; transition: all .22s ease;
    }
    .sw-btn-unsold { background: rgba(194,24,91,.06); border: 1.5px solid rgba(194,24,91,.33); color: var(--berry); }
    .sw-btn-unsold:hover { background: rgba(194,24,91,.12); border-color: var(--berry); box-shadow: 0 0 16px rgba(194,24,91,.16); transform: translateY(-1px); }
    .sw-btn-unsold:active { transform: translateY(0); }
    .sw-btn-sell { background: linear-gradient(135deg, var(--berry-dark) 0%, var(--berry) 50%, var(--berry-bright) 100%); color: #fff; border: 1.5px solid rgba(233,30,99,.30); box-shadow: 0 4px 18px rgba(194,24,91,.30), inset 0 1px 0 rgba(255,255,255,.18); }
    .sw-btn-sell:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(194,24,91,.46); filter: brightness(1.06); }
    .sw-btn-sell:active:not(:disabled) { transform: translateY(0); filter: brightness(.96); }
    .sw-btn-sell:disabled { opacity: .38; cursor: not-allowed; }
    .sw-btn-next { background: rgba(194,24,91,.06); border: 1.5px solid rgba(194,24,91,.28); color: var(--text-mid); }
    .sw-btn-next:hover { background: rgba(194,24,91,.13); border-color: var(--berry); box-shadow: 0 0 14px rgba(194,24,91,.14); transform: translateY(-1px); color: var(--berry); }
    .sw-btn-next:active { transform: translateY(0); }
  </style>
</head>

<body t-att-data-player-id="player.id">

  <!-- HEADER ──────────────────────────────────────────────────── -->
  <header class="sw-header">
    <div class="sw-header-brand">
      <img src="/auction_module/static/src/assets/images/logo.svg" alt="Auction Champ" class="sw-brand-logo"/>
      <div class="sw-brand-text">
        <div class="sw-brand-name">Auction Champ</div>
        <div class="sw-brand-sub">Strawberry Edition</div>
      </div>
    </div>
    <div class="sw-header-center">
      <t t-if="tournament and tournament.logo">
        <img class="sw-tourn-logo" t-att-src="image_data_uri(tournament.logo)" alt="Tournament Logo"/>
      </t>
      <t t-if="tournament">
        <div class="sw-tourn-info">
          <div class="sw-tourn-name"><t t-esc="tournament.name"/></div>
          <t t-if="tournament.description">
            <div class="sw-tourn-desc"><t t-esc="tournament.description"/></div>
          </t>
        </div>
      </t>
    </div>
    <div class="sw-live-badge">
      <span class="sw-live-dot"></span>
      LIVE
    </div>
  </header>

  <!-- STAGE (data-player-zone) ──────────────────────────────── -->
  <div class="sw-stage" data-player-zone="">

    <!-- Photo column -->
    <div class="sw-photo-col">
      <div class="sw-photo-wm"><t t-esc="player.sl_no or ''"/></div>
      <img class="sw-photo" id="loadImage" t-att-src="image_data_uri(player.photo)" alt="Player Photo"/>
      <div class="sw-corner sw-corner-tl"></div>
      <div class="sw-corner sw-corner-tr"></div>
      <div class="sw-corner sw-corner-bl"></div>
      <div class="sw-corner sw-corner-br"></div>
    </div>

    <!-- Info column -->
    <div class="sw-info-col">

      <!-- Identity card -->
      <div class="sw-identity">
        <div class="sw-serial-block">
          <span class="sw-serial-hash">#</span>
          <span class="sw-serial-num"><t t-esc="'%02d' % (player.sl_no or 0)"/></span>
        </div>
        <div class="sw-id-vsep"></div>
        <div class="sw-id-info">
          <div class="sw-player-name" data-sm-name=""><t t-esc="player.name.upper() if player.name else ''"/></div>
          <div class="sw-badges">
            <t t-if="player.role">
              <span class="sw-role-tag" data-sm-role=""><t t-esc="player.role"/></span>
            </t>
            <t t-if="player.tier_id">
              <span class="sw-tier-badge"
                    t-att-style="'background-color: ' + (player.tier_id.color or '#C2185B') + '18; color: ' + (player.tier_id.color or '#C2185B') + '; border: 1.5px solid ' + (player.tier_id.color or '#C2185B') + '50;'">
                <t t-esc="player.tier_id.name"/>
              </span>
            </t>
          </div>
        </div>
      </div>

      <!-- Stats section -->
      <div class="sw-stats-wrap">
        <div class="sw-stats-title">Player Profile</div>
        <t t-if="player.batting_style">
          <div class="sw-stat-row">
            <span class="sw-stat-key">Batting</span>
            <span class="sw-stat-val"><t t-esc="player.batting_style"/></span>
          </div>
        </t>
        <t t-if="player.bowling_style">
          <div class="sw-stat-row">
            <span class="sw-stat-key">Bowling</span>
            <span class="sw-stat-val"><t t-esc="player.bowling_style"/></span>
          </div>
        </t>
        <t t-if="player.blood_group">
          <div class="sw-stat-row">
            <span class="sw-stat-key">Blood</span>
            <span class="sw-stat-val blood"><t t-esc="player.blood_group"/></span>
          </div>
        </t>
        <t t-if="player.p_category">
          <div class="sw-stat-row">
            <span class="sw-stat-key">Category</span>
            <span class="sw-stat-val"><t t-esc="player.p_category"/></span>
          </div>
        </t>
        <t t-if="player.contact">
          <div class="sw-stat-row">
            <span class="sw-stat-key">Mobile</span>
            <span class="sw-stat-val"><t t-esc="player.contact"/></span>
          </div>
        </t>
        <t t-if="player.address">
          <div class="sw-stat-row">
            <span class="sw-stat-key">Location</span>
            <span class="sw-stat-val"><t t-esc="player.address"/></span>
          </div>
        </t>
        <t t-if="player.effective_base_price">
          <div class="sw-base-price">
            <span class="sw-base-label">Base Price</span>
            <span class="sw-base-val"><t t-esc="'{:,}'.format(int(player.effective_base_price or 0))"/> pts</span>
          </div>
        </t>
      </div><!-- /sw-stats-wrap -->

      <!-- Actions bar -->
      <div class="sw-actions">
        <button class="sw-btn sw-btn-unsold" onclick="setPlayerUnsold()">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
          Set Unsold
        </button>
        <button class="sw-btn sw-btn-sell" onclick="openSellModal()">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
          Sell to Team
        </button>
        <button class="sw-btn sw-btn-next" onclick="changeImage()">
          Next Player
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18L14.5 12 6 6V18ZM16 6V18H18V6H16Z"/></svg>
        </button>
      </div>

    </div><!-- /sw-info-col -->

  </div><!-- /sw-stage (data-player-zone) -->

  <!-- JS ─────────────────────────────────────────────────────── -->
  <script>
    async function changeImage() {
      var toast = document.getElementById('ac-next-toast');
      var bar   = document.getElementById('ac-next-bar');
      if (toast) {
        toast.style.display  = 'flex';
        toast.style.opacity  = '1';
        bar.style.transition = 'none';
        bar.style.width      = '0%';
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            bar.style.transition = 'width 1.2s cubic-bezier(.4,0,.2,1)';
            bar.style.width      = '80%';
          });
        });
      }
      try {
        var resp = await fetch(window.location.href, {cache: 'no-store'});
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        var html = await resp.text();
        var parser = new DOMParser();
        var newDoc = parser.parseFromString(html, 'text/html');
        var pid = newDoc.body.getAttribute('data-player-id');
        if (pid) document.body.setAttribute('data-player-id', pid);
        var zone    = document.querySelector('[data-player-zone]');
        var newZone = newDoc.querySelector('[data-player-zone]');
        if (zone &amp;&amp; newZone) { zone.innerHTML = newZone.innerHTML; }
        if (toast) {
          bar.style.transition = 'width 0.15s ease';
          bar.style.width      = '100%';
          setTimeout(function() {
            toast.style.opacity = '0';
            setTimeout(function() { toast.style.display = 'none'; }, 400);
          }, 250);
        }
      } catch(e) {
        console.error('Next player load failed:', e);
        window.location.reload();
      }
    }

    document.addEventListener('keydown', function(event) {
      if (event.code === 'Space') { event.preventDefault(); changeImage(); }
    });

    function setPlayerUnsold() {
      document.getElementById('swUnsoldModal').style.display = 'flex';
    }

    (function() {
      document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('swUnsoldCancel').addEventListener('click', function() {
          document.getElementById('swUnsoldModal').style.display = 'none';
        });
        document.getElementById('swUnsoldConfirm').addEventListener('click', function() {
          document.getElementById('swUnsoldModal').style.display = 'none';
          var playerId = parseInt(document.body.getAttribute('data-player-id'));
          if (!playerId) { showUnsoldToast('Error: Player ID not found', true); return; }
          fetch('/web/dataset/call_kw', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
              jsonrpc: '2.0', method: 'call',
              params: { model: 'auction.team.player', method: 'action_unsold', args: [[playerId]], kwargs: {} }
            })
          }).then(r => r.json()).then(function(result) {
            if (result.error) showUnsoldToast('Failed to mark player as unsold', true);
            else {
              var secs = (result.result &amp;&amp; result.result.display_seconds > 0) ? result.result.display_seconds : 5;
              showUnsoldStamp(secs, '#C2185B', '#fff');
            }
          }).catch(function() { showUnsoldToast('Failed to mark player as unsold', true); });
        });
      });
    })();

    function showUnsoldToast(message, isError) {
      var toast = document.getElementById('swToast');
      toast.textContent = message;
      toast.style.background = isError ? '#8B0000' : '#1b5e20';
      toast.style.display = 'block';
      setTimeout(function() { toast.style.display = 'none'; }, 3500);
    }

    function showUnsoldStamp(displaySeconds, stampColor, stampText) {
      if (!document.getElementById('_unsoldStampCSS')) {
        var s = document.createElement('style');
        s.id = '_unsoldStampCSS';
        s.textContent = '@keyframes _unsoldDrop{0%{transform:rotate(-22deg) scale(2.4);opacity:0}100%{transform:rotate(-22deg) scale(1);opacity:.92}}@keyframes _unsoldFadeIn{from{opacity:0}to{opacity:1}}';
        document.head.appendChild(s);
      }
      var img = document.getElementById('loadImage');
      var r = img.getBoundingClientRect();
      var ov = document.createElement('div');
      ov.style.cssText = 'position:fixed;z-index:9500;top:'+r.top+'px;left:'+r.left+'px;width:'+r.width+'px;height:'+r.height+'px;background:rgba(0,0,0,0.48);display:flex;align-items:center;justify-content:center;animation:_unsoldFadeIn .35s ease;pointer-events:none;';
      var stamp = document.createElement('div');
      stamp.style.cssText = 'background:'+stampColor+';color:'+stampText+';font-size:clamp(1.8rem,5vw,3.2rem);font-weight:900;letter-spacing:6px;padding:8px 36px;border:5px solid rgba(255,255,255,0.85);border-radius:6px;box-shadow:0 0 0 3px '+stampColor+',0 8px 40px rgba(0,0,0,.5);opacity:0;animation:_unsoldDrop .5s cubic-bezier(.34,1.3,.64,1) .15s forwards;text-shadow:2px 3px 8px rgba(0,0,0,.4);';
      stamp.textContent = 'UNSOLD';
      var barWrap = document.createElement('div');
      barWrap.style.cssText = 'position:absolute;bottom:12px;left:16px;right:16px;';
      var barTrack = document.createElement('div');
      barTrack.style.cssText = 'background:rgba(255,255,255,0.25);border-radius:4px;height:6px;overflow:hidden;';
      var bar = document.createElement('div');
      bar.style.cssText = 'height:100%;width:100%;background:'+stampColor+';border-radius:4px;transition:width '+displaySeconds+'s linear;';
      barTrack.appendChild(bar);
      barWrap.appendChild(barTrack);
      ov.appendChild(stamp);
      ov.appendChild(barWrap);
      document.body.appendChild(ov);
      requestAnimationFrame(function() { requestAnimationFrame(function() { bar.style.width = '0%'; }); });
      setTimeout(function() { if (ov.parentNode) ov.parentNode.removeChild(ov); changeImage(); }, displaySeconds * 1000);
    }

    function openBidSummary() {
      document.getElementById('swBidDrawer').style.right = '0';
      document.getElementById('swBidArrow').innerHTML = '&#x2192;';
      document.getElementById('swBidOverlay').style.display = 'block';
      document.getElementById('swBidFrame').src = '/auction/show/team/balance';
      document.body.style.overflow = 'hidden';
    }
    function closeBidSummary() {
      document.getElementById('swBidDrawer').style.right = '-1150px';
      document.getElementById('swBidArrow').innerHTML = '&#x2190;';
      document.getElementById('swBidOverlay').style.display = 'none';
      document.body.style.overflow = '';
    }
    function toggleBidSummary() {
      var r = document.getElementById('swBidDrawer').style.right;
      if (r === '0px' || r === '0') { closeBidSummary(); } else { openBidSummary(); }
    }
    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(function(e) { console.warn(e); });
      } else {
        document.exitFullscreen();
      }
    }
    document.addEventListener('fullscreenchange', function() {
      var btn = document.getElementById('fs-btn');
      if (!btn) return;
      if (document.fullscreenElement) {
        btn.title = 'Exit Fullscreen';
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/></svg>';
      } else {
        btn.title = 'Enter Fullscreen';
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>';
      }
    });
  </script>

  <!-- Bid Summary Drawer -->
  <div id="swBidDrawer" style="position:fixed;top:0;right:-1150px;width:1150px;max-width:96vw;height:100vh;z-index:9800;display:flex;flex-direction:column;background:#fff;border-left:3px solid #C2185B;box-shadow:-6px 0 32px rgba(194,24,91,0.18);transition:right .35s cubic-bezier(.4,0,.2,1);">
    <div onclick="toggleBidSummary()" style="position:absolute;left:-44px;top:50%;transform:translateY(-50%);width:44px;height:130px;background:linear-gradient(180deg,#880E4F,#C2185B);border-radius:8px 0 0 8px;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;box-shadow:-4px 2px 14px rgba(194,24,91,0.30);">
      <span id="swBidArrow" style="color:#fff;font-size:1.2rem;line-height:1;">&#x2190;</span>
      <span style="color:#fff;writing-mode:vertical-rl;transform:rotate(180deg);font-size:0.58rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;opacity:0.9;">Summary</span>
    </div>
    <div style="padding:16px 20px;background:#C2185B;color:#fff;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;border-bottom:2px solid #880E4F;">
      <span style="font-family:'Antonio',sans-serif;font-size:1.05rem;letter-spacing:2px;">&#x1F4CA; Auction Bid Summary</span>
      <button onclick="closeBidSummary()" style="background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.28);color:#fff;width:32px;height:32px;border-radius:6px;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">&#x2715;</button>
    </div>
    <iframe id="swBidFrame" style="flex:1;border:none;width:100%;" title="Bid Summary"></iframe>
  </div>
  <div id="swBidOverlay" onclick="closeBidSummary()" style="display:none;position:fixed;inset:0;z-index:9700;background:rgba(26,10,18,0.48);"></div>

  <!-- Unsold Confirm Modal -->
  <div id="swUnsoldModal" style="display:none;position:fixed;inset:0;z-index:10000;background:rgba(26,10,18,0.68);align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:16px;padding:36px 28px 28px;max-width:400px;width:92%;box-shadow:0 12px 48px rgba(194,24,91,0.22);border-top:3px solid #C2185B;text-align:center;font-family:'Barlow',sans-serif;">
      <div style="width:56px;height:56px;border-radius:50%;background:#fff0f5;border:2px solid #C2185B;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.6rem;">⚠️</div>
      <h5 style="margin:0 0 10px;font-family:'Antonio',sans-serif;font-size:1.3rem;letter-spacing:2px;color:#1a0a12;">Set Player as Unsold?</h5>
      <p style="color:rgba(26,10,18,0.55);margin:0 0 26px;font-size:0.9rem;line-height:1.55;">This will mark the player as Unsold. You can bring them back to Auction later.</p>
      <div style="display:flex;gap:12px;justify-content:center;">
        <button id="swUnsoldCancel" style="padding:10px 28px;border-radius:8px;border:1.5px solid rgba(194,24,91,0.28);background:rgba(194,24,91,0.06);color:#C2185B;font-size:0.9rem;cursor:pointer;font-weight:600;">Cancel</button>
        <button id="swUnsoldConfirm" style="padding:10px 28px;border-radius:8px;border:none;background:#C2185B;color:#fff;font-size:0.9rem;font-weight:700;cursor:pointer;">Confirm</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="swToast" style="display:none;position:fixed;bottom:28px;left:50%;transform:translateX(-50%);z-index:10001;color:#fff;padding:12px 28px;border-radius:8px;font-size:0.9rem;font-weight:600;box-shadow:0 4px 16px rgba(0,0,0,.4);"></div>

  <!-- Next-player progress toast -->
  <div id="ac-next-toast" style="display:none;opacity:0;position:fixed;bottom:28px;left:50%;transform:translateX(-50%);z-index:10002;min-width:220px;max-width:320px;background:#fff;border-radius:14px;box-shadow:0 8px 32px rgba(194,24,91,.22);overflow:hidden;flex-direction:column;transition:opacity .4s;border:1.5px solid rgba(194,24,91,.25);">
    <div style="padding:12px 20px 10px;display:flex;align-items:center;gap:10px;">
      <span style="font-size:1.1rem;">⚡</span>
      <span style="color:#1a0a12;font-size:0.85rem;font-weight:600;letter-spacing:.5px;">Loading Next Player…</span>
    </div>
    <div style="height:3px;background:rgba(194,24,91,.14);">
      <div id="ac-next-bar" style="height:100%;width:0%;background:#C2185B;border-radius:2px;transition:width .3s;"></div>
    </div>
  </div>

  <!-- Fullscreen button -->
  <button id="fs-btn" onclick="toggleFullscreen()" title="Enter Fullscreen" style="position:fixed;top:14px;right:14px;z-index:9999;width:38px;height:38px;border-radius:8px;background:rgba(194,24,91,0.07);border:1.5px solid rgba(194,24,91,0.33);color:#C2185B;cursor:pointer;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);padding:0;transition:background .2s,box-shadow .2s;" onmouseover="this.style.boxShadow='0 0 12px rgba(194,24,91,0.28)'" onmouseout="this.style.boxShadow='none'">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
  </button>

  <t t-call="auction_module.player_sell_modal"/>
</body>
