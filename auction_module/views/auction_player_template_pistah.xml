<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="player_template_pistah" name="Player Auction – Pistah">
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
        crossorigin="anonymous"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1"/>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&amp;family=Exo+2:wght@300;400;500;600;700;800&amp;display=swap"
        rel="stylesheet"/>
  <title>Player Showcase – Pistah</title>
  <style>
    /* ── Reset ───────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --pistah:        #6BBF4E;
      --pistah-dark:   #2E7D32;
      --pistah-bright: #A8E063;
      --pistah-glow:   rgba(107,191,78,0.35);
      --pistah-border: rgba(107,191,78,0.45);
      --slate:         #778899;
      --slate-light:   #B0BEC5;
      --slate-dark:    #546E7A;
      --bg:            #060e08;
      --bg-surface:    #0b1a0e;
      --bg-panel:      #0d1f11;
      --bg-card:       #111f14;
      --text-main:     #e8f5e9;
      --text-dim:      rgba(232,245,233,0.55);
      --divider:       rgba(107,191,78,0.30);
    }

    html, body {
      height: 100vh;
      background: var(--bg);
      color: var(--text-main);
      font-family: 'Exo 2', sans-serif;
      overflow: hidden;
    }

    /* ── Ambient background layer ──────────────────────────── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 50%, rgba(107,191,78,.07) 0%, transparent 65%),
        radial-gradient(ellipse 50% 80% at 80% 20%, rgba(46,125,50,.10) 0%, transparent 60%),
        linear-gradient(180deg, #060e08 0%, #081208 100%);
      pointer-events: none; z-index: 0;
    }

    /* ── TOP HEADER BAR ──────────────────────────────────────── */
    .pt-header {
      position: relative; z-index: 20;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px;
      height: 72px;
      background: linear-gradient(90deg, #030a04 0%, #081508 40%, #0a1c0c 70%, #030a04 100%);
      border-bottom: 2px solid var(--pistah-border);
      box-shadow: 0 2px 24px rgba(107,191,78,.20), inset 0 -1px 0 rgba(107,191,78,.15);
    }
    /* top green stripe */
    .pt-header::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg,
        transparent 0%,
        var(--pistah-dark) 15%,
        var(--pistah) 40%,
        var(--pistah-bright) 50%,
        var(--pistah) 60%,
        var(--pistah-dark) 85%,
        transparent 100%);
      box-shadow: 0 0 12px rgba(107,191,78,.6);
    }

    /* ── LEFT: product brand ──────────────────────────────── */
    .pt-header-brand {
      display: flex; align-items: center; gap: 12px;
      flex: 0 0 auto;
    }
    .pt-header-brand img {
      height: 46px; width: auto;
      object-fit: contain;
      filter: drop-shadow(0 0 8px rgba(107,191,78,.5));
    }
    .pt-header-brand-text { display: flex; flex-direction: column; }
    .pt-header-brand-text .pt-brand-name {
      font-family: 'Orbitron', sans-serif;
      font-size: .9rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      color: var(--text-main); line-height: 1;
    }
    .pt-header-brand-text .pt-brand-season {
      font-size: .6rem; font-weight: 500;
      letter-spacing: 2px; color: var(--pistah); opacity: .85;
    }

    /* ── CENTER: tournament identity ─────────────────────── */
    .pt-header-center {
      flex: 1; display: flex; justify-content: center; align-items: center; gap: 14px;
    }
    .pt-tourn-logo-center {
      height: 58px; width: auto; flex-shrink: 0;
      object-fit: contain;
      border-radius: 10px;
      border: 2px solid var(--pistah-border);
      box-shadow: 0 0 18px var(--pistah-glow), 0 0 0 1px rgba(107,191,78,.12);
      padding: 4px;
      background: rgba(107,191,78,.07);
    }
    .pt-tourn-info-center { display: flex; flex-direction: column; gap: 2px; }
    .pt-tourn-name-center {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.05rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      color: var(--text-main); line-height: 1;
      text-shadow: 0 0 14px rgba(107,191,78,.3);
    }
    .pt-tourn-desc-center {
      font-size: .65rem; font-weight: 500;
      letter-spacing: 1.5px; color: var(--slate-light); opacity: .8;
    }

    /* ── RIGHT: LIVE indicator only ──────────────────────── */
    .pt-header-right-wrap {
      flex: 0 0 auto; display: flex; align-items: center;
    }
    .pt-live-badge {
      display: flex; align-items: center; gap: 8px;
      padding: 5px 14px; border-radius: 30px;
      background: rgba(107,191,78,.10);
      border: 1px solid rgba(107,191,78,.35);
      font-family: 'Orbitron', sans-serif;
      font-size: .7rem; font-weight: 700;
      letter-spacing: 3px; text-transform: uppercase;
      color: var(--pistah-bright);
    }
    .pt-live-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--pistah);
      box-shadow: 0 0 8px var(--pistah), 0 0 16px var(--pistah-glow);
      animation: ptPulse 1.4s ease-in-out infinite;
    }
    @keyframes ptPulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50%      { opacity: .5; transform: scale(.8); }
    }

    /* ── MAIN SPLIT STAGE ────────────────────────────────────── */
    .pt-stage {
      position: relative; z-index: 5;
      display: grid;
      grid-template-columns: 48% 52%;
      height: calc(100vh - 72px - 52px); /* subtract header + footer */
    }

    /* Right column wrapper — flex column so buttons sit BELOW the panel */
    .pt-right-col {
      display: flex; flex-direction: column;
      overflow: hidden; /* clips the right col as a whole */
    }

    /* ── LEFT: PHOTO PANEL ───────────────────────────────────── */
    .pt-photo-panel {
      position: relative;
      overflow: hidden;
      background: #060e08;
    }

    /* Blurred backdrop — same photo, blurred + dimmed to fill empty space */
    .pt-photo-blur {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
      filter: blur(18px) brightness(0.25) saturate(0.6);
      transform: scale(1.08); /* prevent blur edge halos */
      z-index: 1;
      pointer-events: none;
    }

    /* Dark vignette overlay on photo */
    .pt-photo-panel::after {
      content: '';
      position: absolute; inset: 0;
      background:
        linear-gradient(to right, transparent 55%, rgba(6,14,8,.95) 100%),
        linear-gradient(to bottom, rgba(6,14,8,.5) 0%, transparent 20%, transparent 70%, rgba(6,14,8,.8) 100%);
      z-index: 3; pointer-events: none;
    }

    /* Diagonal green slash accent */
    .pt-diagonal-slash {
      position: absolute;
      right: -2px; top: 0; bottom: 0;
      width: 80px;
      background: linear-gradient(135deg,
        transparent 0%,
        transparent 45%,
        rgba(107,191,78,.12) 45%,
        rgba(107,191,78,.08) 55%,
        transparent 55%,
        transparent 100%);
      z-index: 4; pointer-events: none;
    }

    /* Serial number watermark */
    .pt-serial-watermark {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-family: 'Orbitron', sans-serif;
      font-size: 22rem; font-weight: 900; line-height: 1;
      color: rgba(107,191,78,.04);
      white-space: nowrap;
      pointer-events: none; z-index: 5;
      user-select: none;
    }

    .pt-photo-panel img.pt-photo {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: contain;
      object-position: center bottom;
      z-index: 2;
    }

    /* Player name overlay at bottom of photo */
    .pt-photo-name-block {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 32px 32px 24px;
      z-index: 6;
      background: linear-gradient(to top,
        rgba(6,14,8,.92) 0%,
        rgba(6,14,8,.70) 40%,
        transparent 100%);
    }
    .pt-player-name {
      font-family: 'Orbitron', sans-serif;
      font-size: 2.2rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 3px;
      color: #fff; line-height: 1.05;
      text-shadow: 0 2px 20px rgba(0,0,0,.8);
    }
    .pt-player-role {
      font-size: .95rem; font-weight: 700;
      letter-spacing: 4px; text-transform: uppercase;
      color: var(--pistah-bright);
      margin-top: 5px;
    }
    .pt-photo-serial {
      font-family: 'Orbitron', sans-serif;
      font-size: .8rem; font-weight: 600;
      letter-spacing: 3px; color: var(--pistah);
      opacity: .85; margin-bottom: 6px;
    }

    /* ── RIGHT: INFO PANEL ───────────────────────────────────── */
    .pt-info-panel {
      position: relative;
      flex: 1; /* fills remaining height in pt-right-col */
      display: flex; flex-direction: column;
      padding: 20px 28px 16px 32px;
      background: linear-gradient(160deg, #0a1a0c 0%, #0d1f11 50%, #0b1a0e 100%);
      border-left: 1px solid rgba(107,191,78,.18);
      overflow: hidden;
    }

    /* Background grid pattern */
    .pt-info-panel::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        repeating-linear-gradient(0deg,
          rgba(107,191,78,.02) 0px, rgba(107,191,78,.02) 1px,
          transparent 1px, transparent 60px),
        repeating-linear-gradient(90deg,
          rgba(107,191,78,.02) 0px, rgba(107,191,78,.02) 1px,
          transparent 1px, transparent 60px);
      pointer-events: none;
    }

    /* Accent corner glow */
    .pt-info-panel::after {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 300px; height: 300px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(107,191,78,.08) 0%, transparent 65%);
      pointer-events: none;
    }

    /* Tier badge */
    .pt-tier-badge {
      position: relative; z-index: 2;
      display: inline-flex; align-items: center; gap: 7px;
      padding: 4px 14px; border-radius: 4px;
      font-family: 'Orbitron', sans-serif;
      font-size: .7rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      width: fit-content;
      margin-bottom: 10px;
      border: 1px solid rgba(107,191,78,.4);
      background: rgba(107,191,78,.08);
      color: var(--pistah-bright);
    }
    .pt-tier-badge::before {
      content: '';
      width: 7px; height: 7px; border-radius: 2px;
      background: var(--pistah);
      box-shadow: 0 0 5px var(--pistah-glow);
    }

    /* Divider line */
    .pt-green-rule {
      position: relative; z-index: 2;
      height: 2px; margin-bottom: 14px;
      background: linear-gradient(90deg,
        var(--pistah) 0%,
        var(--pistah-bright) 30%,
        rgba(107,191,78,.2) 70%,
        transparent 100%);
      border-radius: 1px;
      box-shadow: 0 0 6px rgba(107,191,78,.35);
    }

    /* Stats grid – compact 2-column */
    .pt-stats-grid {
      position: relative; z-index: 2;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 7px;
      margin-bottom: 14px;
    }

    .pt-stat-tile {
      padding: 8px 12px;
      background: rgba(107,191,78,.04);
      border: 1px solid rgba(107,191,78,.13);
      border-radius: 6px;
      display: flex; flex-direction: column; justify-content: center;
      transition: border-color .2s;
    }
    .pt-stat-tile:hover { border-color: rgba(107,191,78,.30); }

    .pt-stat-val {
      font-family: 'Exo 2', sans-serif;
      font-size: .92rem; font-weight: 700;
      color: var(--text-main); line-height: 1.2;
    }
    .pt-stat-key {
      font-size: .6rem; font-weight: 600;
      letter-spacing: 2px; text-transform: uppercase;
      color: var(--slate-light); opacity: .65;
      margin-top: 2px;
    }

    /* ── ACTION BUTTONS ─────────────────────────────────────── */
    .pt-actions {
      flex-shrink: 0; /* never compress */
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      padding: 10px 28px 8px 32px;
      background: linear-gradient(160deg, #0a1a0c 0%, #0d1f11 100%);
      border-left: 1px solid rgba(107,191,78,.18);
    }

    .pt-btn {
      display: flex; align-items: center; justify-content: center; gap: 7px;
      padding: 11px 10px;
      border-radius: 7px;
      font-family: 'Orbitron', sans-serif;
      font-size: .72rem; font-weight: 700;
      letter-spacing: 1.5px; text-transform: uppercase;
      cursor: pointer; transition: all .2s ease;
      white-space: nowrap;
    }

    .pt-btn-unsold {
      background: transparent;
      border: 1.5px solid rgba(107,191,78,.40);
      color: var(--pistah);
    }
    .pt-btn-unsold:hover {
      border-color: var(--pistah);
      background: rgba(107,191,78,.10);
      box-shadow: 0 0 14px rgba(107,191,78,.20);
    }

    .pt-btn-sell {
      background: linear-gradient(135deg, var(--pistah-dark) 0%, #2e7d32 50%, #388e3c 100%);
      border: 1px solid rgba(107,191,78,.55);
      color: #fff;
      box-shadow: 0 3px 16px rgba(107,191,78,.30);
    }
    .pt-btn-sell:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 22px rgba(107,191,78,.50);
    }

    /* Next player button */
    .pt-next-strip {
      flex-shrink: 0;
      padding: 8px 28px 12px 32px;
      background: linear-gradient(160deg, #0a1a0c 0%, #0d1f11 100%);
      border-left: 1px solid rgba(107,191,78,.18);
      border-top: 1px solid rgba(107,191,78,.10);
    }

    /* ── Spacer: pushes buttons to bottom via margin-top:auto ─ */
    /* (no explicit spacer div needed) */

    /* ── Base-price strip ────────────────────────────────── */
    .pt-base-strip {
      position: relative; z-index: 2;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(107,191,78,.05);
      border: 1px solid rgba(107,191,78,.14);
      border-radius: 6px;
      padding: 10px 16px;
    }
    .pt-base-strip-label {
      font-family: 'Orbitron', sans-serif;
      font-size: .55rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      color: var(--slate-light); opacity: .7;
    }
    .pt-base-strip-val {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.05rem; font-weight: 900;
      color: var(--pistah-bright);
      text-shadow: 0 0 10px rgba(107,191,78,.5);
    }
    .pt-next-btn {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      width: 100%; padding: 11px 20px;
      background: rgba(107,191,78,.06);
      border: 1px solid rgba(107,191,78,.25);
      border-radius: 7px;
      font-family: 'Orbitron', sans-serif;
      font-size: .72rem; font-weight: 600;
      letter-spacing: 2px; text-transform: uppercase;
      color: var(--slate-light);
      cursor: pointer;
      transition: all .2s ease;
    }
    .pt-next-btn:hover {
      background: rgba(107,191,78,.12);
      border-color: rgba(107,191,78,.45);
      color: var(--pistah-bright);
    }
    .pt-next-btn svg { flex-shrink: 0; }

    /* ── FOOTER TICKER ───────────────────────────────────────── */
    .pt-footer {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      height: 52px; z-index: 30;
      display: flex; align-items: center;
      background: linear-gradient(90deg, #030a04 0%, #081508 50%, #030a04 100%);
      border-top: 1px solid rgba(107,191,78,.25);
      overflow: hidden;
    }
    .pt-footer-label {
      flex-shrink: 0;
      padding: 0 18px;
      font-family: 'Orbitron', sans-serif;
      font-size: .65rem; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase;
      color: var(--pistah);
      border-right: 1px solid rgba(107,191,78,.2);
      height: 100%;
      display: flex; align-items: center;
      background: rgba(107,191,78,.06);
    }
    /* ── Scrolling ticker ─────────────────────────────────── */
    .pt-teams-ticker {
      flex: 1;
      overflow: hidden;
      position: relative;
      mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 3%,
        black 97%,
        transparent 100%
      );
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 3%,
        black 97%,
        transparent 100%
      );
    }
    .pt-ticker-track {
      display: flex;
      align-items: center;
      gap: 24px;
      padding: 0 24px;
      width: max-content;               /* let it grow as wide as needed */
      animation: pt-ticker-scroll var(--pt-ticker-dur, 60s) linear infinite;
      will-change: transform;
    }
    .pt-ticker-track:hover {
      animation-play-state: paused;    /* pause on hover for readability */
    }
    @keyframes pt-ticker-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }  /* -50% = one full copy width */
    }
    .pt-team-chip {
      display: flex; align-items: center; gap: 8px;
      flex-shrink: 0;
      padding: 4px 14px 4px 8px;
      border-radius: 20px;
      border: 1px solid rgba(107,191,78,.15);
      background: rgba(107,191,78,.05);
    }
    .pt-team-chip img {
      width: 26px; height: 26px; border-radius: 50%;
      object-fit: contain;
      border: 1px solid rgba(107,191,78,.2);
    }
    .pt-team-chip-name {
      font-size: .72rem; font-weight: 600;
      letter-spacing: 1px; text-transform: uppercase;
      color: var(--slate-light);
    }
    .pt-team-chip-pts {
      font-family: 'Orbitron', sans-serif;
      font-size: .68rem; font-weight: 700;
      color: var(--pistah);
      margin-left: 4px;
    }

    /* ── Modals / overlays ───────────────────────────────────── */
    #ptUnsoldModal {
      display: none; position: fixed; inset: 0; z-index: 10000;
      background: rgba(0,0,0,.82);
      align-items: center; justify-content: center;
    }
    #ptUnsoldModal .pt-modal-box {
      background: #0d1f11;
      border-radius: 14px; padding: 36px 28px 28px;
      max-width: 400px; width: 92%;
      box-shadow: 0 12px 48px rgba(107,191,78,.25), 0 0 0 1px rgba(107,191,78,.35);
      border-top: 3px solid var(--pistah);
      text-align: center; font-family: inherit;
    }
    .pt-modal-icon {
      width: 56px; height: 56px; border-radius: 50%;
      background: rgba(107,191,78,.10);
      border: 2px solid var(--pistah);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 16px; font-size: 1.6rem;
    }
    .pt-modal-title {
      margin: 0 0 10px; font-size: 1.15rem; font-weight: 700; color: var(--text-main);
    }
    .pt-modal-body {
      color: var(--text-dim); margin: 0 0 26px;
      font-size: .9rem; line-height: 1.5;
    }
    .pt-modal-btns { display: flex; gap: 12px; justify-content: center; }
    .pt-btn-cancel {
      padding: 10px 28px; border-radius: 8px;
      border: 1px solid rgba(255,255,255,.2);
      background: rgba(255,255,255,.06); color: var(--text-main);
      font-size: .95rem; cursor: pointer; font-weight: 500;
    }
    .pt-btn-confirm {
      padding: 10px 28px; border-radius: 8px;
      border: none;
      background: linear-gradient(135deg, var(--pistah-dark), #388e3c);
      color: #fff; font-size: .95rem; font-weight: 700; cursor: pointer;
      box-shadow: 0 0 16px rgba(107,191,78,.4);
    }

    #ptToast {
      display: none; position: fixed;
      bottom: 70px; left: 50%; transform: translateX(-50%);
      z-index: 10001; color: #fff;
      padding: 12px 28px; border-radius: 8px;
      font-size: .95rem; font-weight: 600;
      box-shadow: 0 4px 16px rgba(0,0,0,.5);
    }

    /* ── Cricket Watermark ─────────────────────────────────── */
    .pt-cricket-wm {
      margin-top: auto;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 12px 16px 8px;
      pointer-events: none;
      user-select: none;
      position: relative;
    }
    .pt-cricket-wm-rule {
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(107,191,78,.2), transparent);
    }
    .pt-cricket-wm-icons {
      display: flex;
      align-items: center;
      gap: 20px;
      opacity: 0.28;
    }
  </style>
</head>

<body t-att-data-player-id="player.id">

  <!-- ── HEADER ────────────────────────────────────────────── -->
  <header class="pt-header">

    <!-- LEFT: Auction Champ product brand (logo.svg) -->
    <div class="pt-header-brand">
      <img src="/auction_module/static/src/assets/images/logo.svg" alt="Auction Champ"/>
      <div class="pt-header-brand-text">
        <span class="pt-brand-name">Auction Champ</span>
        <span class="pt-brand-season">Pistah Edition</span>
      </div>
    </div>

    <!-- CENTER: Tournament logo (large) + name + description -->
    <div class="pt-header-center">
      <t t-if="tournament and tournament.logo">
        <img class="pt-tourn-logo-center"
             t-att-src="image_data_uri(tournament.logo)"
             alt="Tournament Logo"/>
      </t>
      <t t-if="tournament">
        <div class="pt-tourn-info-center">
          <span class="pt-tourn-name-center"><t t-esc="tournament.name"/></span>
          <t t-if="tournament.description">
            <span class="pt-tourn-desc-center"><t t-esc="tournament.description"/></span>
          </t>
        </div>
      </t>
    </div>

    <!-- RIGHT: LIVE badge only -->
    <div class="pt-header-right-wrap">
      <div class="pt-live-badge">
        <span class="pt-live-dot"></span>
        LIVE
      </div>
    </div>

  </header>

  <!-- ── MAIN STAGE ─────────────────────────────────────────── -->
  <main class="pt-stage" data-player-zone="">

    <!-- LEFT: PHOTO PANEL -->
    <div class="pt-photo-panel">
      <div class="pt-serial-watermark">
        <t t-esc="'%02d' % (player.sl_no or 0)"/>
