           t-att-src="image_data_uri(player.photo)"
           aria-hidden="true" alt=""/>

      <img class="pt-photo" id="loadImage"
           t-att-src="image_data_uri(player.photo)"
           alt="Player Photo"/>

      <!-- Diagonal slash -->
      <div class="pt-diagonal-slash"></div>

      <!-- Name block at bottom of photo -->
      <div class="pt-photo-name-block">
        <div class="pt-photo-serial">
          #<t t-esc="'%02d' % (player.sl_no or 0)"/>
        </div>
        <div class="pt-player-name"><t t-esc="player.name"/></div>
        <t t-if="player.role">
          <div class="pt-player-role"><t t-esc="player.role"/></div>
        </t>
      </div>
    </div>

    <!-- RIGHT: right-col wraps info panel + buttons so they're outside overflow:hidden -->
    <div class="pt-right-col">

    <div class="pt-info-panel">

      <!-- Tier badge -->
      <div class="pt-tier-badge"
           t-att-style="('--tier-color:' + player.tier_id.color + '; color:' + player.tier_id.color + '; border-color:' + player.tier_id.color + '55; background:' + player.tier_id.color + '15;') if player.tier_id else ''">
        <t t-if="player.tier_id">
          <t t-esc="player.tier_id.name"/>
