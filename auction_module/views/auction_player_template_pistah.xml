      <!-- Stats grid -->
      <div class="pt-stats-grid">
        <t t-if="player.batting_style">
          <div class="pt-stat-tile">
            <div class="pt-stat-val"><t t-esc="player.batting_style"/></div>
            <div class="pt-stat-key">Batting</div>
          </div>
        </t>
        <t t-if="player.bowling_style">
          <div class="pt-stat-tile">
            <div class="pt-stat-val"><t t-esc="player.bowling_style"/></div>
            <div class="pt-stat-key">Bowling</div>
          </div>
        </t>
        <t t-if="player.blood_group">
          <div class="pt-stat-tile">
            <div class="pt-stat-val" style="color:#A8E063; font-weight:800;">
              <t t-esc="player.blood_group"/>
            </div>
            <div class="pt-stat-key">Blood Group</div>
          </div>
        </t>
        <t t-if="player.p_category">
          <div class="pt-stat-tile">
            <div class="pt-stat-val"><t t-esc="player.p_category"/></div>
            <div class="pt-stat-key">Category</div>
          </div>
        </t>
        <t t-if="player.contact">
          <div class="pt-stat-tile">
            <div class="pt-stat-val"><t t-esc="player.contact"/></div>
            <div class="pt-stat-key">Mobile</div>
          </div>
        </t>
        <t t-if="player.address">
          <div class="pt-stat-tile">
            <div class="pt-stat-val"><t t-esc="player.address"/></div>
            <div class="pt-stat-key">Location</div>
          </div>
        </t>
      </div>

      <!-- Base price from auction tier setup -->
      <t t-if="player.effective_base_price">
        <div class="pt-base-strip">
          <span class="pt-base-strip-label">Base Price</span>
          <span class="pt-base-strip-val"><t t-esc="'{:,}'.format(int(player.effective_base_price or 0))"/> pts</span>
        </div>
      </t>

      <!-- Cricket Watermark Row — fills empty space between stats and buttons -->
      <div class="pt-cricket-wm">
        <div class="pt-cricket-wm-rule"></div>
        <div class="pt-cricket-wm-icons">

          <!-- Cricket Bat -->
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Blade: rounded oval body -->
            <ellipse cx="22" cy="17" rx="8" ry="13" fill="rgba(107,191,78,.15)" stroke="rgba(107,191,78,.9)" stroke-width="1.4"/>
            <!-- Shoulder ridges -->
            <line x1="15" y1="22" x2="29" y2="22" stroke="rgba(107,191,78,.5)" stroke-width="0.8"/>
            <line x1="15" y1="26" x2="29" y2="26" stroke="rgba(107,191,78,.5)" stroke-width="0.8"/>
            <!-- Handle grip -->
            <rect x="19.5" y="30" width="5" height="10" rx="2.5" fill="rgba(107,191,78,.2)" stroke="rgba(107,191,78,.9)" stroke-width="1.4"/>
            <!-- Grip wrap marks -->
            <line x1="19.5" y1="33" x2="24.5" y2="33" stroke="rgba(107,191,78,.6)" stroke-width="0.9"/>
            <line x1="19.5" y1="36" x2="24.5" y2="36" stroke="rgba(107,191,78,.6)" stroke-width="0.9"/>
            <line x1="19.5" y1="39" x2="24.5" y2="39" stroke="rgba(107,191,78,.6)" stroke-width="0.9"/>
          </svg>

          <!-- Cricket Ball -->
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="22" cy="22" r="16" fill="rgba(107,191,78,.10)" stroke="rgba(107,191,78,.9)" stroke-width="1.4"/>
            <!-- Vertical seam curves -->
            <path d="M16 7 Q12 14 13 22 Q14 30 16 37" stroke="rgba(107,191,78,.75)" stroke-width="1.1" stroke-linecap="round" fill="none"/>
            <path d="M28 7 Q32 14 31 22 Q30 30 28 37" stroke="rgba(107,191,78,.75)" stroke-width="1.1" stroke-linecap="round" fill="none"/>
            <!-- Horizontal seam curves -->
            <path d="M8 17 Q15 21 22 20 Q29 19 36 21" stroke="rgba(107,191,78,.55)" stroke-width="0.9" stroke-linecap="round" fill="none"/>
            <path d="M8 27 Q15 24 22 25 Q29 26 36 24" stroke="rgba(107,191,78,.55)" stroke-width="0.9" stroke-linecap="round" fill="none"/>
          </svg>

          <!-- Cricket Stumps + Bails -->
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Ground line -->
            <line x1="6" y1="38" x2="38" y2="38" stroke="rgba(107,191,78,.5)" stroke-width="1" stroke-linecap="round"/>
            <!-- Three stumps -->
            <line x1="14" y1="10" x2="14" y2="38" stroke="rgba(107,191,78,.9)" stroke-width="2.2" stroke-linecap="round"/>
            <line x1="22" y1="10" x2="22" y2="38" stroke="rgba(107,191,78,.9)" stroke-width="2.2" stroke-linecap="round"/>
            <line x1="30" y1="10" x2="30" y2="38" stroke="rgba(107,191,78,.9)" stroke-width="2.2" stroke-linecap="round"/>
            <!-- Bail 1 (stump 1 → stump 2) -->
            <path d="M12 10 Q14 7 18 10 Q20 11 22 10" stroke="rgba(107,191,78,.9)" stroke-width="2" stroke-linecap="round" fill="none"/>
            <!-- Bail 2 (stump 2 → stump 3) -->
            <path d="M22 10 Q24 7 28 10 Q30 11 32 10" stroke="rgba(107,191,78,.9)" stroke-width="2" stroke-linecap="round" fill="none"/>
          </svg>

        </div>
        <div class="pt-cricket-wm-rule"></div>
      </div>

    </div><!-- /pt-info-panel -->

    <!-- Buttons live OUTSIDE pt-info-panel so overflow:hidden doesn't clip them -->
    <!-- Primary action buttons -->
    <div class="pt-actions">
      <button class="pt-btn pt-btn-unsold" onclick="setPlayerUnsold()">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
        </svg>
        Set Unsold
      </button>
      <button class="pt-btn pt-btn-sell" onclick="openSellModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
        </svg>
        Sell to Team
      </button>
    </div>

    <!-- Next player -->
    <div class="pt-next-strip">
      <button class="pt-next-btn" onclick="changeImage()">
        Next Player
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 18L14.5 12 6 6V18ZM16 6V18H18V6H16Z"/>
        </svg>
      </button>
    </div>

    </div><!-- /pt-right-col -->
  </main>

  <!-- ── FOOTER TICKER ─────────────────────────────────────── -->
  <footer class="pt-footer">
    <div class="pt-footer-label">Teams</div>
    <div class="pt-teams-ticker">
      <t t-if="auction_ids">
        <!-- Track is rendered twice; CSS animates it by -50% for a seamless loop -->
        <div class="pt-ticker-track" id="ptTickerTrack">
          <!-- copy 1 -->
          <t t-foreach="auction_ids" t-as="a">
            <div class="pt-team-chip">
              <t t-if="a.team_id and a.team_id.logo">
                <img t-att-src="image_data_uri(a.team_id.logo)"
                     t-att-alt="a.team_id.name"/>
              </t>
              <span class="pt-team-chip-name">
                <t t-esc="a.team_id.name if a.team_id else 'Team'"/>
              </span>
              <span class="pt-team-chip-pts">
                <t t-esc="'{:,}'.format(a.remaining_points or 0)"/> pts
              </span>
            </div>
          </t>
          <!-- copy 2 — identical, aria-hidden so screen readers skip it -->
          <t t-foreach="auction_ids" t-as="a">
            <div class="pt-team-chip" aria-hidden="true">
              <t t-if="a.team_id and a.team_id.logo">
                <img t-att-src="image_data_uri(a.team_id.logo)"
                     t-att-alt="a.team_id.name"/>
              </t>
              <span class="pt-team-chip-name">
                <t t-esc="a.team_id.name if a.team_id else 'Team'"/>
              </span>
              <span class="pt-team-chip-pts">
                <t t-esc="'{:,}'.format(a.remaining_points or 0)"/> pts
              </span>
            </div>
          </t>
        </div>
      </t>
    </div>
  </footer>

  <script>
    /* Calibrate ticker speed to content width so it feels consistent
       regardless of team count (target ~90 px/s).
       If all teams fit on screen without scrolling, disable animation. */
    (function () {
      var track = document.getElementById('ptTickerTrack');
      if (!track) return;
      var singleW = track.scrollWidth / 2;   /* width of one copy */
      var viewW   = track.parentElement.offsetWidth;
      if (singleW &lt;= viewW) {
        /* All teams fit — no scrolling needed, centre them instead */
        track.style.animation = 'none';
        track.style.justifyContent = 'center';
      } else {
        var dur = Math.max(20, Math.round(singleW / 90)); /* min 20 s */
        track.style.setProperty('--pt-ticker-dur', dur + 's');
      }
    })();
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"
          integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM"
          crossorigin="anonymous"></script>

  <script>
    async function changeImage() {
      var toast = document.getElementById('ac-next-toast');
      var bar   = document.getElementById('ac-next-bar');
      if (toast) {
        toast.style.display  = 'flex';
        toast.style.opacity  = '1';
        bar.style.transition = 'none';
        bar.style.width      = '0%';
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            bar.style.transition = 'width 1.2s cubic-bezier(.4,0,.2,1)';
            bar.style.width      = '80%';
          });
        });
      }
      try {
        var resp = await fetch(window.location.href, {cache: 'no-store'});
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        var html = await resp.text();
        var parser = new DOMParser();
        var newDoc = parser.parseFromString(html, 'text/html');
        var pid = newDoc.body.getAttribute('data-player-id');
        if (pid) document.body.setAttribute('data-player-id', pid);
        var zone    = document.querySelector('[data-player-zone]');
        var newZone = newDoc.querySelector('[data-player-zone]');
        if (zone &amp;&amp; newZone) { zone.innerHTML = newZone.innerHTML; }
        if (toast) {
          bar.style.transition = 'width 0.15s ease';
          bar.style.width      = '100%';
          setTimeout(function() {
            toast.style.opacity = '0';
            setTimeout(function() { toast.style.display = 'none'; }, 400);
          }, 250);
        }
      } catch(e) {
        console.error('Next player load failed:', e);
        window.location.reload();
      }
    }

    document.addEventListener('keydown', function(e) {
      if (e.code === 'Space') { e.preventDefault(); changeImage(); }
    });

    function setPlayerUnsold() {
      document.getElementById('ptUnsoldModal').style.display = 'flex';
    }

    (function() {
      document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('ptCancelBtn').addEventListener('click', function() {
          document.getElementById('ptUnsoldModal').style.display = 'none';
        });
        document.getElementById('ptConfirmBtn').addEventListener('click', function() {
          document.getElementById('ptUnsoldModal').style.display = 'none';
          var playerId = parseInt(document.body.getAttribute('data-player-id'));
          if (!playerId) { showToast('Error: Player ID not found', true); return; }
          fetch('/web/dataset/call_kw', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
              jsonrpc: '2.0', method: 'call',
              params: { model: 'auction.team.player', method: 'action_unsold', args: [[playerId]], kwargs: {} }
            })
          }).then(r => r.json()).then(function(result) {
            if (result.error) { showToast('Failed to mark player as unsold', true); }
            else {
              var secs = (result.result &amp;&amp; result.result.display_seconds > 0) ? result.result.display_seconds : 5;
              showUnsoldStamp(secs, '#6BBF4E', '#fff');
            }
          }).catch(function() { showToast('Failed to mark player as unsold', true); });
        });
      });
    })();

    function showToast(message, isError) {
      var t = document.getElementById('ptToast');
      t.textContent = message;
      t.style.background = isError ? '#1b5e20' : '#2e7d32';
      t.style.display = 'block';
      setTimeout(function() { t.style.display = 'none'; }, 3500);
    }

    function showUnsoldStamp(displaySeconds, stampColor, stampText) {
      if (!document.getElementById('_ptUnsoldCSS')) {
        var s = document.createElement('style');
        s.id = '_ptUnsoldCSS';
        s.textContent = '@keyframes _ptDrop{0%{transform:rotate(-22deg) scale(2.4);opacity:0}100%{transform:rotate(-22deg) scale(1);opacity:.92}}@keyframes _ptFade{from{opacity:0}to{opacity:1}}';
        document.head.appendChild(s);
      }
      var img = document.getElementById('loadImage');
      var r = img.getBoundingClientRect();
      var ov = document.createElement('div');
      ov.style.cssText = 'position:fixed;z-index:9500;top:'+r.top+'px;left:'+r.left+'px;width:'+r.width+'px;height:'+r.height+'px;background:rgba(0,0,0,0.48);display:flex;align-items:center;justify-content:center;animation:_ptFade .35s ease;pointer-events:none;';
      var stamp = document.createElement('div');
      stamp.style.cssText = 'background:'+stampColor+';color:'+stampText+';font-family:Orbitron,sans-serif;font-size:clamp(1.8rem,5vw,3.2rem);font-weight:900;letter-spacing:6px;padding:8px 36px;border:5px solid rgba(255,255,255,0.85);border-radius:6px;box-shadow:0 0 0 3px '+stampColor+',0 8px 40px rgba(0,0,0,.5);opacity:0;animation:_ptDrop .5s cubic-bezier(.34,1.3,.64,1) .15s forwards;text-shadow:2px 3px 8px rgba(0,0,0,.4);';
      stamp.textContent = 'UNSOLD';
      var barWrap = document.createElement('div');
      barWrap.style.cssText = 'position:absolute;bottom:12px;left:16px;right:16px;';
      var barTrack = document.createElement('div');
      barTrack.style.cssText = 'background:rgba(255,255,255,0.25);border-radius:4px;height:6px;overflow:hidden;';
      var bar = document.createElement('div');
      bar.style.cssText = 'height:100%;width:100%;background:'+stampColor+';border-radius:4px;transition:width '+displaySeconds+'s linear;';
      barTrack.appendChild(bar); barWrap.appendChild(barTrack);
      ov.appendChild(stamp); ov.appendChild(barWrap);
      document.body.appendChild(ov);
      requestAnimationFrame(function() { requestAnimationFrame(function() { bar.style.width = '0%'; }); });
      setTimeout(function() { if (ov.parentNode) ov.parentNode.removeChild(ov); changeImage(); }, displaySeconds * 1000);
    }

    function openBidSummary() {
      document.getElementById('ptBidFrame').src = '/auction/show/team/balance';
      document.getElementById('ptBidDrawer').style.right = '0';
      document.getElementById('ptBidArrow').innerHTML = '&#x2192;';
      document.getElementById('ptBidOverlay').style.display = 'block';
      document.body.style.overflow = 'hidden';
    }
    function closeBidSummary() {
      document.getElementById('ptBidDrawer').style.right = '-1150px';
      document.getElementById('ptBidArrow').innerHTML = '&#x2190;';
      document.getElementById('ptBidOverlay').style.display = 'none';
      document.body.style.overflow = '';
    }
    function toggleBidSummary() {
      var r = document.getElementById('ptBidDrawer').style.right;
      if (r === '0px' || r === '0') closeBidSummary(); else openBidSummary();
    }
  </script>

  <!-- Bid Summary Drawer – Pistah Theme -->
  <div id="ptBidDrawer" style="position:fixed;top:0;right:-1150px;width:1150px;max-width:96vw;height:100vh;z-index:9800;display:flex;flex-direction:column;background:#0b1a0e;border-left:3px solid #6BBF4E;box-shadow:-6px 0 40px rgba(107,191,78,0.3);transition:right .35s cubic-bezier(.4,0,.2,1);">
    <div onclick="toggleBidSummary()" style="position:absolute;left:-44px;top:50%;transform:translateY(-50%);width:44px;height:130px;background:linear-gradient(180deg,#1b5e20,#2e7d32);border-radius:8px 0 0 8px;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;box-shadow:-4px 2px 14px rgba(107,191,78,0.4);z-index:1;border:1px solid rgba(107,191,78,0.3);">
      <span id="ptBidArrow" style="color:#A8E063;font-size:1.2rem;line-height:1;">&#x2190;</span>
      <span style="color:#A8E063;writing-mode:vertical-rl;transform:rotate(180deg);font-size:0.58rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;opacity:0.9;">Summary</span>
    </div>
    <div style="padding:16px 20px;background:linear-gradient(135deg,#060e08,#0d1f11);color:#e8f5e9;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;border-bottom:2px solid #6BBF4E;">
      <span style="font-size:1.05rem;font-weight:700;letter-spacing:.3px;">&#x1F4CA; Auction Bid Summary</span>
      <button onclick="closeBidSummary()" style="background:rgba(107,191,78,0.12);border:1px solid rgba(107,191,78,0.4);color:#e8f5e9;width:32px;height:32px;border-radius:6px;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">&#x2715;</button>
    </div>
    <iframe id="ptBidFrame" style="flex:1;border:none;width:100%;" title="Bid Summary"></iframe>
  </div>
  <div id="ptBidOverlay" onclick="closeBidSummary()" style="display:none;position:fixed;inset:0;z-index:9700;background:rgba(0,0,0,0.65);"></div>

  <!-- Unsold Confirmation Modal – Pistah Theme -->
  <div id="ptUnsoldModal" style="display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,0.82);align-items:center;justify-content:center;">
    <div class="pt-modal-box">
      <div class="pt-modal-icon">⚠️</div>
      <h5 class="pt-modal-title">Set Player as Unsold?</h5>
      <p class="pt-modal-body">This will set the player to Unsold. You can bring them back to Auction later.</p>
      <div class="pt-modal-btns">
        <button id="ptCancelBtn" class="pt-btn-cancel">Cancel</button>
        <button id="ptConfirmBtn" class="pt-btn-confirm">Confirm</button>
      </div>
    </div>
  </div>

  <!-- Next-player progress toast -->
  <div id="ac-next-toast" style="display:none;opacity:0;position:fixed;bottom:70px;left:50%;transform:translateX(-50%);z-index:10002;min-width:220px;max-width:320px;background:#0a1a0d;border-radius:14px;box-shadow:0 8px 32px rgba(0,0,0,.6);overflow:hidden;flex-direction:column;transition:opacity .4s;border:1px solid rgba(107,191,78,.2);">
    <div style="padding:12px 20px 10px;display:flex;align-items:center;gap:10px;">
      <span style="font-size:1.1rem;">⚡</span>
      <span style="color:#e8f5e9;font-size:0.85rem;font-weight:600;letter-spacing:.5px;">Loading Next Player…</span>
    </div>
    <div style="height:3px;background:rgba(255,255,255,.1);">
      <div id="ac-next-bar" style="height:100%;width:0%;background:#6BBF4E;border-radius:2px;transition:width .3s;"></div>
    </div>
  </div>

  <!-- Toast -->
