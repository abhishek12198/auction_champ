<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ── Search View ──────────────────────────────────────────────── -->
        <record id="view_auction_team_search" model="ir.ui.view">
            <field name="name">auction.team.search</field>
            <field name="model">auction.team</field>
            <field name="arch" type="xml">
                <search string="Team">
                    <field name="name" filter_domain="[('name','ilike',self)]" string="Team Name"/>
                    <field name="manager" filter_domain="[('manager','ilike',self)]" string="Owner"/>
                    <field name="tournament_id" string="League"/>
                    <separator/>
                    <filter string="Has Icon Players" name="has_icon_players"
                            domain="[('key_player_ids', '!=', False)]"/>
                    <group expand="1" string="Group By">
                        <filter string="League" name="group_by_tournament"
                                context="{'group_by': 'tournament_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ── Kanban View ──────────────────────────────────────────────── -->
        <record id="view_auction_team_kanban" model="ir.ui.view">
            <field name="name">auction.team.kanban</field>
            <field name="model">auction.team</field>
            <field name="arch" type="xml">
                <kanban class="o_team_kanban_view">
                    <field name="name"/>
                    <field name="logo"/>
                    <field name="tournament_id"/>
                    <field name="manager"/>
                    <field name="key_player_ids"/>
                    <field name="id"/>
                    <templates>
                        <t t-name="kanban-box">
                            <t t-set="icon_count" t-value="(record.key_player_ids.raw_value || []).length"/>
                            <div class="atk-card oe_kanban_global_click">

                                <!-- Banner: circular logo over gradient -->
                                <div class="atk-banner">
                                    <div class="atk-logo-wrap">
                                        <img t-attf-src="/web/image/auction.team/#{record.id.raw_value}/logo"
                                             alt="Team Logo"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
                                        <div class="atk-logo-ph" style="display:none;">🛡</div>
                                    </div>
                                    <div class="atk-banner-info">
                                        <div class="atk-team-name"><t t-esc="record.name.raw_value"/></div>
                                        <div t-if="record.manager.raw_value" class="atk-owner">
                                            <i class="fa fa-user-o"/>
                                            <t t-esc="record.manager.raw_value"/>
                                        </div>
                                    </div>
                                </div>

                                <!-- Card body -->
                                <div class="atk-body">
                                    <t t-if="record.tournament_id.raw_value">
                                        <div class="atk-tournament">
                                            <i class="fa fa-trophy"/>
                                            <t t-esc="record.tournament_id.value"/>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="atk-tournament-empty">
                                            <i class="fa fa-trophy"/>
                                            No league assigned
                                        </div>
                                    </t>

                                    <div class="atk-divider"/>

                                    <div class="atk-section-label">
                                        <i class="fa fa-star"/>
                                        Icon Players
                                        <span class="atk-count-badge"><t t-esc="icon_count"/></span>
                                    </div>
                                    <t t-if="icon_count > 0">
                                        <field name="key_player_ids" widget="many2many_tags"/>
                                    </t>
                                    <t t-else="">
                                        <div class="atk-no-players">No icon players assigned</div>
                                    </t>
                                </div>

                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ── List View ────────────────────────────────────────────────── -->
        <record id="view_auction_team_tree" model="ir.ui.view">
            <field name="name">auction.team.tree</field>
            <field name="model">auction.team</field>
            <field name="arch" type="xml">
                <tree string="Teams" decoration-muted="not manager" class="o_team_list_view">
                    <field name="logo" widget="image" string=" "/>
                    <field name="name" string="Team Name"/>
                    <field name="manager" string="Owner"/>
                    <field name="tournament_id" string="League"/>
                    <field name="key_player_ids" widget="many2many_tags" string="Icon Players"/>
                </tree>
            </field>
        </record>

        <!-- ── Form View ────────────────────────────────────────────────── -->
        <record id="view_auction_team_form" model="ir.ui.view">
            <field name="name">auction.team.form</field>
            <field name="model">auction.team</field>
            <field name="arch" type="xml">
                <form string="Team">
                    <sheet>
                        <field name="logo" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <label class="o_form_label" for="name"/>
                            <h1><field name="name" placeholder="Team Name…"/></h1>
                            <h4 style="color:#888;font-weight:400;margin-top:4px;">
                                <field name="manager" placeholder="Owner name" required="1"/>
                            </h4>
                        </div>

                        <group>
                            <group string="Team Details">
                                <field name="tournament_id" string="League / Tournament"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="⭐  Icon Players" name="icon_players">
                                <field name="key_player_ids" nolabel="1"
                                       domain="[('state', 'in', ['draft', 'auction'])]"
                                       options="{'no_create': 1}" readonly="1">
                                    <tree editable="bottom" create="0" delete="0" write="0">
                                        <field name="name"/>
                                        <field name="contact"/>
                                        <field name="role"/>
                                        <field name="batting_style"/>
                                        <field name="bowling_style"/>
                                    </tree>
                                    <form>
                                        <widget name="web_ribbon" title="Icon Player" bg_color="bg-info"
                                                attrs="{'invisible': [('icon_player', '=', False)]}"/>
                                        <field name="photo" widget="image" class="oe_avatar" readonly="1"/>
                                        <group col="4">
                                            <field name="name"/>
                                            <field name="contact"/>
                                            <field name="batting_style"/>
                                            <field name="bowling_style"/>
                                            <field name="role"/>
                                            <field name="amount_paid" widget="boolean_toggle"/>
                                            <field name="photo_url" readonly="1" widget="url"/>
                                            <field name="icon_player" invisible="1"/>
                                        </group>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ── Action ───────────────────────────────────────────────────── -->
        <record id="action_auction_team" model="ir.actions.act_window">
            <field name="name">Team</field>
            <field name="res_model">auction.team</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="view_auction_team_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first team!
                </p>
                <p>
                    Create and manage teams participating in the auction.
                </p>
            </field>
        </record>

    </data>
</odoo>
