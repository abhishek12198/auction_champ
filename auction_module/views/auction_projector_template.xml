<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="projector_template" name="Auction Projector View">
<html lang="en" t-att-data-theme="theme">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Projector — <t t-if="tournament"><t t-esc="tournament.name"/></t></title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1"/>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=Barlow+Condensed:wght@400;500;600;700&amp;family=Orbitron:wght@600;700;900&amp;family=Rajdhani:wght@400;500;600;700&amp;family=Nunito:wght@600;700;800;900&amp;family=Teko:wght@500;600;700&amp;display=swap" rel="stylesheet"/>
  <style>
/* ══ THEME VARIABLES ══════════════════════════════════════════════════ */
[data-theme="vanilla"]{
  --accent:#E8A020;--accent2:#c87d10;--glow:rgba(232,160,32,.4);
  --bg:#060C1A;--bg2:#0f1f44;--card:#0B1529;
  --tx:#EEF4FF;--tx-d:rgba(238,244,255,.55);
  --hf:'Orbitron',sans-serif;--bf:'Rajdhani',sans-serif;
  --tier-glow:rgba(232,160,32,.3);
}
[data-theme="butterscotch"]{
  --accent:#F5C842;--accent2:#d4a820;--glow:rgba(245,200,66,.4);
  --bg:#090912;--bg2:#1a1005;--card:#0f0f20;
  --tx:#fff;--tx-d:rgba(255,255,255,.55);
  --hf:'Teko',sans-serif;--bf:'Rajdhani',sans-serif;
  --tier-glow:rgba(245,200,66,.3);
}
[data-theme="strawberry"]{
  --accent:#C2185B;--accent2:#880E4F;--glow:rgba(194,24,91,.35);
  --bg:#FFF0F5;--bg2:#FFE4EE;--card:#fff;
  --tx:#1a0a12;--tx-d:rgba(26,10,18,.5);
  --hf:'Nunito',sans-serif;--bf:'Nunito',sans-serif;
  --tier-glow:rgba(194,24,91,.25);
}
[data-theme="cherry"]{
  --accent:#DC143C;--accent2:#a00e2b;--glow:rgba(220,20,60,.4);
  --bg:#0d0d0d;--bg2:#1a0608;--card:#181818;
  --tx:#f5f5f5;--tx-d:rgba(245,245,245,.5);
  --hf:'Teko',sans-serif;--bf:'Rajdhani',sans-serif;
  --tier-glow:rgba(220,20,60,.3);
}
[data-theme="pistah"]{
  --accent:#6BBF4E;--accent2:#4a9935;--glow:rgba(107,191,78,.4);
  --bg:#060e08;--bg2:#0d1f11;--card:#111f14;
  --tx:#e8f5e9;--tx-d:rgba(232,245,233,.5);
  --hf:'Orbitron',sans-serif;--bf:'Rajdhani',sans-serif;
  --tier-glow:rgba(107,191,78,.3);
}

/* ══ RESET + BASE ═════════════════════════════════════════════════════ */
/* Sports display font — all themes */
:root,[data-theme]{--sf:'Bebas Neue','Teko',sans-serif;--sf-body:'Barlow Condensed','Rajdhani',sans-serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);color:var(--tx);
  font-family:var(--sf-body)}

/* ══ LAYOUT ═══════════════════════════════════════════════════════════ */
#pj-root{position:fixed;inset:0;display:flex;flex-direction:column}

/* Top bar */
#pj-bar{display:flex;align-items:center;justify-content:space-between;
  padding:10px 28px;background:var(--bg2);border-bottom:2px solid var(--accent);
  flex-shrink:0;z-index:10;gap:16px}
.pj-bar-left{display:flex;align-items:center;gap:12px}
.pj-logo{height:40px;width:auto;object-fit:contain}
.pj-logo-ph{width:40px;height:40px;border-radius:50%;background:var(--accent);
  display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:var(--bg)}
.pj-tname{font-family:var(--hf);font-size:clamp(.9rem,2vw,1.2rem);font-weight:700;
  letter-spacing:3px;text-transform:uppercase;color:var(--accent)}
.pj-bar-right{font-family:var(--hf);font-size:.65rem;font-weight:600;letter-spacing:2px;
  text-transform:uppercase;color:var(--tx-d);display:flex;align-items:center;gap:14px}
/* Auction Champ logo in bar */
.pj-ac-bar-logo{height:28px;width:auto;opacity:.85;
  filter:drop-shadow(0 0 6px var(--glow));flex-shrink:0}
.pj-bar-divider{width:1px;height:20px;background:rgba(255,255,255,.15)}
.pj-fs-btn{background:none;border:1.5px solid rgba(255,255,255,.2);color:var(--tx-d);
  width:34px;height:34px;border-radius:6px;cursor:pointer;font-size:1rem;
  display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.pj-fs-btn:hover{border-color:var(--accent);color:var(--accent)}
.pj-live-dot{width:8px;height:8px;border-radius:50%;background:#2ecc71;
  animation:pjPulse 1.6s ease-in-out infinite}
@keyframes pjPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}

/* Stage area */
#pj-stage{flex:1;position:relative;overflow:hidden;display:flex}

/* ══ STADIUM BACKGROUND ═══════════════════════════════════════════════ */
#pjStadium{position:absolute;inset:0;width:100%;height:100%;
  z-index:0;pointer-events:none;display:block}
/* Floodlight beam breathing */
@keyframes pjBeam{0%,100%{opacity:1}50%{opacity:.6}}
.pj-beam-1{animation:pjBeam 4s ease-in-out infinite}
.pj-beam-2{animation:pjBeam 4s ease-in-out 1s infinite}
.pj-beam-3{animation:pjBeam 4s ease-in-out 2s infinite}
.pj-beam-4{animation:pjBeam 4s ease-in-out 3s infinite}
/* Strawberry is light-themed — keep projector stage dark so stadium reads well */
[data-theme="strawberry"] #pj-stage{background:#0d0610}
/* Strawberry overrides: restore light text so player name/details are visible on dark projector */
[data-theme="strawberry"] #pj-stage{--tx:#EEF4FF;--tx-d:rgba(238,244,255,.55);--bg2:#1a0a1e;--card:#120818}
[data-theme="strawberry"] #pj-stage .pj-stat{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.15)}
/* Info side semi-transparent dark veil so text stays readable over stadium */
.pj-info-side{background:linear-gradient(135deg,rgba(0,0,0,.62) 0%,rgba(0,0,0,.38) 100%)}

/* ══ WAITING SCREEN ═══════════════════════════════════════════════════ */
#pj-waiting{position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:20px;
  background:rgba(0,0,0,.80);backdrop-filter:blur(3px);z-index:5;transition:opacity .5s}
#pj-waiting.hidden{opacity:0;pointer-events:none}
/* Auction Champ product logo — big, centre-stage */
.pj-ac-logo{width:clamp(180px,30vw,340px);height:auto;
  filter:drop-shadow(0 0 28px var(--glow)) drop-shadow(0 0 8px rgba(0,0,0,.8));
  animation:pjAcPulse 4s ease-in-out infinite}
@keyframes pjAcPulse{
  0%,100%{filter:drop-shadow(0 0 20px var(--glow)) drop-shadow(0 0 8px rgba(0,0,0,.8))}
  50%    {filter:drop-shadow(0 0 50px var(--glow)) drop-shadow(0 0 8px rgba(0,0,0,.8))}
}
/* Tournament logo — secondary, smaller */
.pj-wait-logo{width:min(100px,16vw);height:auto;opacity:.5;border-radius:8px}
.pj-wait-logo-ph{width:min(70px,12vw);height:min(70px,12vw);border-radius:50%;
  background:rgba(255,255,255,.05);display:flex;align-items:center;
  justify-content:center;font-size:2.2rem;opacity:.3}
.pj-wait-title{font-family:var(--hf);font-size:clamp(1.2rem,3vw,2rem);font-weight:700;
  letter-spacing:6px;text-transform:uppercase;color:var(--tx-d);text-align:center}
.pj-wait-dots{display:flex;gap:10px}
.pj-wait-dot{width:10px;height:10px;border-radius:50%;background:var(--accent);
  animation:pjDot 1.4s ease-in-out infinite}
.pj-wait-dot:nth-child(2){animation-delay:.2s}
.pj-wait-dot:nth-child(3){animation-delay:.4s}
@keyframes pjDot{0%,80%,100%{transform:scale(.6);opacity:.3}40%{transform:scale(1);opacity:1}}

/* ══ PROJECTOR DICE (waiting screen) ══════════════════════════════════ */
.pj-dice-area{display:none;flex-direction:column;align-items:center;gap:20px;margin-top:10px}
.pj-dice-area.visible{display:flex;animation:pjDiceAreaIn .5s cubic-bezier(.175,.885,.32,1.275)}
.pj-dice-area.hiding{animation:pjDiceAreaOut .4s ease forwards}
@keyframes pjDiceAreaIn{from{opacity:0;transform:scale(.6) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes pjDiceAreaOut{to{opacity:0;transform:scale(.7) translateY(20px)}}
.pj-dice-roll-lbl{font-family:var(--hf);font-size:clamp(.75rem,1.8vw,1.05rem);
  letter-spacing:5px;text-transform:uppercase;color:var(--accent);opacity:.8;text-align:center}
.pj-dice{width:clamp(90px,12vw,150px);height:clamp(90px,12vw,150px);
  background:rgba(0,0,0,.6);border:3px solid var(--accent);border-radius:16px;padding:13px;
  box-shadow:0 0 50px var(--accent-glow),0 0 90px var(--accent-glow),inset 0 0 20px rgba(0,0,0,.5)}
.pj-dice.rolling{animation:pjDiceShake .12s linear infinite}
@keyframes pjDiceShake{
  0%  {transform:rotate(-14deg) scale(.88)}
  25% {transform:rotate(14deg)  scale(1.09)}
  50% {transform:rotate(-9deg)  scale(.93)}
  75% {transform:rotate(11deg)  scale(1.06)}
  100%{transform:rotate(0deg)   scale(1)}
}
.pj-die-grid{display:grid;grid-template-columns:repeat(3,1fr);
  grid-template-rows:repeat(3,1fr);width:100%;height:100%;gap:4px}
.pj-die-cell{display:flex;align-items:center;justify-content:center}
.pj-die-dot{width:clamp(12px,1.6vw,20px);height:clamp(12px,1.6vw,20px);
  background:var(--accent);border-radius:50%;
  box-shadow:0 0 8px var(--accent),0 0 18px var(--accent-glow)}
.pj-dice-num{display:none;font-family:var(--hf);font-weight:900;
  font-size:clamp(3rem,8vw,6.5rem);letter-spacing:10px;
  color:var(--accent);text-shadow:0 0 30px var(--accent),0 0 60px var(--accent-glow);line-height:1}
@keyframes pjDiceNumIn{
  0%  {transform:scale(0) rotate(-20deg);opacity:0}
  75% {transform:scale(1.12) rotate(3deg)}
  100%{transform:scale(1) rotate(0deg);opacity:1}
}

/* ══ PLAYER CARD ══════════════════════════════════════════════════════ */
#pj-card{position:absolute;inset:0;display:flex;opacity:0;
  transition:opacity .45s ease;pointer-events:none}
#pj-card.visible{opacity:1;pointer-events:all}

/* Serial number circle badge — top-right corner of the card */
#pjSerialBadge{
  position:absolute;top:18px;right:18px;z-index:30;
  width:clamp(72px,9vw,110px);height:clamp(72px,9vw,110px);
  border-radius:50%;
  background:var(--accent);
  display:none;flex-direction:column;align-items:center;justify-content:center;
  box-shadow:0 0 0 4px rgba(255,255,255,.15), 0 0 40px var(--glow), 0 6px 24px rgba(0,0,0,.6);
  border:3px solid rgba(255,255,255,.25);
  animation:pjBadgePop .5s cubic-bezier(.175,.885,.32,1.275) both}
@keyframes pjBadgePop{
  0%  {transform:scale(0) rotate(-20deg);opacity:0}
  70% {transform:scale(1.1) rotate(4deg)}
  100%{transform:scale(1) rotate(0deg);opacity:1}}
#pjSerialBadge .sl-no-lbl{
  font-family:var(--sf-body);font-size:clamp(.4rem,.9vw,.58rem);
  letter-spacing:2px;text-transform:uppercase;color:var(--bg);opacity:.7;margin-bottom:1px}
#pjSerialBadge .sl-no-val{
  font-family:var(--sf);font-size:clamp(1.6rem,3.8vw,3rem);font-weight:400;
  color:var(--bg);line-height:1}

/* Photo side */
.pj-photo-side{flex:0 0 45%;position:relative;overflow:hidden;background:var(--bg2)}
/* Blurred ambient background (same photo, dark+blurred) */
.pj-photo-bg{position:absolute;inset:0;background-size:cover;background-position:center;
  filter:blur(22px) brightness(0.28) saturate(0.6);transform:scale(1.12);z-index:0;display:none}
/* Foreground photo — contain so entire player is always visible */
.pj-photo{width:100%;height:100%;object-fit:contain;object-position:center bottom;
  display:block;position:relative;z-index:1}
.pj-photo-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;
  font-size:8rem;opacity:.15;position:relative;z-index:1}
/* Bottom gradient fade */
.pj-photo-side::after{content:'';position:absolute;inset:0;
  background:linear-gradient(to right,transparent 60%,var(--bg) 100%),
             linear-gradient(to top,var(--bg) 0%,transparent 30%);
  pointer-events:none}
/* Serial watermark */
.pj-serial-wm{position:absolute;bottom:16px;left:20px;
  font-family:var(--hf);font-size:clamp(3rem,8vw,6rem);font-weight:900;
  color:var(--accent);opacity:.09;line-height:1;pointer-events:none;z-index:2;
  text-shadow:0 0 40px var(--glow)}

/* Info side */
.pj-info-side{flex:1;display:flex;flex-direction:column;justify-content:center;
  padding:clamp(20px,4vw,60px) clamp(24px,5vw,72px) clamp(20px,4vw,60px) clamp(10px,2vw,32px);
  position:relative;z-index:2;overflow:hidden}
/* Accent glow behind info */
.pj-info-side::before{content:'';position:absolute;top:-20%;right:-10%;
  width:60%;height:140%;background:radial-gradient(ellipse,var(--glow) 0%,transparent 70%);
  opacity:.45;pointer-events:none}

.pj-serial{display:none}
.pj-name{font-family:var(--sf);font-size:clamp(2.4rem,6vw,5rem);font-weight:400;
  text-transform:uppercase;letter-spacing:4px;line-height:1;
  margin-bottom:14px;color:var(--tx)}
/* Tier + Role badges row */
.pj-badges{display:flex;flex-wrap:wrap;align-items:center;gap:10px;
  margin-bottom:clamp(16px,3vw,28px)}
.pj-tier{display:inline-block;font-family:var(--sf);font-size:clamp(.75rem,1.6vw,1.05rem);
  font-weight:400;padding:6px 22px;border-radius:30px;letter-spacing:3px;
  text-transform:uppercase;color:#fff}
.pj-role{display:inline-flex;align-items:center;gap:6px;
  font-family:var(--sf);font-size:clamp(.75rem,1.6vw,1.05rem);font-weight:400;
  padding:6px 20px;border-radius:30px;letter-spacing:3px;text-transform:uppercase;
  color:var(--accent);border:2px solid var(--accent);background:var(--glow)}

/* Stats grid */
.pj-stats{display:grid;grid-template-columns:1fr 1fr;gap:12px 20px;
  margin-bottom:clamp(20px,4vw,36px);max-width:500px}
.pj-stat{background:rgba(255,255,255,.05);border-radius:10px;padding:12px 16px;
  border:1px solid rgba(255,255,255,.08)}
.pj-stat-label{font-family:var(--sf-body);font-size:clamp(.55rem,1.2vw,.72rem);font-weight:700;
  letter-spacing:2px;text-transform:uppercase;color:var(--tx-d);margin-bottom:4px}
.pj-stat-val{font-family:var(--sf);font-size:clamp(.95rem,2vw,1.3rem);
  font-weight:400;letter-spacing:1px;color:var(--tx)}

/* Base price */
.pj-base{display:inline-flex;align-items:baseline;gap:8px;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  border-radius:12px;padding:12px 28px;margin-top:4px}
.pj-base-label{font-family:var(--sf);font-size:clamp(.65rem,1.3vw,.85rem);
  font-weight:400;letter-spacing:3px;text-transform:uppercase;color:rgba(0,0,0,.7)}
.pj-base-val{font-family:var(--sf);font-size:clamp(1.6rem,4vw,2.8rem);
  font-weight:400;letter-spacing:2px;color:var(--bg);line-height:1}
.pj-base-unit{font-size:clamp(.7rem,1.5vw,.9rem);font-weight:700;
  color:rgba(0,0,0,.6);align-self:flex-end;padding-bottom:3px}

/* ══ SOLD / UNSOLD STAMP ══════════════════════════════════════════════ */
/* ══ SOLD / UNSOLD OVERLAY ════════════════════════════════════════════ */
.pj-stamp-wrap{position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:clamp(12px,2.2vw,28px);
  pointer-events:none;z-index:20;
  background:rgba(0,0,0,.65);backdrop-filter:blur(5px);
  opacity:0;transition:opacity .4s}
.pj-stamp-wrap.show{opacity:1}
/* Wooden mallet — strikes in from upper-left */
.pj-gavel-svg{width:clamp(80px,11vw,128px);height:auto;display:block;
  filter:drop-shadow(0 6px 22px rgba(0,0,0,.75));
  animation:pjGavelIn .65s cubic-bezier(.34,1.2,.64,1) both}
@keyframes pjGavelIn{
  0%  {transform:rotate(-65deg) scale(0.5) translateY(-20px);opacity:0}
  62% {transform:rotate(-22deg) scale(1.07);opacity:1}
  80% {transform:rotate(-34deg)}
  100%{transform:rotate(-28deg) scale(1);opacity:1}
}
/* Horizontal verdict pill */
.pj-verdict-row{display:flex;flex-direction:row;align-items:stretch;border-radius:18px;
  box-shadow:0 0 70px rgba(0,0,0,.65),0 10px 36px rgba(0,0,0,.5);
  animation:pjVerdictIn .45s cubic-bezier(.34,1.2,.64,1) .18s both}
@keyframes pjVerdictIn{from{transform:scale(0.65);opacity:0}to{transform:scale(1);opacity:1}}
/* Left half — verdict word */
.pj-stamp{font-family:var(--hf);font-size:clamp(1.8rem,5.5vw,4.5rem);font-weight:900;
  letter-spacing:8px;padding:clamp(14px,2.5vw,22px) clamp(22px,4vw,48px);
  text-shadow:0 2px 8px rgba(0,0,0,.4);flex-shrink:0;line-height:1;
  border-radius:18px 0 0 18px}
.pj-stamp.sold  {background:linear-gradient(135deg,#B8860B 0%,#DAA520 50%,#F5C842 100%);color:#1a0d00}
.pj-stamp.unsold{background:linear-gradient(135deg,#8B0000 0%,#DC143C 55%,#FF3A3A 100%);
  color:#fff;border-radius:18px}   /* full radius when no team section */
/* Right half — sold-to team */
.pj-sold-team{display:none;flex-direction:row;align-items:center;
  gap:clamp(12px,2.2vw,22px);
  background:rgba(0,0,0,.82);border-radius:0 18px 18px 0;
  border-left:3px solid rgba(218,165,32,.5);
  padding:clamp(12px,2vw,22px) clamp(18px,3.5vw,42px);
  opacity:0;transform:translateX(18px);
  transition:opacity .5s .42s,transform .5s .42s}
.pj-sold-team.show{opacity:1;transform:translateX(0)}
.pj-sold-team-logo{width:clamp(52px,8vw,82px);height:clamp(52px,8vw,82px);
  object-fit:contain;border-radius:50%;flex-shrink:0;
  background:rgba(255,255,255,.08);padding:5px;
  box-shadow:0 0 20px rgba(218,165,32,.5),0 0 0 2px rgba(218,165,32,.35)}
.pj-sold-team-info{display:flex;flex-direction:column;gap:2px}
.pj-sold-team-label{font-family:var(--hf);font-size:clamp(.5rem,1vw,.68rem);
  font-weight:700;letter-spacing:4px;text-transform:uppercase;color:rgba(218,165,32,.65)}
.pj-sold-team-name{font-family:var(--hf);font-size:clamp(1rem,3vw,2.2rem);
  font-weight:900;letter-spacing:2px;text-transform:uppercase;
  color:#DAA520;text-shadow:0 0 22px rgba(218,165,32,.65);
  line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pj-sold-pts{font-family:var(--hf);font-size:clamp(1.1rem,2.8vw,2.2rem);
  font-weight:900;letter-spacing:3px;line-height:1;color:#fff}
.pj-sold-pts .pts-num{color:#FFD700;text-shadow:0 0 22px rgba(255,215,0,.65)}
.pj-sold-pts .pts-unit{font-size:clamp(.6rem,1.5vw,1.1rem);color:rgba(255,255,255,.55);
  margin-left:4px;vertical-align:middle}

/* ══ RESPONSIVE ═══════════════════════════════════════════════════════ */
@media(max-width:768px){
  #pj-bar{padding:8px 14px}
  .pj-tname{font-size:.85rem;letter-spacing:2px}
  .pj-photo-side{flex:0 0 40%}
  .pj-info-side{padding:16px 20px 16px 12px}
  .pj-stats{grid-template-columns:1fr;gap:8px}
  .pj-stamp{font-size:clamp(1.5rem,6vw,3.5rem);padding:10px 22px}
}
@media(max-width:480px){
  #pj-card{flex-direction:column}
  .pj-photo-side{flex:0 0 45vh}
  .pj-photo-side::after{background:linear-gradient(to bottom,transparent 60%,var(--bg) 100%)}
  .pj-info-side{padding:12px 16px;overflow-y:auto}
  .pj-name{font-size:clamp(2rem,7vw,3rem)}
  .pj-badges{gap:6px}
  .pj-tier,.pj-role{font-size:clamp(.65rem,1.8vw,.9rem);padding:4px 14px}
}
  </style>
</head>
<body>
<script>
  window.PJ_DB   = '<t t-esc="db_name or ''"/>';
  window.PJ_SLUG = '<t t-esc="tournament_slug or (tournament.slug if tournament else '')"/>';
  window.PJ_DATA_URL = '/' + PJ_DB + '/auction/projector/' + PJ_SLUG + '/data';
</script>

