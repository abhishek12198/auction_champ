<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="auction_details_show" name="Player Auction">
  <html lang="en" t-att-data-theme="theme"
        t-att-data-balance-json-url="'/' + (db_name or '') + '/' + (tournament_slug or '') + '/auction/show/team/balance/json'">
    <head>
      <meta charset="UTF-8"/>
      <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
      <link rel="shortcut icon" t-att-href="'/web/image/res.company/%d/favicon' % res_company.id" type="image/x-icon"/>
      <link href="/auction_module/static/src/assets/css/bootstrap.min.css" rel="stylesheet"/>
      <link rel="preconnect" href="https://fonts.googleapis.com"/>
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="1"/>
      <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700;900&amp;family=Barlow+Condensed:wght@400;500;600;700;800&amp;family=Teko:wght@500;600;700&amp;display=swap"
            rel="stylesheet" media="print" onload="this.media='all'"/>
      <noscript><link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700;900&amp;family=Barlow+Condensed:wght@400;500;600;700;800&amp;family=Teko:wght@500;600;700&amp;display=swap" rel="stylesheet"/></noscript>
      <title>Auction Bid Summary</title>
      <style>
        
        :root,
        [data-theme="vanilla"] {
          --bg:#050c1a; --bg2:#0b1529; --bg3:#0d1f3c;
          --acc:#E8A020; --acc2:#FFD166; --glow:rgba(232,160,32,.30);
          --bdr:rgba(232,160,32,.18); --bdr2:rgba(255,255,255,.08);
          --tx:#EEF4FF; --tx-d:rgba(238,244,255,.55); --tx-m:rgba(238,244,255,.30);
          --hf:'Orbitron',sans-serif; --bf:'Barlow Condensed',sans-serif; --nf:'Teko',sans-serif;
          --card-bg:rgba(11,21,41,.85); --card-bdr:rgba(232,160,32,.15);
        }
        [data-theme="butterscotch"] {
          --bg:#06060f; --bg2:#0f0f20; --bg3:#1a1430;
          --acc:#F5C842; --acc2:#FF9F1C; --glow:rgba(245,200,66,.30);
          --bdr:rgba(245,200,66,.18); --bdr2:rgba(255,255,255,.08);
          --tx:#fff; --tx-d:rgba(255,255,255,.55); --tx-m:rgba(255,255,255,.30);
          --hf:'Teko',sans-serif; --bf:'Barlow Condensed',sans-serif; --nf:'Teko',sans-serif;
          --card-bg:rgba(15,15,32,.85); --card-bdr:rgba(245,200,66,.15);
        }
        [data-theme="strawberry"] {
          --bg:#0d0610; --bg2:#1a0a18; --bg3:#26102a;
          --acc:#E91E63; --acc2:#F48FB1; --glow:rgba(233,30,99,.30);
          --bdr:rgba(233,30,99,.20); --bdr2:rgba(255,255,255,.08);
          --tx:#FFF0F5; --tx-d:rgba(255,240,245,.55); --tx-m:rgba(255,240,245,.30);
          --hf:'Orbitron',sans-serif; --bf:'Barlow Condensed',sans-serif; --nf:'Teko',sans-serif;
          --card-bg:rgba(26,10,24,.85); --card-bdr:rgba(233,30,99,.15);
        }
        [data-theme="cherry"] {
          --bg:#0d0000; --bg2:#1a0508; --bg3:#2a080e;
          --acc:#DC143C; --acc2:#FF6B6B; --glow:rgba(220,20,60,.30);
          --bdr:rgba(220,20,60,.20); --bdr2:rgba(255,255,255,.08);
          --tx:#FFF5F5; --tx-d:rgba(255,245,245,.55); --tx-m:rgba(255,245,245,.30);
          --hf:'Orbitron',sans-serif; --bf:'Barlow Condensed',sans-serif; --nf:'Teko',sans-serif;
          --card-bg:rgba(26,5,8,.85); --card-bdr:rgba(220,20,60,.15);
        }

        * { box-sizing: border-box; }
        html { min-height: 100%; background: var(--bg); }
        body {
          margin: 0;
          min-height: 100vh;
          background:
            radial-gradient(circle at 12% 18%, var(--glow) 0, transparent 28%),
            radial-gradient(circle at 88% 10%, rgba(255,255,255,.05) 0, transparent 22%),
            linear-gradient(180deg, var(--bg) 0%, var(--bg2) 45%, var(--bg3) 100%);
          color: var(--tx);
          font-family: var(--bf);
          font-weight: 700;
          letter-spacing: .02em;
          overflow-x: hidden;
        }
        body::before {
          content: '';
          position: fixed;
          inset: 0;
          pointer-events: none;
          background:
            linear-gradient(120deg, rgba(255,255,255,.03) 0%, transparent 22%, transparent 78%, rgba(255,255,255,.02) 100%),
            repeating-linear-gradient(180deg, rgba(255,255,255,.015) 0 1px, transparent 1px 52px);
          opacity: .55;
        }
        a { color: inherit; text-decoration: none; }
        button { font: inherit; color: inherit; }
        img { display: block; max-width: 100%; }

        .bs2-hdr {
          position: fixed;
          top: 0;
          left: 0;
          right: 0;
          z-index: 100;
          height: 68px;
          padding: 0 18px;
          display: grid;
          grid-template-columns: minmax(0, 1.3fr) auto minmax(0, 1fr);
          align-items: center;
          gap: 14px;
          background: linear-gradient(135deg, rgba(4,10,22,.94), rgba(9,18,34,.90));
          border-bottom: 1px solid var(--bdr2);
          backdrop-filter: blur(16px);
          box-shadow: 0 16px 32px rgba(0,0,0,.35);
        }
        .bs2-hdr-side {
          display: flex;
          align-items: center;
          gap: 12px;
          min-width: 0;
        }
        .bs2-left { justify-content: flex-start; }
        .bs2-right { justify-content: flex-end; }
        .bs2-back-btn,
        .bs2-toggle-btn,
        .bs2-fs-btn,
        .bs2-engage {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          gap: 8px;
          border-radius: 999px;
          border: 1px solid var(--bdr);
          background: rgba(255,255,255,.05);
          box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 10px 24px rgba(0,0,0,.18);
          transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease, background .2s ease;
          white-space: nowrap;
        }
        .bs2-back-btn,
        .bs2-fs-btn {
          height: 40px;
          padding: 0 16px;
          font-size: .92rem;
          text-transform: uppercase;
          letter-spacing: .11em;
        }
        .bs2-back-btn:hover,
        .bs2-toggle-btn:hover,
        .bs2-fs-btn:hover,
        .bs2-engage:hover {
          transform: translateY(-1px);
          border-color: rgba(255,255,255,.22);
          box-shadow: 0 12px 30px rgba(0,0,0,.22), 0 0 0 1px var(--bdr);
        }
        .bs2-back-btn {
          color: var(--tx);
          background: linear-gradient(135deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
        }
        .bs2-t-logo {
          width: 44px;
          height: 44px;
          border-radius: 14px;
          object-fit: cover;
          border: 1px solid var(--bdr);
          box-shadow: 0 0 0 3px rgba(255,255,255,.03), 0 10px 24px rgba(0,0,0,.20);
          flex: 0 0 auto;
        }
        .bs2-t-meta {
          min-width: 0;
          display: flex;
          flex-direction: column;
          gap: 1px;
        }
        .bs2-t-name {
          font-family: var(--hf);
          font-size: 1.15rem;
          font-weight: 900;
          letter-spacing: .08em;
          color: var(--tx);
          text-transform: uppercase;
          line-height: 1;
          overflow: hidden;
          text-overflow: ellipsis;
          white-space: nowrap;
        }
        .bs2-t-desc {
          font-size: .78rem;
          letter-spacing: .12em;
          color: var(--tx-d);
          text-transform: uppercase;
          overflow: hidden;
          text-overflow: ellipsis;
          white-space: nowrap;
        }
        .bs2-title-wrap {
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 2px;
          text-align: center;
        }
        .bs2-title {
          font-family: var(--hf);
          font-weight: 900;
          letter-spacing: .16em;
          font-size: 1.42rem;
          line-height: 1;
          text-transform: uppercase;
        }
        .bs2-live {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          font-size: .8rem;
          letter-spacing: .24em;
          color: var(--acc2);
          text-transform: uppercase;
        }
        .bs2-live-dot {
          width: 9px;
          height: 9px;
          border-radius: 50%;
          background: var(--acc2);
          box-shadow: 0 0 0 0 var(--glow);
          animation: livePulse 1.4s ease-in-out infinite;
        }
        .bs2-view-toggle {
          display: inline-flex;
          align-items: center;
          padding: 4px;
          border-radius: 999px;
          background: rgba(255,255,255,.05);
          border: 1px solid var(--bdr);
          box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
        }
        .bs2-toggle-btn {
          min-width: 88px;
          height: 34px;
          padding: 0 16px;
          border: 0;
          background: transparent;
          font-size: .9rem;
          letter-spacing: .16em;
          text-transform: uppercase;
          color: var(--tx-d);
          box-shadow: none;
        }
        .bs2-toggle-btn.active {
          background: linear-gradient(135deg, var(--acc), var(--acc2));
          color: #07101f;
          border-color: transparent;
          box-shadow: 0 8px 18px var(--glow);
        }
        .bs2-v-divider {
          width: 1px;
          height: 34px;
          background: linear-gradient(180deg, transparent, var(--bdr2), transparent);
        }
        .bs2-fs-btn {
          border: 1px solid var(--bdr);
        }
        .bs2-fs-ico {
          font-size: 1rem;
          line-height: 1;
        }
        .bs2-main {
          position: relative;
          z-index: 1;
          padding: 76px 16px 18px;
        }
        .bs2-panel {
          width: 100%;
          margin: 0 auto;
        }
        .bs2-table-wrap {
          overflow-x: auto;
          padding-bottom: 4px;
        }
        .bs2-table {
          width: 100%;
          border-collapse: separate;
          border-spacing: 0 6px;
          min-width: 1140px;
        }
        .bs2-table thead th {
          padding: 8px 12px;
          font-family: var(--hf);
          font-size: .78rem;
          letter-spacing: .18em;
          color: var(--tx-d);
          text-transform: uppercase;
          white-space: nowrap;
        }
        .bs2-row {
          transition: transform .2s ease, box-shadow .2s ease;
        }
        .bs2-row:hover {
          transform: translateX(2px);
          box-shadow: -3px 0 0 var(--acc), 0 16px 28px rgba(0,0,0,.18);
        }
        .bs2-row td {
          padding: 12px;
          background: var(--card-bg);
          border-top: 1px solid var(--card-bdr);
          border-bottom: 1px solid var(--card-bdr);
          vertical-align: middle;
          backdrop-filter: blur(18px);
        }
        .bs2-row td:first-child {
          border-left: 1px solid var(--card-bdr);
          border-radius: 18px 0 0 18px;
        }
        .bs2-row td:last-child {
          border-right: 1px solid var(--card-bdr);
          border-radius: 0 18px 18px 0;
        }
        .bs2-team-cell,
        .bs2-card-head {
          display: flex;
          align-items: center;
          gap: 12px;
          min-width: 0;
        }
        .bs2-team-logo,
        .bs2-card-logo,
        .bs2-logo-fallback {
          width: 52px;
          height: 52px;
          border-radius: 16px;
          object-fit: cover;
          border: 1px solid var(--bdr);
          background: linear-gradient(135deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
          box-shadow: 0 12px 22px rgba(0,0,0,.16);
          flex: 0 0 auto;
        }
        .bs2-logo-fallback {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          font-family: var(--hf);
          font-size: 1.05rem;
          color: var(--acc2);
          text-transform: uppercase;
        }
        .bs2-team-copy,
        .bs2-card-copy {
          min-width: 0;
          display: flex;
          flex-direction: column;
          gap: 3px;
        }
        .bs2-team-name,
        .bs2-card-name {
          font-family: var(--hf);
          font-weight: 900;
          letter-spacing: .08em;
          line-height: .95;
          text-transform: uppercase;
        }
        .bs2-team-name {
          font-size: 1.22rem;
        }
        .bs2-card-name {
          font-size: 0.92rem;
        }
        .bs2-manager,
        .bs2-card-manager {
          color: var(--tx-d);
          font-size: .82rem;
          letter-spacing: .12em;
          text-transform: uppercase;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }
        .bs2-purse-stack,
        .bs2-card-purse {
          display: flex;
          flex-direction: column;
          gap: 8px;
        }
        .bs2-overline {
          font-family: var(--hf);
          font-size: .7rem;
          letter-spacing: .18em;
          color: var(--tx-d);
          text-transform: uppercase;
        }
        .bs2-purse-line,
        .bs2-card-purse-line,
        .bs2-maxcall {
          display: inline-flex;
          align-items: flex-end;
          gap: 8px;
          line-height: .9;
        }
        .bs2-purse-value,
        .bs2-maxcall-value,
        .bs2-players-number,
        .bs2-squad-value,
        .bs2-card-purse-value,
        .bs2-stat-figure {
          font-family: var(--nf);
          font-weight: 700;
          letter-spacing: .04em;
        }
        .bs2-purse-value,
        .bs2-maxcall-value {
          font-size: 2.65rem;
        }
        .bs2-card-purse-value {
          font-size: 3.28rem;
        }
        .bs2-unit {
          font-size: 1rem;
          color: var(--tx-d);
          letter-spacing: .16em;
          text-transform: uppercase;
          margin-bottom: 5px;
        }
        .bs2-progress {
          height: 10px;
          border-radius: 999px;
          overflow: hidden;
          background: rgba(255,255,255,.08);
          border: 1px solid rgba(255,255,255,.06);
          box-shadow: inset 0 2px 8px rgba(0,0,0,.22);
        }
        .bs2-progress.bs2-progress-lg {
          height: 8px;
        }
        .bs2-progress-fill {
          height: 100%;
          width: 0;
          border-radius: inherit;
          transition: width .8s cubic-bezier(.4,0,.2,1), filter .2s ease;
          box-shadow: 0 0 16px rgba(255,255,255,.12);
        }
        .pf-high { background: linear-gradient(90deg,#16a34a,#4ade80); }
        .pf-mid  { background: linear-gradient(90deg,#ca8a04,#fde047); }
        .pf-low  { background: linear-gradient(90deg,#ea580c,#fb923c); }
        .pf-crit { background: linear-gradient(90deg,#dc2626,#f87171); }
        .bs2-pct-label {
          font-size: .82rem;
          letter-spacing: .12em;
          color: var(--tx-d);
          text-transform: uppercase;
        }
        .bs2-needed-chip {
          min-width: 92px;
          padding: 12px 16px;
          border-radius: 18px;
          display: inline-flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.04));
          border: 1px solid var(--bdr2);
          box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
        }
        .bs2-players-number,
        .bs2-squad-value,
        .bs2-stat-figure {
          font-size: 2.15rem;
          line-height: .9;
        }
        .bs2-chip-label,
        .bs2-stat-label {
          margin-top: 4px;
          font-size: .68rem;
          letter-spacing: .18em;
          text-transform: uppercase;
          color: var(--tx-d);
          white-space: nowrap;
        }
        .bs2-squad-wrap {
          display: inline-flex;
          flex-direction: column;
          gap: 4px;
        }
        .bs2-badge {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          min-width: 132px;
          padding: 8px 14px;
          border-radius: 999px;
          font-family: var(--hf);
          font-size: .76rem;
          font-weight: 900;
          letter-spacing: .12em;
          text-transform: uppercase;
          white-space: nowrap;
        }
        .comfortable { background:rgba(22,163,74,.12); color:#4ade80; border:1.5px solid rgba(22,163,74,.35); }
        .healthy     { background:rgba(20,184,166,.12); color:#2dd4bf; border:1.5px solid rgba(20,184,166,.35); }
        .balanced    { background:rgba(202,138,4,.12); color:#fde047; border:1.5px solid rgba(202,138,4,.35); }
        .tight       { background:rgba(234,88,12,.12); color:#fb923c; border:1.5px solid rgba(234,88,12,.35); }
        .critical    { background:rgba(220,38,38,.12); color:#f87171; border:1.5px solid rgba(220,38,38,.4); animation: badgePulse 1.2s ease-in-out infinite; }
        .bs2-access-cell {
          text-align: right;
        }
        .bs2-engage {
          height: 42px;
          padding: 0 18px;
          border-color: rgba(255,255,255,.12);
          background: linear-gradient(135deg, var(--acc), var(--acc2));
          color: #07101f;
          font-size: .92rem;
          letter-spacing: .12em;
          text-transform: uppercase;
          font-weight: 900;
        }
        .bs2-grid {
          display: grid;
          grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
          gap: 14px;
        }
        .bs2-card {
          position: relative;
          overflow: hidden;
          min-height: 100%;
          border-radius: 24px;
          border: 1px solid var(--card-bdr);
          background: var(--card-bg);
          backdrop-filter: blur(22px);
          box-shadow: 0 16px 34px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.06);
          transition: transform .2s, box-shadow .2s;
        }
        .bs2-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 24px 42px rgba(0,0,0,.28), 0 0 0 1px var(--bdr);
        }
        .bs2-card-accent {
          height: 3px;
          background: var(--acc);
          box-shadow: 0 0 24px var(--glow);
        }
        .bs2-card-body {
          padding: 16px;
          display: flex;
          flex-direction: column;
          gap: 16px;
        }
        .bs2-card-head {
          justify-content: flex-start;
          align-items: center;
          flex-wrap: nowrap;
        }
        .bs2-card-head .bs2-team-cell {
          flex: 1 1 0;
          min-width: 0;
        }
        .bs2-card-copy {
          flex: 1 1 0;
          min-width: 0;
        }
        .bs2-card-name {
          white-space: normal;
          overflow: visible;
          text-overflow: unset;
          word-break: break-word;
        }
        .bs2-card-status {
          flex-shrink: 0;
        }
        .bs2-card-foot {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 8px;
        }
        .bs2-card-stats {
          display: grid;
          grid-template-columns: repeat(3, minmax(0, 1fr));
          gap: 0;
          border-top: 1px solid rgba(255,255,255,.06);
          border-bottom: 1px solid rgba(255,255,255,.06);
          background: rgba(255,255,255,.03);
          border-radius: 18px;
          overflow: hidden;
        }
        .bs2-stat-col {
          padding: 14px 10px;
          text-align: center;
        }
        .bs2-stat-col + .bs2-stat-col {
          border-left: 1px solid rgba(255,255,255,.08);
        }
        .bs2-flash {
          animation: flashUpdate .85s ease;
          border-radius: 12px;
        }
        @keyframes livePulse {
          0% { transform: scale(.92); opacity: .62; box-shadow: 0 0 0 0 var(--glow); }
          70% { transform: scale(1.08); opacity: 1; box-shadow: 0 0 0 10px rgba(255,255,255,0); }
          100% { transform: scale(.92); opacity: .62; box-shadow: 0 0 0 0 rgba(255,255,255,0); }
        }
        @keyframes badgePulse {
          0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(220,38,38,.18); }
          50% { transform: scale(1.04); box-shadow: 0 0 0 10px rgba(220,38,38,0); }
        }
        @keyframes flashUpdate {
          0% { background-color: rgba(255,255,255,0); box-shadow: 0 0 0 0 rgba(255,255,255,0); }
          35% { background-color: rgba(255,255,255,.16); box-shadow: 0 0 0 6px rgba(255,255,255,.05); }
          100% { background-color: rgba(255,255,255,0); box-shadow: 0 0 0 0 rgba(255,255,255,0); }
        }
        @media (max-width: 1180px) {
          .bs2-hdr {
            height: auto;
            padding: 12px 16px;
            grid-template-columns: 1fr;
            gap: 12px;
          }
          .bs2-title-wrap { order: -1; }
          .bs2-right,
          .bs2-left { justify-content: center; }
          .bs2-main { padding-top: 160px; }
        }
        @media (max-width: 680px) {
          .bs2-main { padding-left: 10px; padding-right: 10px; }
          .bs2-grid { grid-template-columns: 1fr; }
          .bs2-card-head { flex-wrap: wrap; }
          .bs2-card-status { margin-left: 0; }
          .bs2-toggle-btn { min-width: 76px; }
          .bs2-back-btn,
          .bs2-fs-btn { padding: 0 12px; }
        }
      </style>
    </head>
    <body>
      <header class="bs2-hdr">
        <div class="bs2-hdr-side bs2-left">
          <a class="bs2-back-btn" t-att-href="'/' + db_name + '/auction/projector/' + tournament_slug + '/'">&#8592; PROJECTOR</a>
          <t t-if="tournament and tournament.logo">
            <img class="bs2-t-logo" t-att-src="image_data_uri(tournament.logo)" alt="Tournament logo"/>
          </t>
          <div class="bs2-t-meta">
            <div class="bs2-t-name"><t t-esc="tournament.name if tournament and tournament.name else 'Auction Tournament'"/></div>
            <div class="bs2-t-desc"><t t-esc="tournament.description if tournament and tournament.description else 'Live bid summary dashboard'"/></div>
          </div>
        </div>
        <div class="bs2-title-wrap">
          <div class="bs2-title">BID SUMMARY</div>
          <div class="bs2-live"><span class="bs2-live-dot"></span><span>LIVE</span></div>
        </div>
        <div class="bs2-hdr-side bs2-right">
          <div class="bs2-view-toggle" role="tablist" aria-label="View toggle">
            <button type="button" id="btn-list" class="bs2-toggle-btn active" aria-pressed="true">LIST</button>
            <button type="button" id="btn-grid" class="bs2-toggle-btn" aria-pressed="false">GRID</button>
          </div>
          <div class="bs2-v-divider"></div>
          <button type="button" class="bs2-fs-btn" id="fs-btn" aria-label="Toggle fullscreen"><span class="bs2-fs-ico">⛶</span><span class="bs2-fs-tx">FULL</span></button>
        </div>
      </header>

      <main class="bs2-main">
        <div class="bs2-panel" id="list-section">
          <div class="bs2-table-wrap">
            <table class="bs2-table">
              <thead>
                <tr>
                  <th>Team</th>
                  <th>Purse</th>
                  <th>Needed</th>
                  <th>Max Bid</th>
                  <th>Squad</th>
                  <th>Status</th>
                  <t t-if="type == 'internal'"><th>Access</th></t>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="teams" t-as="team">
                  <t t-set="purse_pct" t-value="int(team.remaining_points * 100 // team.total_point) if team.total_point else 0"/>
                  <t t-set="purse_cls" t-value="'pf-high' if purse_pct &gt;= 60 else ('pf-mid' if purse_pct &gt;= 30 else ('pf-low' if purse_pct &gt;= 10 else 'pf-crit'))"/>
                  <t t-set="status_label" t-value="'COMFORTABLE' if purse_pct &gt;= 60 else ('HEALTHY' if purse_pct &gt;= 40 else ('BALANCED' if purse_pct &gt;= 25 else ('TIGHT' if purse_pct &gt;= 10 else 'CRITICAL')))"/>
                  <t t-set="status_cls" t-value="'comfortable' if purse_pct &gt;= 60 else ('healthy' if purse_pct &gt;= 40 else ('balanced' if purse_pct &gt;= 25 else ('tight' if purse_pct &gt;= 10 else 'critical')))"/>
                  <t t-set="players_recruited" t-value="team.max_players - team.remaining_players_count"/>
                  <tr class="bs2-row" t-attf-data-auction-id="#{team.id}" t-attf-data-total-pts="#{team.total_point}" t-attf-data-max-players="#{team.max_players}">
                    <td>
                      <div class="bs2-team-cell">
                        <t t-if="team.team_id.logo">
                          <img class="bs2-team-logo" t-att-src="image_data_uri(team.team_id.logo)" t-att-alt="team.team_id.name"/>
                        </t>
                        <t t-else="">
                          <span class="bs2-logo-fallback"><t t-esc="(team.team_id.name or '')[:1]"/></span>
                        </t>
                        <div class="bs2-team-copy">
                          <div class="bs2-team-name"><t t-esc="team.team_id.name"/></div>
                          <div class="bs2-manager"><t t-esc="team.manager or 'Team Manager'"/></div>
                        </div>
                      </div>
                    </td>
                    <td>
                      <div class="bs2-purse-stack">
                        <div class="bs2-purse-line">
                          <span class="bs2-purse-value" t-attf-id="team-points-#{team.id}"><t t-esc="team.remaining_points"/></span>
                          <span class="bs2-unit">pts</span>
                        </div>
                        <div class="bs2-progress">
                          <div data-role="purse-fill" t-attf-class="bs2-progress-fill #{purse_cls}" t-attf-style="width:#{purse_pct}%"></div>
                        </div>
                        <div class="bs2-pct-label" data-role="pct-label"><t t-esc="str(purse_pct) + '% remaining'"/></div>
                      </div>
                    </td>
                    <td>
                      <div class="bs2-needed-chip">
                        <span class="bs2-players-number" t-attf-id="team-players-#{team.id}"><t t-esc="team.remaining_players_count"/></span>
                        <span class="bs2-chip-label">players</span>
                      </div>
                    </td>
                    <td>
                      <div class="bs2-maxcall">
                        <span class="bs2-maxcall-value" t-attf-id="team-maxcall-#{team.id}"><t t-esc="team.max_call"/></span>
                        <span class="bs2-unit">pts</span>
                      </div>
                    </td>
                    <td>
                      <div class="bs2-squad-wrap">
                        <span class="bs2-squad-value" data-role="squad-value"><t t-esc="str(players_recruited) + ' / ' + str(team.max_players)"/></span>
                        <span class="bs2-chip-label">recruited</span>
                      </div>
                    </td>
                    <td>
                      <span data-role="status-badge" data-base-class="bs2-badge" t-attf-class="bs2-badge #{status_cls}"><t t-esc="status_label"/></span>
                    </td>
                    <t t-if="type == 'internal'">
                      <td class="bs2-access-cell">
                        <a t-att-href="'/auction/get/players/team/%s' % team.team_id.id" class="bs2-engage">&#9654; ENGAGE</a>
                      </td>
                    </t>
                  </tr>
                </t>
              </tbody>
            </table>
          </div>
        </div>

        <div class="bs2-panel" id="grid-section" style="display:none">
          <div class="bs2-grid">
            <t t-foreach="teams" t-as="team">
              <t t-set="purse_pct" t-value="int(team.remaining_points * 100 // team.total_point) if team.total_point else 0"/>
              <t t-set="purse_cls" t-value="'pf-high' if purse_pct &gt;= 60 else ('pf-mid' if purse_pct &gt;= 30 else ('pf-low' if purse_pct &gt;= 10 else 'pf-crit'))"/>
              <t t-set="status_label" t-value="'COMFORTABLE' if purse_pct &gt;= 60 else ('HEALTHY' if purse_pct &gt;= 40 else ('BALANCED' if purse_pct &gt;= 25 else ('TIGHT' if purse_pct &gt;= 10 else 'CRITICAL')))"/>
              <t t-set="status_cls" t-value="'comfortable' if purse_pct &gt;= 60 else ('healthy' if purse_pct &gt;= 40 else ('balanced' if purse_pct &gt;= 25 else ('tight' if purse_pct &gt;= 10 else 'critical')))"/>
              <t t-set="players_recruited" t-value="team.max_players - team.remaining_players_count"/>
              <div class="bs2-card" t-attf-data-auction-id="#{team.id}" t-attf-data-total-pts="#{team.total_point}" t-attf-data-max-players="#{team.max_players}">
                <div class="bs2-card-accent"></div>
                <div class="bs2-card-body">
                  <div class="bs2-card-head">
                    <div class="bs2-team-cell">
                      <t t-if="team.team_id.logo">
                        <img class="bs2-card-logo" t-att-src="image_data_uri(team.team_id.logo)" t-att-alt="team.team_id.name"/>
                      </t>
                      <t t-else="">
                        <span class="bs2-logo-fallback"><t t-esc="(team.team_id.name or '')[:1]"/></span>
                      </t>
                      <div class="bs2-card-copy">
                        <div class="bs2-card-name"><t t-esc="team.team_id.name"/></div>
                        <div class="bs2-card-manager"><t t-esc="team.manager or 'Team Manager'"/></div>
                      </div>
                    </div>
                  </div>

                  <div class="bs2-card-purse">
                    <div class="bs2-overline">Purse Remaining</div>
                    <div class="bs2-card-purse-line">
                      <span class="bs2-card-purse-value" t-attf-id="grid-team-points-#{team.id}"><t t-esc="team.remaining_points"/></span>
                      <span class="bs2-unit">pts</span>
                    </div>
                    <div class="bs2-progress bs2-progress-lg">
                      <div data-role="purse-fill" t-attf-class="bs2-progress-fill #{purse_cls}" t-attf-style="width:#{purse_pct}%"></div>
                    </div>
                    <div class="bs2-pct-label" data-role="pct-label"><t t-esc="str(purse_pct) + '% remaining'"/></div>
                  </div>

                  <div class="bs2-card-stats">
                    <div class="bs2-stat-col">
                      <div class="bs2-stat-label">Players Needed</div>
                      <div class="bs2-stat-figure" t-attf-id="grid-team-players-#{team.id}"><t t-esc="team.remaining_players_count"/></div>
                    </div>
                    <div class="bs2-stat-col">
                      <div class="bs2-stat-label">Max Bid</div>
                      <div class="bs2-stat-figure"><span t-attf-id="grid-team-maxcall-#{team.id}"><t t-esc="team.max_call"/></span><span class="bs2-unit"> pts</span></div>
                    </div>
                    <div class="bs2-stat-col">
                      <div class="bs2-stat-label">Squad</div>
                      <div class="bs2-stat-figure" data-role="squad-value"><t t-esc="str(players_recruited) + ' / ' + str(team.max_players)"/></div>
                    </div>
                  </div>

                  <div class="bs2-card-foot">
                    <span data-role="status-badge" data-base-class="bs2-badge bs2-card-status" t-attf-class="bs2-badge bs2-card-status #{status_cls}"><t t-esc="status_label"/></span>
                    <t t-if="type == 'internal'">
                      <a t-att-href="'/auction/get/players/team/%s' % team.team_id.id" class="bs2-engage">&#9654; ENGAGE</a>
                    </t>
                  </div>
                </div>
              </div>
            </t>
          </div>
        </div>
      </main>

      <script><![CDATA[
        (function () {
          var htmlEl = document.documentElement;
          var listBtn = document.getElementById('btn-list');
          var gridBtn = document.getElementById('btn-grid');
          var listSection = document.getElementById('list-section');
          var gridSection = document.getElementById('grid-section');
          var fsBtn = document.getElementById('fs-btn');
          var fsIcon = fsBtn ? fsBtn.querySelector('.bs2-fs-ico') : null;
          var fsText = fsBtn ? fsBtn.querySelector('.bs2-fs-tx') : null;
          var balanceUrl = htmlEl.getAttribute('data-balance-json-url') || '';
          var _balanceTimer = null;

          function asNumber(value) {
            var num = Number(value);
            return isFinite(num) ? num : 0;
          }

          function flashUpdate(element) {
            if (!element) {
              return;
            }
            element.classList.remove('bs2-flash');
            void element.offsetWidth;
            element.classList.add('bs2-flash');
            window.clearTimeout(element._flashTimer);
            element._flashTimer = window.setTimeout(function () {
              element.classList.remove('bs2-flash');
            }, 850);
          }

          function purseClass(pct) {
            if (pct >= 60) { return 'pf-high'; }
            if (pct >= 30) { return 'pf-mid'; }
            if (pct >= 10) { return 'pf-low'; }
            return 'pf-crit';
          }

          function statusMeta(pct) {
            if (pct >= 60) { return { label: 'COMFORTABLE', cls: 'comfortable' }; }
            if (pct >= 40) { return { label: 'HEALTHY', cls: 'healthy' }; }
            if (pct >= 25) { return { label: 'BALANCED', cls: 'balanced' }; }
            if (pct >= 10) { return { label: 'TIGHT', cls: 'tight' }; }
            return { label: 'CRITICAL', cls: 'critical' };
          }

          function setView(mode) {
            var isList = mode === 'list';
            if (listSection) { listSection.style.display = isList ? '' : 'none'; }
            if (gridSection) { gridSection.style.display = isList ? 'none' : ''; }
            if (listBtn) {
              listBtn.classList.toggle('active', isList);
              listBtn.setAttribute('aria-pressed', isList ? 'true' : 'false');
            }
            if (gridBtn) {
              gridBtn.classList.toggle('active', !isList);
              gridBtn.setAttribute('aria-pressed', isList ? 'false' : 'true');
            }
          }

          function syncFullscreenButton() {
            var active = !!document.fullscreenElement;
            if (fsIcon) { fsIcon.textContent = active ? '✕' : '⛶'; }
            if (fsText) { fsText.textContent = active ? 'EXIT' : 'FULL'; }
            if (fsBtn) { fsBtn.setAttribute('aria-label', active ? 'Exit fullscreen' : 'Enter fullscreen'); }
          }

          function updateValueById(id, value) {
            var element = document.getElementById(id);
            var nextText = String(value);
            if (!element) {
              return;
            }
            if (element.textContent.trim() !== nextText) {
              element.textContent = nextText;
              flashUpdate(element);
            }
          }

          function updateContainer(container, remainingPoints, remainingPlayers, totalPoints, maxPlayers) {
            if (!container) {
              return;
            }
            var pct = totalPoints ? Math.max(0, Math.min(100, Math.round((remainingPoints * 100) / totalPoints))) : 0;
            var recruited = Math.max(0, maxPlayers - remainingPlayers);
            var status = statusMeta(pct);

            Array.prototype.forEach.call(container.querySelectorAll('[data-role="purse-fill"]'), function (fill) {
              var nextClass = 'bs2-progress-fill ' + purseClass(pct);
              var nextWidth = pct + '%';
              if (fill.className !== nextClass) {
                fill.className = nextClass;
                flashUpdate(fill);
              }
              if (fill.style.width !== nextWidth) {
                fill.style.width = nextWidth;
                flashUpdate(fill.parentElement || fill);
              }
            });

            Array.prototype.forEach.call(container.querySelectorAll('[data-role="pct-label"]'), function (label) {
              var nextText = pct + '% remaining';
              if (label.textContent.trim() !== nextText) {
                label.textContent = nextText;
                flashUpdate(label);
              }
            });

            Array.prototype.forEach.call(container.querySelectorAll('[data-role="status-badge"]'), function (badge) {
              var nextClass = (badge.getAttribute('data-base-class') || 'bs2-badge') + ' ' + status.cls;
              if (badge.className !== nextClass) {
                badge.className = nextClass;
                flashUpdate(badge);
              }
              if (badge.textContent.trim() !== status.label) {
                badge.textContent = status.label;
                flashUpdate(badge);
              }
            });

            Array.prototype.forEach.call(container.querySelectorAll('[data-role="squad-value"]'), function (squad) {
              var nextText = recruited + ' / ' + maxPlayers;
              if (squad.textContent.trim() !== nextText) {
                squad.textContent = nextText;
                flashUpdate(squad);
              }
            });
          }

          function normalizePayload(payload) {
            function objectMap(source) {
              return Object.keys(source || {}).map(function (key) {
                var item = source[key];
                if (item === null || typeof item !== 'object' || Array.isArray(item)) {
                  item = { remaining_points: item };
                }
                if (item.id === undefined && item.auction_id === undefined) {
                  item.id = key;
                }
                return item;
              });
            }

            if (!payload) { return []; }
            if (Array.isArray(payload)) { return payload; }
            if (Array.isArray(payload.teams)) { return payload.teams; }
            if (Array.isArray(payload.data)) { return payload.data; }
            if (Array.isArray(payload.results)) { return payload.results; }
            if (payload.teams && typeof payload.teams === 'object') { return objectMap(payload.teams); }
            if (payload.data && typeof payload.data === 'object') { return objectMap(payload.data); }
            if (payload.results && typeof payload.results === 'object') { return objectMap(payload.results); }
            if (typeof payload === 'object') { return objectMap(payload); }
            return [];
          }

          function resolveAuctionId(entry) {
            if (!entry || typeof entry !== 'object') {
              return 0;
            }
            if (entry.id !== undefined) { return asNumber(entry.id); }
            if (entry.auction_id !== undefined) { return asNumber(entry.auction_id); }
            if (entry.auctionId !== undefined) { return asNumber(entry.auctionId); }
            if (entry.team_id && typeof entry.team_id === 'object' && entry.team_id.id !== undefined) {
              return asNumber(entry.team_id.id);
            }
            if (entry.team_id !== undefined) { return asNumber(entry.team_id); }
            return 0;
          }

          function refreshBalance() {
            if (!balanceUrl) {
              return Promise.resolve();
            }
            return fetch(balanceUrl, {
              method: 'GET',
              headers: { 'Accept': 'application/json' },
              cache: 'no-store'
            }).then(function (response) {
              if (!response.ok) {
                throw new Error('HTTP ' + response.status);
              }
              return response.json();
            }).then(function (payload) {
              normalizePayload(payload).forEach(function (entry) {
                var auctionId = resolveAuctionId(entry);
                if (!auctionId) {
                  return;
                }
                var row = document.querySelector('tr[data-auction-id="' + auctionId + '"]');
                var card = document.querySelector('.bs2-card[data-auction-id="' + auctionId + '"]');
                var totalPoints = asNumber(
                  entry.total_point !== undefined ? entry.total_point :
                  entry.total_points !== undefined ? entry.total_points :
                  entry.totalPts !== undefined ? entry.totalPts :
                  (row ? row.getAttribute('data-total-pts') : null) ||
                  (card ? card.getAttribute('data-total-pts') : null)
                );
                var maxPlayers = asNumber(
                  entry.max_players !== undefined ? entry.max_players :
                  entry.maxPlayers !== undefined ? entry.maxPlayers :
                  (row ? row.getAttribute('data-max-players') : null) ||
                  (card ? card.getAttribute('data-max-players') : null)
                );
                var remainingPoints = asNumber(
                  entry.remaining_points !== undefined ? entry.remaining_points :
                  entry.remainingPoints !== undefined ? entry.remainingPoints :
                  entry.points !== undefined ? entry.points :
                  entry.purse_remaining !== undefined ? entry.purse_remaining :
                  entry.balance !== undefined ? entry.balance : 0
                );
                var remainingPlayers = asNumber(
                  entry.remaining_players_count !== undefined ? entry.remaining_players_count :
                  entry.remainingPlayersCount !== undefined ? entry.remainingPlayersCount :
                  entry.players_needed !== undefined ? entry.players_needed :
                  entry.playersNeeded !== undefined ? entry.playersNeeded :
                  entry.remaining_players !== undefined ? entry.remaining_players : 0
                );
                var maxCall = asNumber(
                  entry.max_call !== undefined ? entry.max_call :
                  entry.maxCall !== undefined ? entry.maxCall :
                  entry.max_bid !== undefined ? entry.max_bid :
                  entry.maxBid !== undefined ? entry.maxBid :
                  entry.maxcall !== undefined ? entry.maxcall : 0
                );

                updateValueById('team-points-' + auctionId, remainingPoints);
                updateValueById('team-players-' + auctionId, remainingPlayers);
                updateValueById('team-maxcall-' + auctionId, maxCall);
                updateValueById('grid-team-points-' + auctionId, remainingPoints);
                updateValueById('grid-team-players-' + auctionId, remainingPlayers);
                updateValueById('grid-team-maxcall-' + auctionId, maxCall);

                updateContainer(row, remainingPoints, remainingPlayers, totalPoints, maxPlayers);
                updateContainer(card, remainingPoints, remainingPlayers, totalPoints, maxPlayers);
              });
            }).catch(function () {
              return null;
            });
          }

          function stopPolling() {
            if (_balanceTimer) {
              clearInterval(_balanceTimer);
              _balanceTimer = null;
            }
          }

          function startPolling() {
            stopPolling();
            _balanceTimer = setInterval(refreshBalance, 8000);
          }

          if (listBtn) {
            listBtn.addEventListener('click', function () { setView('list'); });
          }
          if (gridBtn) {
            gridBtn.addEventListener('click', function () { setView('grid'); });
          }
          if (fsBtn) {
            fsBtn.addEventListener('click', function () {
              if (document.fullscreenElement) {
                if (document.exitFullscreen) {
                  document.exitFullscreen();
                }
              } else if (htmlEl.requestFullscreen) {
                htmlEl.requestFullscreen();
              }
            });
          }

          document.addEventListener('fullscreenchange', syncFullscreenButton);
          document.addEventListener('visibilitychange', function() {
            if (document.hidden) stopPolling(); else { refreshBalance(); startPolling(); }
          });
          window.addEventListener('beforeunload', stopPolling);
          document.addEventListener('DOMContentLoaded', function () {
            setView('list');
            syncFullscreenButton();
            refreshBalance();
            if (!document.hidden) {
              startPolling();
            }
          });
        }());
      ]]></script>
      <script src="/auction_module/static/src/assets/bootstrap.bundle.min.js" defer="defer"></script>
    </body>
  </html>
</template>
