<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_users_form_auction_owner" model="ir.ui.view">
        <field name="name">res.users.form.auction_owner</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Auction Team" name="auction_team_page"
                      groups="auction_module.group_auction_group_admin">
                    <group>
                        <field name="auction_team_id" widget="many2one"
                               placeholder="Assign to an auction team…"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
